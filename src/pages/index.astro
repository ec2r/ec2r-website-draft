---
import Layout from '../layouts/Layout.astro';
import TopNav from '../components/TopNav.astro';
import BottomBar from '../components/BottomBar.astro';
import VousLeVivez from '../components/VousLeVivez.astro';
import LaMethode from '../components/LaMethode.astro';
import IlsLontVecu from '../components/IlsLontVecu.astro';
import LeProtocole from '../components/LeProtocole.astro';
import LesPraticiens from '../components/LesPraticiens.astro';
import ParlonsEn from '../components/ParlonsEn.astro';
import '../styles/global.css';
import { translations } from '../i18n/translations';

const fr = translations.fr;
const en = translations.en;

const universes = [
  { id: 'la-methode', labelFr: 'Méthode', labelEn: 'Method' },
  { id: 'ils-lont-vecu', labelFr: 'Ils l\'ont vécu', labelEn: 'They lived it' },
  { id: 'le-protocole', labelFr: 'Plateforme', labelEn: 'Platform' },
  { id: 'les-praticiens', labelFr: 'La team', labelEn: 'The team' },
  { id: 'parlons-en', labelFr: 'Parlons-en !', labelEn: 'Let\'s talk!' },
];
---

<Layout>
  <TopNav universes={universes} fr={fr} en={en} />

  <!-- Carrousel horizontal — 5 univers (Méthode = hero/intro fusionné) -->
  <main id="universe-carousel" class="universe-carousel">
    <section id="la-methode" class="universe-panel">
      <button class="universe-next-btn" data-next-universe="ils-lont-vecu">
        <span data-i18n-lang="fr">Avancer</span>
        <span data-i18n-lang="en">Next</span>
        <svg fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" /></svg>
      </button>
      <div class="universe-scroll">
        <VousLeVivez fr={fr} en={en} />
        <LaMethode fr={fr} en={en} />
      </div>
    </section>

    <section id="ils-lont-vecu" class="universe-panel">
      <button class="universe-next-btn" data-next-universe="le-protocole">
        <span data-i18n-lang="fr">Avancer</span>
        <span data-i18n-lang="en">Next</span>
        <svg fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" /></svg>
      </button>
      <div class="universe-scroll">
        <IlsLontVecu fr={fr} en={en} />
      </div>
    </section>

    <section id="le-protocole" class="universe-panel">
      <button class="universe-next-btn" data-next-universe="les-praticiens">
        <span data-i18n-lang="fr">Avancer</span>
        <span data-i18n-lang="en">Next</span>
        <svg fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" /></svg>
      </button>
      <div class="universe-scroll">
        <LeProtocole fr={fr} en={en} />
      </div>
    </section>

    <section id="les-praticiens" class="universe-panel">
      <button class="universe-next-btn" data-next-universe="parlons-en">
        <span data-i18n-lang="fr">Avancer</span>
        <span data-i18n-lang="en">Next</span>
        <svg fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" /></svg>
      </button>
      <div class="universe-scroll">
        <LesPraticiens fr={fr} en={en} />
      </div>
    </section>

    <section id="parlons-en" class="universe-panel">
      <!-- Pas de bouton Next sur le dernier univers (géré par CSS) -->
      <div class="universe-scroll">
        <ParlonsEn fr={fr} en={en} />
      </div>
    </section>
  </main>

  <BottomBar fr={fr} en={en} />
</Layout>

<script>
  // ══════════════════════════════════════════════════════════════════
  // UNIVERSE NAVIGATION BUTTONS
  // ══════════════════════════════════════════════════════════════════
  
  document.addEventListener('DOMContentLoaded', () => {
    // Boutons "Univers suivant" — scroll horizontal vers l'univers suivant
    const nextButtons = document.querySelectorAll<HTMLButtonElement>('[data-next-universe]');
    nextButtons.forEach(btn => {
      btn.addEventListener('click', () => {
        const nextId = btn.dataset.nextUniverse;
        if (nextId) {
          const nextPanel = document.getElementById(nextId);
          if (nextPanel) {
            nextPanel.scrollIntoView({ behavior: 'smooth', block: 'nearest', inline: 'start' });
          }
        }
      });
    });
  });
</script>
