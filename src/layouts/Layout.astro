---
import '../styles/fonts.css';
import AnnouncementBanner from '../components/AnnouncementBanner.astro';
import { translations, type Lang } from '../i18n/translations';

interface Props {
  lang?: Lang;
  title?: string;
  description?: string;
  /**
   * Si true, n'émet pas de hreflang EN (pour les pages sans version anglaise,
   * ex. mentions légales / politique de confidentialité — contenu juridique FR).
   */
  noAlternate?: boolean;
}

const {
  lang = 'fr',
  title,
  description,
  noAlternate = false,
} = Astro.props;

const t = translations[lang];
const resolvedTitle = title ?? t.seo.title;
const resolvedDescription = description ?? t.seo.description;

// Compute mirror URL (FR ↔ EN) for hreflang and language toggle
const path = Astro.url.pathname;
const frPath = path.startsWith('/en/') ? path.slice(3) : path === '/en' ? '/' : path;
const enPath = path.startsWith('/en/') || path === '/en' ? path : `/en${path === '/' ? '/' : path}`;
const frUrl = new URL(frPath, 'https://methode-ec2r.com').href;
const enUrl = new URL(enPath, 'https://methode-ec2r.com').href;
---

<!DOCTYPE html>
<html lang={lang} data-lang={lang}>
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content={resolvedDescription} />
  <script is:inline>
    // Theme : mode clair par défaut (sauf choix utilisateur persisté)
    (function(){var t=localStorage.getItem('ec2r-theme')||'light';document.documentElement.setAttribute('data-theme',t);})();
  </script>

  <!-- Canonical URL -->
  <link rel="canonical" href={Astro.url.href} />

  <!-- Hreflang — chaque URL pointe vers sa vraie version localisée -->
  <link rel="alternate" hreflang="fr" href={frUrl} />
  {!noAlternate && <link rel="alternate" hreflang="en" href={enUrl} />}
  <link rel="alternate" hreflang="x-default" href={frUrl} />

  <!-- OG -->
  <meta property="og:title" content={resolvedTitle} />
  <meta property="og:description" content={resolvedDescription} />
  <meta property="og:type" content="website" />
  <meta property="og:url" content={Astro.url.href} />
  <meta property="og:image" content={new URL('/images/og-image.png', Astro.url).href} />
  <meta property="og:image:width" content="1200" />
  <meta property="og:image:height" content="630" />
  <meta property="og:locale" content={lang === 'en' ? 'en_GB' : 'fr_FR'} />

  <!-- Twitter Card -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={resolvedTitle} />
  <meta name="twitter:description" content={resolvedDescription} />
  <meta name="twitter:image" content={new URL('/images/og-image.png', Astro.url).href} />

  <title>{resolvedTitle}</title>

  <!-- Favicon -->
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
  <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
  <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
  <link rel="shortcut icon" href="/favicon.ico" />

  <!-- Structured Data — Organization (localisé) -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "Organization",
    "name": "EC²R Conseil",
    "url": "https://methode-ec2r.com",
    "logo": new URL('/images/logo-ec2r.png', Astro.url).href,
    "description": resolvedDescription,
    "founder": {
      "@type": "Person",
      "name": "Stéphane Flahaut",
      "jobTitle": lang === 'en' ? "Founder, EC²R Conseil" : "Fondateur EC²R Conseil"
    },
    "contactPoint": {
      "@type": "ContactPoint",
      "email": "contact@methode-ec2r.com",
      "contactType": "customer service",
      "availableLanguage": ["French", "English"]
    },
    "sameAs": [
      "https://www.youtube.com/@stephaneflahaut-ec2rconseil",
      "https://www.linkedin.com/company/methode-ec2r/"
    ]
  })} />

  <!-- Structured Data — Service Mentor IA EC²R -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "Service",
    "name": lang === 'en' ? "EC²R AI Mentor" : "Mentor IA EC²R",
    "alternateName": ["EC2R Mentor", "Mentor EC2R", "EC²R Mentor IA"],
    "serviceType": "AI mentoring & leadership coaching",
    "provider": {
      "@type": "Organization",
      "name": "EC²R Conseil",
      "url": "https://methode-ec2r.com"
    },
    "areaServed": ["FR", "BE", "CH", "LU"],
    "description": lang === 'en'
      ? "EC²R AI Mentor: management support that extends the collective energy barometer and leadership profiles, from diagnosis to daily micro-behaviour."
      : "Mentor IA EC²R : accompagnement managérial qui prolonge le baromètre des énergies collectives et les profils de leadership, du diagnostic au micro-comportement quotidien.",
    "url": "https://methode-ec2r.com/#le-protocole",
    "audience": {
      "@type": "BusinessAudience",
      "audienceType": lang === 'en' ? "Managers, executives, HR and L&D teams" : "Managers, dirigeants, équipes RH et L&D"
    }
  })} />
</head>
<body>
  <AnnouncementBanner lang={lang} />
  <slot />

  <script>
    // Scroll reveal
    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            entry.target.classList.add('visible');
            observer.unobserve(entry.target);
          }
        });
      },
      { threshold: 0.1, rootMargin: '0px 0px -40px 0px' }
    );

    document.querySelectorAll('.reveal').forEach((el) => observer.observe(el));

    // Active nav on scroll
    const sections = document.querySelectorAll('section[id]');
    const navLinks = document.querySelectorAll('.nav-link');

    window.addEventListener('scroll', () => {
      const scrollY = window.scrollY + 100;
      sections.forEach((section) => {
        const sectionEl = section as HTMLElement;
        const top = sectionEl.offsetTop;
        const height = sectionEl.offsetHeight;
        const id = sectionEl.getAttribute('id');
        if (scrollY >= top && scrollY < top + height) {
          navLinks.forEach((link) => {
            link.classList.remove('active');
            if (link.getAttribute('href') === `#${id}`) {
              link.classList.add('active');
            }
          });
        }
      });
    });

    // One-shot migration : ancien localStorage 'ec2r-lang=en' → redirige vers /en/
    (function migrateLegacyEnUser() {
      try {
        const stored = localStorage.getItem('ec2r-lang');
        if (stored === 'en' && !location.pathname.startsWith('/en/') && location.pathname !== '/en') {
          localStorage.removeItem('ec2r-lang');
          location.replace('/en' + (location.pathname === '/' ? '/' : location.pathname) + location.search + location.hash);
        } else if (stored) {
          localStorage.removeItem('ec2r-lang');
        }
      } catch {}
    })();
  </script>
</body>
</html>
