---
interface Props {
  fr: any;
  en: any;
}
const { fr, en } = Astro.props;
---

<!-- Bandeau bas permanent — CTA "Parlons-en" -->
<div id="bottom-bar" class="fixed bottom-0 left-0 right-0 z-50
     bg-navy-950/95 backdrop-blur-lg border-t border-white/10
     transition-all duration-300">
  
  <!-- Desktop -->
  <div class="hidden sm:flex max-w-7xl mx-auto px-6 py-3.5 items-center justify-between">
    <p class="text-white/50 text-sm">
      <span data-i18n-lang="fr">Un vrai échange humain — 10 minutes pour voir comment ça résonne.</span>
      <span data-i18n-lang="en">A real human conversation — 10 minutes to see how it resonates.</span>
    </p>
    <div class="flex items-center gap-3">
      <button class="bottom-bar-navigate text-xs text-white/30 hover:text-white/60 border border-white/10 
                     hover:border-white/30 rounded-md px-3 py-1.5 transition-all"
              data-target="parlons-en">
        <span data-i18n-lang="fr">Je cherche juste un budget</span>
        <span data-i18n-lang="en">I just need a budget</span>
      </button>
      <button class="bottom-bar-navigate bg-energy-green/90 hover:bg-energy-green text-navy-950 font-semibold 
                     text-sm rounded-md px-4 py-1.5 transition-all"
              data-target="parlons-en">
        <span data-i18n-lang="fr">Ça résonne — parlons-en</span>
        <span data-i18n-lang="en">It resonates — let's talk</span>
      </button>
    </div>
  </div>

  <!-- Mobile : bouton flottant compact -->
  <div class="sm:hidden flex justify-center py-3">
    <button class="bottom-bar-navigate bg-energy-green/90 hover:bg-energy-green text-navy-950 font-semibold 
                   text-sm rounded-full px-5 py-2 shadow-lg transition-all flex items-center gap-2"
            data-target="parlons-en">
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z" />
      </svg>
      <span data-i18n-lang="fr">Parlons-en</span>
      <span data-i18n-lang="en">Let's talk</span>
    </button>
  </div>
</div>

<script>
  // Clic sur les boutons → scroll vers l'univers "parlons-en"
  document.querySelectorAll<HTMLElement>('.bottom-bar-navigate').forEach(btn => {
    btn.addEventListener('click', () => {
      const targetId = btn.dataset.target || 'parlons-en';
      const panel = document.getElementById(targetId);
      if (panel) {
        panel.scrollIntoView({ behavior: 'smooth', block: 'nearest', inline: 'start' });
      }
    });
  });
</script>
