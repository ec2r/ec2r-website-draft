---
interface Props { fr: any; en: any; frVideos: any[]; enVideos: any[]; frMuseeLabel: string; enMuseeLabel: string; }
const { fr, en, frVideos, enVideos, frMuseeLabel, enMuseeLabel } = Astro.props;

// IDs YouTube fixes (pas traduisibles)
const videoIds = ["jhq47z0GanA", "e3KEgfNuNzQ"];

const wallTagColors = [
  'bg-energy-dark/10 text-energy-dark border-energy-dark/20',
  'bg-navy-900/10 text-navy-900 border-navy-900/20',
  'bg-energy-green/10 text-energy-dark border-energy-green/30',
  'bg-energy-yellow/10 text-yellow-700 border-energy-yellow/30',
  'bg-energy-dark/10 text-energy-dark border-energy-dark/20',
  'bg-energy-green/10 text-energy-dark border-energy-green/30',
  'bg-navy-900/10 text-navy-900 border-navy-900/20',
  'bg-energy-beige/20 text-yellow-800 border-energy-beige/40',
  'bg-energy-dark/10 text-energy-dark border-energy-dark/20',
  'bg-energy-green/10 text-energy-dark border-energy-green/30',
  'bg-navy-900/10 text-navy-900 border-navy-900/20',
  'bg-energy-yellow/10 text-yellow-700 border-energy-yellow/30',
];
---

<section id="preuves" class="py-24 lg:py-32 bg-slate-50">
  <div class="max-w-7xl mx-auto px-6 lg:px-8">

    <div class="max-w-3xl mb-16 reveal">
      <p class="section-label" data-i18n-fr={fr.label} data-i18n-en={en.label}>{fr.label}</p>
      <h2 class="section-title">
        <span data-i18n-fr={fr.title1} data-i18n-en={en.title1}>{fr.title1}</span><br/>
        <span class="energy-gradient-text" data-i18n-fr={fr.title2} data-i18n-en={en.title2}>{fr.title2}</span>.
      </h2>
      <p class="section-text" data-i18n-fr={fr.intro} data-i18n-en={en.intro}>{fr.intro}</p>
    </div>

    <!-- Wall of tags -->
    <div class="mb-16 reveal">
      <div class="bg-white rounded-2xl border border-slate-200 p-8 md:p-10">
        <h3 class="font-display font-semibold text-navy-950 text-lg mb-6"
            data-i18n-fr={fr.wallTitle} data-i18n-en={en.wallTitle}>{fr.wallTitle}</h3>
        <div class="flex flex-wrap gap-3" id="wall-tags-container">
          {fr.wallTags.map((tag: string, i: number) => (
            <span class={`wall-tag ${wallTagColors[i]}`}
                  style={`animation: fadeSlideTag 0.3s ease-out ${0.05 * i}s both`}
                  data-i18n-fr={tag} data-i18n-en={en.wallTags[i]}>{tag}</span>
          ))}
          <span class="wall-tag bg-white text-slate-400 border-dashed border-slate-300 italic"
                data-i18n-fr={fr.wallMore} data-i18n-en={en.wallMore}>{fr.wallMore}</span>
        </div>
        <p class="text-slate-400 text-xs mt-6 italic"
           data-i18n-fr={fr.wallNote} data-i18n-en={en.wallNote}>{fr.wallNote}</p>
      </div>
    </div>

    <!-- Testimonials -->
    <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6 mb-20">
      {fr.testimonials.map((t: any, i: number) => (
        <div class={`reveal reveal-delay-${i + 1}`}>
          <div class="bg-white rounded-xl p-8 h-full border border-slate-200 relative group
                      hover:shadow-lg hover:shadow-navy-900/5 hover:border-energy-dark/20 transition-all duration-500">
            <span class="inline-block text-xs font-medium text-energy-dark bg-energy-dark/[0.08] px-3 py-1 rounded-full mb-5"
                  data-i18n-fr={t.type} data-i18n-en={en.testimonials[i].type}>{t.type}</span>
            <div class="relative mb-6">
              <div class="text-energy-dark/10 text-7xl font-serif leading-none absolute -top-4 -left-2 select-none">"</div>
              <blockquote class="text-slate-700 leading-relaxed relative z-10 pl-4"
                          data-i18n-fr={t.quote} data-i18n-en={en.testimonials[i].quote}>{t.quote}</blockquote>
            </div>
            <div class="border-t border-slate-100 pt-4 mt-auto">
              <p class="font-display font-semibold text-navy-950 text-sm"
                 data-i18n-fr={t.author} data-i18n-en={en.testimonials[i].author}>{t.author}</p>
              <p class="text-slate-500 text-sm"
                 data-i18n-fr={t.role} data-i18n-en={en.testimonials[i].role}>{t.role}</p>
            </div>
          </div>
        </div>
      ))}
    </div>

    <!-- Videos -->
    <div class="reveal">
      <div class="flex items-center gap-3 mb-2">
        <div class="w-2 h-8 bg-gradient-to-b from-energy-red to-energy-dark rounded-full"></div>
        <h3 class="font-display font-bold text-2xl text-navy-950"
            data-i18n-fr={fr.trajTitle} data-i18n-en={en.trajTitle}>{fr.trajTitle}</h3>
      </div>
      <p class="text-slate-500 text-sm mb-8 ml-5"
         data-i18n-fr={fr.trajSub} data-i18n-en={en.trajSub}>{fr.trajSub}</p>
      <div class="grid md:grid-cols-2 gap-8">
        {frVideos.map((video: any, i: number) => (
          <div class="group">
            <div class="relative aspect-video bg-navy-950 rounded-xl overflow-hidden shadow-lg shadow-navy-900/10 group-hover:shadow-xl transition-shadow duration-300">
              <iframe src={`https://www.youtube-nocookie.com/embed/${videoIds[i]}`}
                title={video.title} class="absolute inset-0 w-full h-full" frameborder="0"
                allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
                allowfullscreen loading="lazy"></iframe>
            </div>
            <div class="mt-4">
              <h4 class="font-display font-semibold text-navy-950"
                  data-i18n-fr={video.title} data-i18n-en={enVideos[i].title}>{video.title}</h4>
              <p class="text-sm text-energy-dark font-medium"
                 data-i18n-fr={video.subtitle} data-i18n-en={enVideos[i].subtitle}>{video.subtitle}</p>
              <p class="text-sm text-slate-500 mt-1"
                 data-i18n-fr={video.description} data-i18n-en={enVideos[i].description}>{video.description}</p>
            </div>
          </div>
        ))}
      </div>
    </div>

    <!-- Musée -->
    <div class="mt-16 reveal">
      <div class="bg-white border border-slate-200 rounded-2xl p-8 md:p-12">
        <div class="grid md:grid-cols-[1fr,auto] gap-8 items-center">
          <div>
            <p class="text-xs text-slate-400 uppercase tracking-wider font-medium mb-3"
               data-i18n-fr={frMuseeLabel} data-i18n-en={enMuseeLabel}>{frMuseeLabel}</p>
            <h4 class="font-display font-bold text-xl text-navy-950 mb-3"
                data-i18n-fr={fr.museeTitle} data-i18n-en={en.museeTitle}>{fr.museeTitle}</h4>
            <p class="text-slate-600 leading-relaxed mb-4"
               data-i18n-fr={fr.museeSub} data-i18n-en={en.museeSub}>{fr.museeSub}</p>
            <div class="flex flex-wrap gap-2 text-xs text-slate-400" id="musee-years">
              {fr.museeYears.map((y: string, i: number) => (
                <span class="px-3 py-1 rounded-full bg-slate-100"
                      data-i18n-fr={y} data-i18n-en={en.museeYears[i]}>{y}</span>
              ))}
            </div>
          </div>
          <div class="flex-shrink-0 hidden md:block">
            <div class="w-20 h-20 rounded-2xl bg-navy-950/[0.04] flex items-center justify-center">
              <svg class="w-10 h-10 text-navy-900/20" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 6v6h4.5m4.5 0a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
            </div>
          </div>
        </div>
      </div>
    </div>

  </div>
</section>

<style>
  @keyframes fadeSlideTag {
    from { opacity: 0; transform: translateY(8px); }
    to { opacity: 1; transform: translateY(0); }
  }
</style>
