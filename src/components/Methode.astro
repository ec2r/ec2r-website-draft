---
interface Props {
  fr: any;
  en: any;
}
const { fr, en } = Astro.props;

const energyColors = ['energy-dark','energy-green','energy-beige','energy-yellow','energy-green','energy-dark'];

const pilierIcons = [
  `<svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M21 21l-5.197-5.197m0 0A7.5 7.5 0 105.196 5.196a7.5 7.5 0 0010.607 10.607zM10.5 7.5v6m3-3h-6"/></svg>`,
  `<svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3"/></svg>`,
  `<svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19.5 12c0-1.232-.046-2.453-.138-3.662a4.006 4.006 0 00-3.7-3.7 48.678 48.678 0 00-7.324 0 4.006 4.006 0 00-3.7 3.7c-.017.22-.032.441-.046.662M19.5 12l3-3m-3 3l-3-3m-12 3c0 1.232.046 2.453.138 3.662a4.006 4.006 0 003.7 3.7 48.656 48.656 0 007.324 0 4.006 4.006 0 003.7-3.7c.017-.22.032-.441.046-.662M4.5 12l3 3m-3-3l-3 3"/></svg>`,
];
---

<section id="methode" class="py-24 lg:py-32 bg-white">
  <div class="max-w-7xl mx-auto px-6 lg:px-8">

    <div class="max-w-3xl mb-20 reveal">
      <p class="section-label" data-i18n-fr={fr.label} data-i18n-en={en.label}>{fr.label}</p>
      <h2 class="section-title">
        <span data-i18n-fr={fr.title1} data-i18n-en={en.title1}>{fr.title1}</span><span class="plus-accent">+</span><br/>
        <span class="energy-gradient-text" data-i18n-fr={fr.title2} data-i18n-en={en.title2}>{fr.title2}</span><span class="plus-accent">+</span><br/>
        <span data-i18n-fr={fr.title3} data-i18n-en={en.title3}>{fr.title3}</span><span class="plus-accent">+</span>
      </h2>
      <p class="section-text" data-i18n-fr={fr.intro} data-i18n-en={en.intro}>{fr.intro}</p>
    </div>

    <!-- Philosophy blocks -->
    <div class="grid md:grid-cols-3 gap-8 mb-20">
      {[
        { key: 'irm', barClass: 'bg-energy-dark' },
        { key: 'mobiliser', barClass: 'bg-gradient-to-b from-energy-red to-energy-dark' },
        { key: 'methode', barClass: 'bg-energy-green' },
      ].map(({ key, barClass }, i) => (
        <div class={`reveal reveal-delay-${i+1}`}>
          <div class="bg-slate-50 rounded-xl p-8 h-full border border-slate-100 hover:border-navy-200 transition-colors duration-300">
            <div class="flex items-center gap-3 mb-4">
              <div class={`w-2 h-8 ${barClass} rounded-full`}></div>
              <h3 class="font-display font-bold text-xl text-navy-900"
                  data-i18n-fr={(fr.blocks as any)[key].title}
                  data-i18n-en={(en.blocks as any)[key].title}>{(fr.blocks as any)[key].title}</h3>
            </div>
            <p class="text-slate-600 leading-relaxed"
               data-i18n-fr={(fr.blocks as any)[key].text}
               data-i18n-en={(en.blocks as any)[key].text}>{(fr.blocks as any)[key].text}</p>
          </div>
        </div>
      ))}
    </div>

    <!-- Piliers -->
    <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8 mb-24">
      {fr.piliers.map((pilier: any, i: number) => (
        <div class={`reveal reveal-delay-${i + 1}`}>
          <div class="relative group h-full">
            <div class="h-1 energy-gradient-bar rounded-t-lg opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>
            <div class="bg-slate-50 rounded-b-lg rounded-t-lg group-hover:rounded-t-none p-8 h-full border border-slate-100
                        group-hover:border-energy-dark/20 group-hover:shadow-xl group-hover:shadow-energy-dark/5 transition-all duration-500">
              <div class="w-12 h-12 rounded-xl bg-navy-950 text-energy-green flex items-center justify-center mb-5" set:html={pilierIcons[i]} />
              <h3 class="font-display font-bold text-xl text-navy-950 mb-3"
                  data-i18n-fr={pilier.title} data-i18n-en={en.piliers[i].title}>{pilier.title}</h3>
              <p class="text-slate-600 leading-relaxed text-[0.95rem]"
                 data-i18n-fr={pilier.description} data-i18n-en={en.piliers[i].description}>{pilier.description}</p>
            </div>
          </div>
        </div>
      ))}
    </div>

    <!-- 6 énergies -->
    <div class="mb-8 reveal">
      <h3 class="font-display font-bold text-2xl text-navy-950 mb-2">
        <span data-i18n-fr={fr.energiesTitle} data-i18n-en={en.energiesTitle}>{fr.energiesTitle}</span><span class="plus-accent">+</span>
      </h3>
      <p class="text-slate-500 text-sm" data-i18n-fr={fr.energiesSub} data-i18n-en={en.energiesSub}>{fr.energiesSub}</p>
    </div>

    <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-5">
      <p class="col-span-full text-xs text-slate-400 uppercase tracking-widest font-semibold mt-4 mb-2">
        Circuit mobilisation →
      </p>
      {fr.energies.map((energy: any, i: number) => (
        <>
          {i === 3 && (
            <p class="col-span-full text-xs text-slate-400 uppercase tracking-widest font-semibold mt-8 mb-2">
              Circuit régulation →
            </p>
          )}
          <div class={`reveal reveal-delay-${(i % 3) + 1}`}>
            <div class={`group relative bg-white border border-slate-200 rounded-xl p-6
                        hover:border-energy-dark/30 hover:shadow-lg hover:shadow-energy-dark/5
                        transition-all duration-300 h-full overflow-hidden`}>
              <div class={`absolute -top-12 -right-12 w-24 h-24 bg-${energyColors[i]} rounded-full opacity-0
                           group-hover:opacity-[0.06] blur-2xl transition-opacity duration-500`}></div>
              <div class="relative">
                <div class="flex items-center justify-between mb-4">
                  <span class="text-xs text-slate-400 font-mono tracking-wider">0{i+1}</span>
                  <div class={`w-3 h-3 rounded-full bg-${energyColors[i]} opacity-40 group-hover:opacity-100 transition-opacity`}></div>
                </div>
                <h3 class="font-display font-bold text-navy-950 text-lg mb-1">
                  <span data-i18n-fr={energy.name} data-i18n-en={en.energies[i].name}>{energy.name}</span><span class="plus-accent">+</span>
                </h3>
                <p class="text-sm text-energy-dark font-medium mb-3"
                   data-i18n-fr={energy.qualifier} data-i18n-en={en.energies[i].qualifier}>{energy.qualifier}</p>
                <p class="text-sm text-slate-500 leading-relaxed"
                   data-i18n-fr={energy.description} data-i18n-en={en.energies[i].description}>{energy.description}</p>
                <div class="mt-5 h-1 bg-slate-100 rounded-full overflow-hidden">
                  <div class={`h-full rounded-full bg-${energyColors[i]} transition-all duration-1000 ease-out`}
                       style="width: 0%" data-fill={`${40 + i * 10}%`}></div>
                </div>
              </div>
            </div>
          </div>
        </>
      ))}
    </div>

  </div>
</section>

<script>
  const bars = document.querySelectorAll('[data-fill]');
  const barObserver = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        const el = entry.target as HTMLElement;
        el.style.width = el.dataset.fill || '0%';
        barObserver.unobserve(el);
      }
    });
  }, { threshold: 0.5 });
  bars.forEach(bar => barObserver.observe(bar));
</script>
