---
interface Universe {
  id: string;
  labelFr: string;
  labelEn: string;
}
interface Props {
  universes: Universe[];
  fr: any;
  en: any;
}
const { universes } = Astro.props;
---

<!-- Progress bar segmentée par univers -->
<div id="universe-progress" class="fixed top-0 left-0 right-0 h-1.5 z-[100] flex">
  {universes.map((u, i) => (
    <div class="universe-progress-segment flex-1 h-full transition-opacity duration-300 opacity-20"
         data-universe-idx={i}
         style={`background: var(--energy-color-${i})`}>
    </div>
  ))}
</div>

<nav id="top-nav" class="fixed top-[calc(2.25rem+6px)] left-0 right-0 z-50 transition-all duration-300">
  <div class="max-w-7xl mx-auto px-4 lg:px-8 flex items-center justify-between h-16 lg:h-18">
    <!-- Logo : Méthode EC²R (² collé) — batterie SVG identique à ec2r-app (shared/_ec2r_battery) -->
    <a href="/" class="flex items-center gap-2 group text-ink" id="logo-home" aria-label="Méthode EC²R">
      <svg class="h-7 lg:h-8 w-auto transition-all duration-300" viewBox="0 0 24 24" fill="none" aria-hidden="true">
        <rect x="2" y="6" width="17" height="12" rx="2" stroke="currentColor" stroke-width="1.5"/>
        <rect x="20.5" y="9.5" width="1.5" height="5" rx="0.75" fill="currentColor"/>
        <rect x="4.5" y="8.5" width="2" height="7" rx="0.5" fill="#DC2626"/>
        <rect x="7" y="8.5" width="2" height="7" rx="0.5" fill="#EAB308"/>
        <rect x="9.5" y="8.5" width="2" height="7" rx="0.5" fill="#C9A56E"/>
        <rect x="12" y="8.5" width="2" height="7" rx="0.5" fill="#22C55E"/>
        <rect x="14.5" y="8.5" width="2" height="7" rx="0.5" fill="#166534"/>
        <path d="M 11.75 3.5 L 8.75 7.75 L 11 7.75 L 9.95 11 L 13.25 6.75 L 11 6.75 L 12.05 3.5 Z"
              fill="#EAB308" stroke="currentColor" stroke-width="0.3" stroke-linejoin="round"/>
      </svg>
      <span class="font-display font-extrabold text-ink text-base lg:text-lg leading-none whitespace-nowrap">
        Méthode&nbsp;EC<sup style="font-size:0.62em;margin:0 -0.08em;vertical-align:0.4em">2</sup>R
      </span>
    </a>

    <!-- Desktop : univers tabs -->
    <ul class="hidden lg:flex items-center gap-1">
      {universes.map((u, i) => (
        <li>
          <button class="universe-tab px-3 py-1.5 rounded-md text-sm font-semibold tracking-wide transition-all duration-200
                         text-ink-subtle hover:text-ink hover:bg-surface-alt
                         data-[active]:text-ink data-[active]:bg-surface-raised"
                  data-universe-target={u.id}
                  data-idx={i}>
            <span data-i18n-lang="fr">{u.labelFr}</span>
            <span data-i18n-lang="en">{u.labelEn}</span>
          </button>
        </li>
      ))}
    </ul>

    <!-- Lang + Theme toggles + Burger (mobile) -->
    <div class="flex items-center gap-2">
      <!-- Lang toggle : version courte mobile (juste la langue active), version longue desktop (drapeaux + FR · EN) -->
      <button id="lang-toggle" aria-label="Switch language"
        class="flex items-center gap-1 text-xs font-semibold tracking-widest text-ink-subtle
               hover:text-ink transition-colors duration-200 border border-border-subtle
               hover:border-border-strong rounded-md px-2 py-1.5">
        <!-- Mobile : juste FR ou EN -->
        <span id="lang-current-mobile" class="lg:hidden">FR</span>
        <!-- Desktop : drapeau FR · drapeau EN avec opacité -->
        <span id="lang-fr-flag" class="hidden lg:inline text-sm leading-none">🇫🇷</span>
        <span id="lang-current" class="hidden lg:inline">FR</span>
        <span class="hidden lg:inline text-ink-disabled mx-0.5">·</span>
        <span id="lang-en-flag" class="hidden lg:inline text-sm leading-none" style="opacity:0.4">🇬🇧</span>
        <span id="lang-other" class="hidden lg:inline text-ink-disabled">EN</span>
      </button>
      <!-- Theme toggle (mode clair par défaut, gros bouton — req TGlT0tmZ) — texte masqué sur mobile -->
      <button id="theme-toggle" aria-label="Basculer mode clair/sombre"
        class="flex items-center gap-1.5 text-xs font-semibold text-ink-muted
               hover:text-ink transition-colors duration-200 border border-border-subtle
               hover:border-border-strong rounded-md px-2 py-1.5 lg:px-3">
        <svg id="theme-icon-sun" class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707M16 12a4 4 0 11-8 0 4 4 0 018 0z" />
        </svg>
        <svg id="theme-icon-moon" class="w-4 h-4 hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z" />
        </svg>
        <span id="theme-label" class="hidden lg:inline">Clair</span>
      </button>
      <!-- Burger mobile (ouvre menu univers) -->
      <button id="mobile-menu-toggle" type="button" aria-label="Menu" aria-expanded="false"
        class="lg:hidden flex items-center justify-center p-2 text-ink border border-border-subtle rounded-md">
        <svg id="burger-open" class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
        </svg>
        <svg id="burger-close" class="w-5 h-5 hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
        </svg>
      </button>
    </div>
  </div>

  <!-- Menu mobile (déroulant univers) -->
  <div id="mobile-menu" class="hidden lg:hidden bg-[rgb(var(--nav-bg))] backdrop-blur-lg border-t border-border-subtle">
    <ul class="px-4 py-3 space-y-1">
      {universes.map((u, i) => (
        <li>
          <button class="universe-tab mobile-menu-item w-full text-left px-3 py-3 rounded-md text-base font-semibold
                         text-ink-subtle hover:text-ink hover:bg-surface-alt
                         data-[active]:text-ink data-[active]:bg-surface-raised flex items-center gap-3"
                  data-universe-target={u.id}
                  data-idx={i}>
            <span class="w-2 h-2 rounded-full flex-shrink-0" style={`background: var(--energy-color-${i})`}></span>
            <span data-i18n-lang="fr">{u.labelFr}</span>
            <span data-i18n-lang="en">{u.labelEn}</span>
          </button>
        </li>
      ))}
    </ul>
  </div>
</nav>

<!-- Bouton "Remonter en haut" — mobile uniquement, fixe en bas-droit.
     Hors <nav> car backdrop-filter sur la nav créerait un containing block
     pour les descendants fixed, et le bouton serait positionné relativement à la nav. -->
<button id="scroll-top-btn" class="scroll-top-btn" aria-label="Remonter en haut">
  <svg fill="none" stroke="currentColor" stroke-width="2.2" viewBox="0 0 24 24">
    <path stroke-linecap="round" stroke-linejoin="round" d="M5 15l7-7 7 7"/>
  </svg>
</button>

<script>
  const carousel = document.getElementById('universe-carousel')!;
  const tabs = document.querySelectorAll<HTMLElement>('.universe-tab');
  const segments = document.querySelectorAll<HTMLElement>('.universe-progress-segment');
  const logoBtn = document.getElementById('logo-home')!;
  const mobileMenu = document.getElementById('mobile-menu')!;
  const mobileMenuToggle = document.getElementById('mobile-menu-toggle')!;
  const burgerOpen = document.getElementById('burger-open')!;
  const burgerClose = document.getElementById('burger-close')!;
  let currentIdx = 0;

  let lastIdx = 0;
  let isClickNav = false;

  function closeMobileMenu() {
    mobileMenu.classList.add('hidden');
    burgerOpen.classList.remove('hidden');
    burgerClose.classList.add('hidden');
    mobileMenuToggle.setAttribute('aria-expanded', 'false');
  }

  function setActiveUniverse(idx: number) {
    const previousIdx = lastIdx;
    currentIdx = idx;

    // Tabs (desktop + mobile menu items partagent .universe-tab) — match via data-idx
    tabs.forEach((t) => {
      const tabIdx = parseInt(t.dataset.idx || '0', 10);
      if (tabIdx === idx) t.setAttribute('data-active', '');
      else t.removeAttribute('data-active');
    });

    // Progress segments
    segments.forEach((s, i) => {
      s.style.opacity = i <= idx ? '1' : '0.2';
    });

    // Background nav
    const nav = document.getElementById('top-nav')!;
    nav.classList.add('bg-[rgb(var(--nav-bg))]', 'backdrop-blur-lg');

    // Notifier les autres composants (BottomBar, scroll-to-top) du changement d'univers
    document.dispatchEvent(new CustomEvent('universechange', { detail: { idx, total: panels.length } }));

    // Reset scroll vertical du nouveau panneau selon direction
    // (sauf si click nav: déjà reset top en amont du scrollIntoView)
    if (!isClickNav && idx !== previousIdx) {
      const scrollEl = (panels[idx] as HTMLElement)?.querySelector('.universe-scroll') as HTMLElement;
      if (scrollEl) {
        if (idx > previousIdx) {
          // Forward (scroll suivant) → arriver en haut
          scrollEl.scrollTo({ top: 0, behavior: 'smooth' });
        } else {
          // Backward (scroll précédent) → arriver en bas
          scrollEl.scrollTo({ top: scrollEl.scrollHeight, behavior: 'smooth' });
        }
      }
    }
    lastIdx = idx;
  }

  // Click tab → reset scroll top + scroll to panel + close mobile menu
  tabs.forEach(tab => {
    tab.addEventListener('click', () => {
      const targetId = tab.dataset.universeTarget!;
      const panel = document.getElementById(targetId);
      if (panel) {
        isClickNav = true;
        const scrollEl = panel.querySelector('.universe-scroll') as HTMLElement;
        if (scrollEl) scrollEl.scrollTop = 0;
        panel.scrollIntoView({ behavior: 'smooth', block: 'nearest', inline: 'start' });
        setTimeout(() => { isClickNav = false; }, 1000);
      }
      closeMobileMenu();
    });
  });

  // Burger toggle (mobile)
  mobileMenuToggle.addEventListener('click', () => {
    const open = mobileMenu.classList.contains('hidden');
    if (open) {
      mobileMenu.classList.remove('hidden');
      burgerOpen.classList.add('hidden');
      burgerClose.classList.remove('hidden');
      mobileMenuToggle.setAttribute('aria-expanded', 'true');
    } else {
      closeMobileMenu();
    }
  });

  // Logo → retour univers 1, reset top
  logoBtn.addEventListener('click', (e) => {
    e.preventDefault();
    const first = carousel.querySelector('.universe-panel') as HTMLElement;
    if (first) {
      isClickNav = true;
      const scrollEl = first.querySelector('.universe-scroll') as HTMLElement;
      if (scrollEl) scrollEl.scrollTop = 0;
      first.scrollIntoView({ behavior: 'smooth', block: 'nearest', inline: 'start' });
      setTimeout(() => { isClickNav = false; }, 1000);
    }
  });

  // IntersectionObserver pour détecter le panneau actif
  const panels = carousel.querySelectorAll('.universe-panel');
  const observer = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting && entry.intersectionRatio >= 0.5) {
        const idx = Array.from(panels).indexOf(entry.target as Element);
        if (idx >= 0) setActiveUniverse(idx);
      }
    });
  }, {
    root: carousel,
    threshold: 0.5
  });

  panels.forEach(p => observer.observe(p));

  // Init
  setActiveUniverse(0);

  // Lang toggle
  const langBtn = document.getElementById('lang-toggle')!;
  const langCur = document.getElementById('lang-current')!;
  const langOth = document.getElementById('lang-other')!;
  const langCurMobile = document.getElementById('lang-current-mobile')!;

  // Init affichage selon lang persistée (Layout pose data-lang au DOMContentLoaded — on relit ici)
  const initLang = (document.documentElement.getAttribute('data-lang') as string) || localStorage.getItem('ec2r-lang') || 'fr';
  langCurMobile.textContent = initLang.toUpperCase();

  langBtn.addEventListener('click', () => {
    const cur = document.documentElement.getAttribute('data-lang') || 'fr';
    const next = cur === 'fr' ? 'en' : 'fr';
    localStorage.setItem('ec2r-lang', next);
    document.documentElement.setAttribute('data-lang', next);
    langCur.textContent = next.toUpperCase();
    langOth.textContent = next === 'fr' ? 'EN' : 'FR';
    langCurMobile.textContent = next.toUpperCase();
    const frFlag = document.getElementById('lang-fr-flag') as HTMLElement;
    const enFlag = document.getElementById('lang-en-flag') as HTMLElement;
    if (frFlag && enFlag) {
      frFlag.style.opacity = next === 'fr' ? '1' : '0.4';
      enFlag.style.opacity = next === 'en' ? '1' : '0.4';
    }
  });

  // ── Theme toggle (light default, persisted in localStorage) ────────
  const themeBtn = document.getElementById('theme-toggle');
  const themeLabel = document.getElementById('theme-label');
  const themeIconSun = document.getElementById('theme-icon-sun');
  const themeIconMoon = document.getElementById('theme-icon-moon');

  function applyTheme(theme: string) {
    document.documentElement.setAttribute('data-theme', theme);
    // Affiche l'ÉTAT courant (soleil = clair, lune = sombre), pas la cible
    if (themeLabel) themeLabel.textContent = theme === 'light' ? 'Clair' : 'Sombre';
    if (themeIconSun && themeIconMoon) {
      themeIconSun.classList.toggle('hidden', theme !== 'light');
      themeIconMoon.classList.toggle('hidden', theme === 'light');
    }
  }

  const savedTheme = localStorage.getItem('ec2r-theme') || 'light';
  applyTheme(savedTheme);

  themeBtn?.addEventListener('click', () => {
    const cur = document.documentElement.getAttribute('data-theme') || 'dark';
    const next = cur === 'light' ? 'dark' : 'light';
    localStorage.setItem('ec2r-theme', next);
    applyTheme(next);
  });

  // Swipe mobile pour naviguer entre univers
  // Exige un mouvement franchement horizontal pour éviter les déclenchements
  // sur un scroll en diagonale (req. Luc — sensibilité trop élevée)
  let touchStartX = 0;
  let touchStartY = 0;
  carousel.addEventListener('touchstart', (e) => {
    touchStartX = e.touches[0].clientX;
    touchStartY = e.touches[0].clientY;
  }, { passive: true });
  carousel.addEventListener('touchend', (e) => {
    const dx = e.changedTouches[0].clientX - touchStartX;
    const dy = e.changedTouches[0].clientY - touchStartY;
    const absX = Math.abs(dx);
    const absY = Math.abs(dy);
    // Seuils renforcés : déplacement horizontal min 90px ET dominance horizontale forte (>1.8× vertical)
    if (absX < 90 || absX < absY * 1.8) return;
    const next = dx < 0 ? Math.min(currentIdx + 1, panels.length - 1) : Math.max(currentIdx - 1, 0);
    (panels[next] as HTMLElement).scrollIntoView({ behavior: 'smooth', block: 'nearest', inline: 'start' });
  }, { passive: true });

  // ── Wheel navigation (desktop) ──────────────────────────────────
  // Redirection vers l'univers suivant/précédent quand le panel
  // atteint son bord vertical (ou si le contenu n'est pas scrollable).
  let isWheelNavigating = false;

  carousel.addEventListener('wheel', (e: WheelEvent) => {
    // Trackpad avec swipe horizontal → laisser le carousel gérer nativement
    if (Math.abs(e.deltaX) > Math.abs(e.deltaY)) return;

    const activePanel = panels[currentIdx] as HTMLElement;
    const scrollEl = activePanel?.querySelector('.universe-scroll') as HTMLElement;
    if (!scrollEl) return;

    const goingDown = e.deltaY > 0;
    const atTop    = scrollEl.scrollTop <= 1;
    const atBottom = scrollEl.scrollTop + scrollEl.clientHeight >= scrollEl.scrollHeight - 1;
    const noScroll = scrollEl.scrollHeight <= scrollEl.clientHeight + 2;

    const shouldNavigate = noScroll || (goingDown && atBottom) || (!goingDown && atTop);

    if (shouldNavigate) {
      e.preventDefault();
      if (isWheelNavigating) return;

      const next = goingDown
        ? Math.min(currentIdx + 1, panels.length - 1)
        : Math.max(currentIdx - 1, 0);

      if (next !== currentIdx) {
        isWheelNavigating = true;
        (panels[next] as HTMLElement).scrollIntoView({ behavior: 'smooth', block: 'nearest', inline: 'start' });
        setTimeout(() => { isWheelNavigating = false; }, 900);
      }
    }
  }, { passive: false });

  // ── Bouton "Remonter en haut" (mobile) ──────────────────────────
  const scrollTopBtn = document.getElementById('scroll-top-btn') as HTMLButtonElement;
  let activeScrollEl: HTMLElement | null = null;

  function attachScrollListener() {
    if (activeScrollEl) activeScrollEl.removeEventListener('scroll', updateScrollTopVisibility);
    activeScrollEl = (panels[currentIdx] as HTMLElement)?.querySelector('.universe-scroll') as HTMLElement;
    if (activeScrollEl) {
      activeScrollEl.addEventListener('scroll', updateScrollTopVisibility, { passive: true });
      updateScrollTopVisibility();
    }
  }

  function updateScrollTopVisibility() {
    if (!scrollTopBtn || !activeScrollEl) return;
    const isMobile = window.matchMedia('(max-width: 1023px)').matches;
    if (!isMobile) {
      scrollTopBtn.style.display = 'none';
      scrollTopBtn.classList.remove('visible');
      return;
    }
    const show = activeScrollEl.scrollTop > 200;
    scrollTopBtn.style.display = 'flex';
    scrollTopBtn.classList.toggle('visible', show);
  }

  scrollTopBtn?.addEventListener('click', () => {
    if (activeScrollEl) activeScrollEl.scrollTo({ top: 0, behavior: 'smooth' });
  });

  document.addEventListener('universechange', () => {
    setTimeout(attachScrollListener, 50);
  });
  window.addEventListener('resize', updateScrollTopVisibility);
  setTimeout(attachScrollListener, 100);

  // ── Keyboard navigation (← →) ───────────────────────────────────
  document.addEventListener('keydown', (e: KeyboardEvent) => {
    const tag = (e.target as Element).tagName;
    if (['INPUT', 'TEXTAREA', 'SELECT'].includes(tag)) return;

    if (e.key === 'ArrowRight') {
      e.preventDefault();
      const next = Math.min(currentIdx + 1, panels.length - 1);
      (panels[next] as HTMLElement).scrollIntoView({ behavior: 'smooth', block: 'nearest', inline: 'start' });
    } else if (e.key === 'ArrowLeft') {
      e.preventDefault();
      const next = Math.max(currentIdx - 1, 0);
      (panels[next] as HTMLElement).scrollIntoView({ behavior: 'smooth', block: 'nearest', inline: 'start' });
    }
  });
</script>

<style>
  :root {
    --energy-color-0: #DC2626; /* rouge */
    --energy-color-1: #EAB308; /* jaune */
    --energy-color-2: #C9A56E; /* beige */
    --energy-color-3: #22C55E; /* vert clair */
    --energy-color-4: #166534; /* vert foncé */
    --energy-color-5: #3B82F6; /* bleu — parlons-en */
  }

  .universe-tab[data-active] {
    color: rgb(var(--ink));
    background: rgb(var(--surface-inverse) / 0.08);
  }
</style>
