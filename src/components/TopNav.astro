---
interface Universe {
  id: string;
  labelFr: string;
  labelEn: string;
}
interface Props {
  universes: Universe[];
  fr: any;
  en: any;
}
const { universes } = Astro.props;
---

<!-- Progress bar segmentée par univers -->
<div id="universe-progress" class="fixed top-0 left-0 right-0 h-1.5 z-[100] flex">
  {universes.map((u, i) => (
    <div class="universe-progress-segment flex-1 h-full transition-opacity duration-300 opacity-20"
         data-universe-idx={i}
         style={`background: var(--energy-color-${i})`}>
    </div>
  ))}
</div>

<nav id="top-nav" class="fixed top-[calc(2.25rem+6px)] left-0 right-0 z-50 transition-all duration-300">
  <div class="max-w-7xl mx-auto px-4 lg:px-8 flex items-center justify-between h-16 lg:h-18">
    <!-- Logo : Méthode EC²R (² collé) -->
    <a href="/" class="flex items-center gap-2 group" id="logo-home" aria-label="Méthode EC²R">
      <img src="/images/logo-ec2r.png" alt="" class="h-7 lg:h-8 transition-all duration-300" />
      <span class="font-display font-extrabold text-white text-base lg:text-lg leading-none whitespace-nowrap">
        Méthode&nbsp;EC<sup style="font-size:0.62em;margin:0 -0.08em;vertical-align:0.4em">2</sup>R
      </span>
    </a>

    <!-- Desktop : univers tabs -->
    <ul class="hidden lg:flex items-center gap-1">
      {universes.map((u, i) => (
        <li>
          <button class="universe-tab px-3 py-1.5 rounded-md text-sm font-semibold tracking-wide transition-all duration-200
                         text-white/50 hover:text-white hover:bg-white/5
                         data-[active]:text-white data-[active]:bg-white/10"
                  data-universe-target={u.id}
                  data-idx={i}>
            <span data-i18n-lang="fr">{u.labelFr}</span>
            <span data-i18n-lang="en">{u.labelEn}</span>
          </button>
        </li>
      ))}
    </ul>

    <!-- Mobile : indicateur univers actif + hamburger -->
    <div class="flex items-center gap-3 lg:hidden">
      <span id="mobile-universe-label" class="text-white/70 text-sm font-semibold truncate max-w-[140px]">
        {universes[0].labelFr}
      </span>
      <!-- Dots indicateurs -->
      <div class="flex gap-1">
        {universes.map((_, i) => (
          <span class="universe-dot w-1.5 h-1.5 rounded-full bg-white/20 transition-all duration-200"
                data-dot-idx={i}></span>
        ))}
      </div>
    </div>

    <!-- Theme + Lang toggles -->
    <div class="flex items-center gap-2">
      <!-- Theme toggle (mode clair par défaut, gros bouton — req TGlT0tmZ) -->
      <button id="theme-toggle" aria-label="Basculer mode clair/sombre"
        class="flex items-center gap-1.5 text-xs font-semibold text-white/60
               hover:text-white transition-colors duration-200 border border-white/15
               hover:border-white/40 rounded-md px-3 py-1.5">
        <svg id="theme-icon-sun" class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707M16 12a4 4 0 11-8 0 4 4 0 018 0z" />
        </svg>
        <svg id="theme-icon-moon" class="w-4 h-4 hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z" />
        </svg>
        <span id="theme-label">Clair</span>
      </button>
      <button id="lang-toggle" aria-label="Switch language"
        class="flex items-center gap-1 text-xs font-semibold tracking-widest text-white/50
               hover:text-white/80 transition-colors duration-200 border border-white/10
               hover:border-white/30 rounded-md px-2 py-1">
        <span id="lang-fr-flag" class="text-sm leading-none">🇫🇷</span>
        <span id="lang-current">FR</span>
        <span class="text-white/15 mx-0.5">·</span>
        <span id="lang-en-flag" class="text-sm leading-none" style="opacity:0.4">🇬🇧</span>
        <span id="lang-other" class="text-white/20">EN</span>
      </button>
    </div>
  </div>
</nav>

<script>
  const carousel = document.getElementById('universe-carousel')!;
  const tabs = document.querySelectorAll<HTMLElement>('.universe-tab');
  const dots = document.querySelectorAll<HTMLElement>('.universe-dot');
  const segments = document.querySelectorAll<HTMLElement>('.universe-progress-segment');
  const mobileLabel = document.getElementById('mobile-universe-label')!;
  const logoBtn = document.getElementById('logo-home')!;
  let currentIdx = 0;

  // Labels pour mobile
  const labelsFr = Array.from(tabs).map(t => t.querySelector('[data-i18n-lang="fr"]')?.textContent || '');
  const labelsEn = Array.from(tabs).map(t => t.querySelector('[data-i18n-lang="en"]')?.textContent || '');

  let lastIdx = 0;
  let isClickNav = false;

  function setActiveUniverse(idx: number) {
    const previousIdx = lastIdx;
    currentIdx = idx;
    const lang = document.documentElement.getAttribute('data-lang') || 'fr';

    // Tabs
    tabs.forEach((t, i) => {
      if (i === idx) t.setAttribute('data-active', '');
      else t.removeAttribute('data-active');
    });

    // Dots
    dots.forEach((d, i) => {
      d.classList.toggle('bg-white', i === idx);
      d.classList.toggle('scale-125', i === idx);
      d.classList.toggle('bg-white/20', i !== idx);
    });

    // Progress segments
    segments.forEach((s, i) => {
      s.style.opacity = i <= idx ? '1' : '0.2';
    });

    // Mobile label
    mobileLabel.textContent = lang === 'en' ? labelsEn[idx] : labelsFr[idx];

    // Background nav
    const nav = document.getElementById('top-nav')!;
    nav.classList.add('bg-navy-950/95', 'backdrop-blur-lg');

    // Reset scroll vertical du nouveau panneau selon direction
    // (sauf si click nav: déjà reset top en amont du scrollIntoView)
    if (!isClickNav && idx !== previousIdx) {
      const scrollEl = (panels[idx] as HTMLElement)?.querySelector('.universe-scroll') as HTMLElement;
      if (scrollEl) {
        if (idx > previousIdx) {
          // Forward (scroll suivant) → arriver en haut
          scrollEl.scrollTo({ top: 0, behavior: 'smooth' });
        } else {
          // Backward (scroll précédent) → arriver en bas
          scrollEl.scrollTo({ top: scrollEl.scrollHeight, behavior: 'smooth' });
        }
      }
    }
    lastIdx = idx;
  }

  // Click tab → reset scroll top + scroll to panel
  tabs.forEach(tab => {
    tab.addEventListener('click', () => {
      const targetId = tab.dataset.universeTarget!;
      const panel = document.getElementById(targetId);
      if (panel) {
        isClickNav = true;
        const scrollEl = panel.querySelector('.universe-scroll') as HTMLElement;
        if (scrollEl) scrollEl.scrollTop = 0;
        panel.scrollIntoView({ behavior: 'smooth', block: 'nearest', inline: 'start' });
        setTimeout(() => { isClickNav = false; }, 1000);
      }
    });
  });

  // Logo → retour univers 1, reset top
  logoBtn.addEventListener('click', (e) => {
    e.preventDefault();
    const first = carousel.querySelector('.universe-panel') as HTMLElement;
    if (first) {
      isClickNav = true;
      const scrollEl = first.querySelector('.universe-scroll') as HTMLElement;
      if (scrollEl) scrollEl.scrollTop = 0;
      first.scrollIntoView({ behavior: 'smooth', block: 'nearest', inline: 'start' });
      setTimeout(() => { isClickNav = false; }, 1000);
    }
  });

  // IntersectionObserver pour détecter le panneau actif
  const panels = carousel.querySelectorAll('.universe-panel');
  const observer = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting && entry.intersectionRatio >= 0.5) {
        const idx = Array.from(panels).indexOf(entry.target as Element);
        if (idx >= 0) setActiveUniverse(idx);
      }
    });
  }, {
    root: carousel,
    threshold: 0.5
  });

  panels.forEach(p => observer.observe(p));

  // Init
  setActiveUniverse(0);

  // Lang toggle
  const langBtn = document.getElementById('lang-toggle')!;
  const langCur = document.getElementById('lang-current')!;
  const langOth = document.getElementById('lang-other')!;

  langBtn.addEventListener('click', () => {
    const cur = document.documentElement.getAttribute('data-lang') || 'fr';
    const next = cur === 'fr' ? 'en' : 'fr';
    localStorage.setItem('ec2r-lang', next);
    document.documentElement.setAttribute('data-lang', next);
    langCur.textContent = next.toUpperCase();
    langOth.textContent = next === 'fr' ? 'EN' : 'FR';
    const frFlag = document.getElementById('lang-fr-flag') as HTMLElement;
    const enFlag = document.getElementById('lang-en-flag') as HTMLElement;
    if (frFlag && enFlag) {
      frFlag.style.opacity = next === 'fr' ? '1' : '0.4';
      enFlag.style.opacity = next === 'en' ? '1' : '0.4';
    }
    // Maj mobile label
    mobileLabel.textContent = next === 'en' ? labelsEn[currentIdx] : labelsFr[currentIdx];
  });

  // ── Theme toggle (light default, persisted in localStorage) ────────
  const themeBtn = document.getElementById('theme-toggle');
  const themeLabel = document.getElementById('theme-label');
  const themeIconSun = document.getElementById('theme-icon-sun');
  const themeIconMoon = document.getElementById('theme-icon-moon');

  function applyTheme(theme: string) {
    document.documentElement.setAttribute('data-theme', theme);
    if (themeLabel) themeLabel.textContent = theme === 'light' ? 'Sombre' : 'Clair';
    if (themeIconSun && themeIconMoon) {
      themeIconSun.classList.toggle('hidden', theme === 'light');
      themeIconMoon.classList.toggle('hidden', theme !== 'light');
    }
  }

  const savedTheme = localStorage.getItem('ec2r-theme') || 'dark';
  applyTheme(savedTheme);

  themeBtn?.addEventListener('click', () => {
    const cur = document.documentElement.getAttribute('data-theme') || 'dark';
    const next = cur === 'light' ? 'dark' : 'light';
    localStorage.setItem('ec2r-theme', next);
    applyTheme(next);
  });

  // Swipe mobile pour naviguer entre univers (optionnel, le scroll snap gère déjà)
  let touchStartX = 0;
  carousel.addEventListener('touchstart', (e) => { touchStartX = e.touches[0].clientX; }, { passive: true });
  carousel.addEventListener('touchend', (e) => {
    const dx = e.changedTouches[0].clientX - touchStartX;
    if (Math.abs(dx) < 60) return;
    const next = dx < 0 ? Math.min(currentIdx + 1, panels.length - 1) : Math.max(currentIdx - 1, 0);
    (panels[next] as HTMLElement).scrollIntoView({ behavior: 'smooth', block: 'nearest', inline: 'start' });
  }, { passive: true });

  // ── Wheel navigation (desktop) ──────────────────────────────────
  // Redirection vers l'univers suivant/précédent quand le panel
  // atteint son bord vertical (ou si le contenu n'est pas scrollable).
  let isWheelNavigating = false;

  carousel.addEventListener('wheel', (e: WheelEvent) => {
    // Trackpad avec swipe horizontal → laisser le carousel gérer nativement
    if (Math.abs(e.deltaX) > Math.abs(e.deltaY)) return;

    const activePanel = panels[currentIdx] as HTMLElement;
    const scrollEl = activePanel?.querySelector('.universe-scroll') as HTMLElement;
    if (!scrollEl) return;

    const goingDown = e.deltaY > 0;
    const atTop    = scrollEl.scrollTop <= 1;
    const atBottom = scrollEl.scrollTop + scrollEl.clientHeight >= scrollEl.scrollHeight - 1;
    const noScroll = scrollEl.scrollHeight <= scrollEl.clientHeight + 2;

    const shouldNavigate = noScroll || (goingDown && atBottom) || (!goingDown && atTop);

    if (shouldNavigate) {
      e.preventDefault();
      if (isWheelNavigating) return;

      const next = goingDown
        ? Math.min(currentIdx + 1, panels.length - 1)
        : Math.max(currentIdx - 1, 0);

      if (next !== currentIdx) {
        isWheelNavigating = true;
        (panels[next] as HTMLElement).scrollIntoView({ behavior: 'smooth', block: 'nearest', inline: 'start' });
        setTimeout(() => { isWheelNavigating = false; }, 900);
      }
    }
  }, { passive: false });

  // ── Keyboard navigation (← →) ───────────────────────────────────
  document.addEventListener('keydown', (e: KeyboardEvent) => {
    const tag = (e.target as Element).tagName;
    if (['INPUT', 'TEXTAREA', 'SELECT'].includes(tag)) return;

    if (e.key === 'ArrowRight') {
      e.preventDefault();
      const next = Math.min(currentIdx + 1, panels.length - 1);
      (panels[next] as HTMLElement).scrollIntoView({ behavior: 'smooth', block: 'nearest', inline: 'start' });
    } else if (e.key === 'ArrowLeft') {
      e.preventDefault();
      const next = Math.max(currentIdx - 1, 0);
      (panels[next] as HTMLElement).scrollIntoView({ behavior: 'smooth', block: 'nearest', inline: 'start' });
    }
  });
</script>

<style>
  :root {
    --energy-color-0: #DC2626; /* rouge */
    --energy-color-1: #EAB308; /* jaune */
    --energy-color-2: #C9A56E; /* beige */
    --energy-color-3: #22C55E; /* vert clair */
    --energy-color-4: #166534; /* vert foncé */
    --energy-color-5: #3B82F6; /* bleu — parlons-en */
  }

  .universe-tab[data-active] {
    color: white;
    background: rgba(255,255,255,0.1);
  }
</style>
