---
/**
 * Mur de témoignages — "Ils l'ont déjà vécu"
 * Données réelles extraites des commentaires LinkedIn (non sollicités).
 *
 * Vue générique : tous les témoignages en mur animé, filtrables par tag/secteur.
 * Vue segmentée (backup) : découpage par secteur + niveau d'impact.
 */
import { testimonials, sectorLabels, impactLabels, allTags, allSectors, type Sector, type ImpactLevel } from '../data/testimonials';

// Labels bilingues inline
const i18n = {
  label:       { fr: 'Ils le vivent',              en: 'They live it' },
  title1:      { fr: 'Ce sont eux',                en: 'These are them' },
  title2:      { fr: 'qui le racontent',           en: 'who tell you' },
  intro:       {
    fr: "Pas de témoignages sollicités. Pas de citations anonymisées. Ce que vous lisez ici, ce sont des mots publiés spontanément sur LinkedIn — des dirigeants, des présidents d'ordres professionnels, des managers de terrain. Ils définissent mieux que nous ce que produit la méthode.",
    en: "No solicited testimonials. No anonymised quotes. What you read here are words published spontaneously on LinkedIn — executives, professional order presidents, field managers. They define better than us what the method produces.",
  },
  statVerif:   { fr: 'témoignages\nvérifiables',   en: 'verifiable\ntestimonials' },
  statSectors: { fr: "secteurs\nd'activité",       en: 'sectors\nof activity' },
  statUnsolit: { fr: 'non sollicités\npublics sur LinkedIn', en: 'unsolicited\npublic on LinkedIn' },
  filterAll:   { fr: 'Tous',                       en: 'All' },
  sectorAll:   { fr: 'Tous les secteurs',          en: 'All sectors' },
  seeLinkedIn: { fr: 'Voir sur LinkedIn',          en: 'See on LinkedIn' },
  emptyState:  { fr: 'Aucun témoignage pour ce filtre.', en: 'No testimonials for this filter.' },
  resetFilter: { fr: 'Voir tous les témoignages', en: 'See all testimonials' },
};

// Group by sector for segmented view
const bySector = allSectors.map(s => ({
  sector: s,
  label: sectorLabels[s],
  items: testimonials.filter(t => t.sector === s),
}));

// Tag frequency for word cloud sizing
const tagFreq: Record<string, number> = {};
testimonials.forEach(t => t.tags.forEach(tag => { tagFreq[tag] = (tagFreq[tag] || 0) + 1; }));
const topTags = Object.entries(tagFreq).sort((a, b) => b[1] - a[1]).slice(0, 25);

// Sector colors
const sectorColors: Record<Sector, string> = {
  'expertise-comptable': 'bg-blue-50 text-blue-700 border-blue-200',
  'immobilier':          'bg-green-50 text-green-700 border-green-200',
  'assurance-protection':'bg-amber-50 text-amber-700 border-amber-200',
  'industrie':           'bg-slate-100 text-slate-700 border-slate-300',
  'hospitality':         'bg-purple-50 text-purple-700 border-purple-200',
  'conseil-rh':          'bg-rose-50 text-rose-700 border-rose-200',
  'direction-generale':  'bg-navy-950/5 text-navy-950 border-navy-950/20',
};

const impactBadge: Record<ImpactLevel, string> = {
  'institutionnel': 'bg-yellow-400/20 text-yellow-800',
  'direction':      'bg-energy-dark/10 text-energy-dark',
  'operationnel':   'bg-slate-100 text-slate-600',
  'prescripteur':   'bg-blue-100 text-blue-700',
};
---

<section id="temoignages" class="py-24 lg:py-32 bg-white">
  <div class="max-w-7xl mx-auto px-6 lg:px-8">

    <!-- Header -->
    <div class="max-w-3xl mb-8 reveal">
      <p class="section-label" data-i18n-fr={i18n.label.fr} data-i18n-en={i18n.label.en}>{i18n.label.fr}</p>
      <h2 class="section-title">
        <span data-i18n-fr={i18n.title1.fr} data-i18n-en={i18n.title1.en}>{i18n.title1.fr}</span><br/>
        <span class="energy-gradient-text" data-i18n-fr={i18n.title2.fr} data-i18n-en={i18n.title2.en}>{i18n.title2.fr}</span>.
      </h2>
      <p class="section-text" data-i18n-fr={i18n.intro.fr} data-i18n-en={i18n.intro.en}>{i18n.intro.fr}</p>
    </div>

    <!-- Stats bar -->
    <div class="flex flex-wrap gap-6 mb-12 reveal">
      <div class="flex items-center gap-2">
        <span class="text-3xl font-display font-bold text-navy-950">{testimonials.length}</span>
        <span class="text-sm text-slate-500 whitespace-pre-line" data-i18n-fr={i18n.statVerif.fr} data-i18n-en={i18n.statVerif.en}>{i18n.statVerif.fr}</span>
      </div>
      <div class="flex items-center gap-2">
        <span class="text-3xl font-display font-bold text-navy-950">{allSectors.length}</span>
        <span class="text-sm text-slate-500 whitespace-pre-line" data-i18n-fr={i18n.statSectors.fr} data-i18n-en={i18n.statSectors.en}>{i18n.statSectors.fr}</span>
      </div>
      <div class="flex items-center gap-2">
        <span class="text-3xl font-display font-bold text-energy-dark">100%</span>
        <span class="text-sm text-slate-500 whitespace-pre-line" data-i18n-fr={i18n.statUnsolit.fr} data-i18n-en={i18n.statUnsolit.en}>{i18n.statUnsolit.fr}</span>
      </div>
    </div>

    <!-- Tag cloud (clickable filters) -->
    <div class="mb-10 reveal" id="temoignages-tags">
      <div class="flex flex-wrap gap-2">
        <button class="tag-filter active px-4 py-2 rounded-full text-sm font-medium border transition-all duration-300 bg-navy-950 text-white border-navy-950" data-tag="all"
                data-i18n-fr={i18n.filterAll.fr} data-i18n-en={i18n.filterAll.en}>
          {i18n.filterAll.fr}
        </button>
        {topTags.map(([tag, freq]) => (
          <button
            class="tag-filter px-4 py-2 rounded-full text-sm border transition-all duration-300 bg-white text-slate-600 border-slate-200 hover:border-energy-dark hover:text-energy-dark"
            data-tag={tag}
          >
            {tag} <span class="text-xs text-slate-400 ml-1">{freq}</span>
          </button>
        ))}
      </div>
    </div>

    <!-- Sector tabs -->
    <div class="mb-8 reveal overflow-x-auto">
      <div class="flex gap-2 min-w-max">
        <button class="sector-tab active px-4 py-2 rounded-lg text-sm font-medium transition-all duration-300 bg-navy-950 text-white" data-sector="all"
                data-i18n-fr={i18n.sectorAll.fr} data-i18n-en={i18n.sectorAll.en}>
          {i18n.sectorAll.fr}
        </button>
        {bySector.map(({ sector, label, items }) => (
          <button
            class={`sector-tab px-4 py-2 rounded-lg text-sm font-medium transition-all duration-300 border ${sectorColors[sector]}`}
            data-sector={sector}
            data-i18n-fr={label.fr}
            data-i18n-en={label.en}
          >
            <span data-i18n-fr={label.fr} data-i18n-en={label.en}>{label.fr}</span>
            <span class="opacity-60"> ({items.length})</span>
          </button>
        ))}
      </div>
    </div>

    <!-- ═══ THE WALL ═══ -->
    <div id="temoignages-wall" class="columns-1 md:columns-2 lg:columns-3 gap-5 space-y-5">
      {testimonials.map((t, i) => (
        <div
          class={`temoignage-card break-inside-avoid bg-white rounded-xl p-6 border border-slate-200
                  hover:shadow-lg hover:shadow-navy-900/5 hover:border-energy-dark/20 
                  transition-all duration-500 reveal reveal-delay-${(i % 4) + 1}`}
          data-tags={JSON.stringify(t.tags)}
          data-sector={t.sector}
          data-impact={t.impact}
        >
          <!-- Header: photo + name -->
          <div class="flex items-start gap-3 mb-4">
            <a href={t.linkedinUrl || '#'} target="_blank" rel="noopener noreferrer"
               class="flex-shrink-0 w-12 h-12 rounded-full bg-gradient-to-br from-slate-100 to-slate-200 
                      border border-slate-200 flex items-center justify-center overflow-hidden
                      hover:border-energy-dark/40 transition-colors group"
               title={`Voir le profil LinkedIn de ${t.name}`}>
              {t.photoUrl ? (
                <img src={t.photoUrl} alt={t.name} class="w-full h-full object-cover rounded-full" />
              ) : (
                <span class="text-navy-900/40 text-xs font-bold group-hover:text-energy-dark transition-colors">
                  {t.name.split(' ').map(w => w[0]).filter(c => c && c === c.toUpperCase()).slice(0, 2).join('')}
                </span>
              )}
            </a>
            <div class="min-w-0">
              <a href={t.linkedinUrl || '#'} target="_blank" rel="noopener noreferrer"
                 class="font-display font-semibold text-navy-950 text-sm hover:text-energy-dark transition-colors block truncate">
                {t.name}
              </a>
              <p class="text-slate-500 text-xs leading-snug">{t.title}</p>
              {t.company && <p class="text-slate-400 text-xs">{t.company}</p>}
            </div>
          </div>

          <!-- Badges -->
          <div class="flex flex-wrap gap-1.5 mb-3">
            <span class={`inline-block text-[10px] font-semibold uppercase tracking-wider px-2 py-0.5 rounded-full ${sectorColors[t.sector]}`}
                  data-i18n-fr={sectorLabels[t.sector].fr} data-i18n-en={sectorLabels[t.sector].en}>
              {sectorLabels[t.sector].fr}
            </span>
            <span class={`inline-block text-[10px] font-medium px-2 py-0.5 rounded-full ${impactBadge[t.impact]}`}
                  data-i18n-fr={impactLabels[t.impact].fr} data-i18n-en={impactLabels[t.impact].en}>
              {impactLabels[t.impact].fr}
            </span>
          </div>

          <!-- Quote -->
          <blockquote class="text-slate-700 text-sm leading-relaxed italic">
            "{t.quote}"
          </blockquote>

          <!-- Footer: year + LinkedIn link -->
          <div class="flex items-center justify-between mt-4 pt-3 border-t border-slate-100">
            <span class="text-xs text-slate-400">{t.year}</span>
            <a href={t.postUrl} target="_blank" rel="noopener noreferrer"
               class="text-xs text-blue-600 hover:text-blue-800 flex items-center gap-1 transition-colors"
               title="Voir le post original sur LinkedIn"
               data-i18n-fr={i18n.seeLinkedIn.fr} data-i18n-en={i18n.seeLinkedIn.en}>
              <svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 24 24">
                <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
              </svg>
              {i18n.seeLinkedIn.fr}
            </a>
          </div>
        </div>
      ))}
    </div>

    <!-- Empty state -->
    <div id="temoignages-empty" class="hidden text-center py-16">
      <p class="text-slate-400 text-lg" data-i18n-fr={i18n.emptyState.fr} data-i18n-en={i18n.emptyState.en}>{i18n.emptyState.fr}</p>
      <button class="mt-4 text-energy-dark text-sm font-medium hover:underline" id="temoignages-reset"
              data-i18n-fr={i18n.resetFilter.fr} data-i18n-en={i18n.resetFilter.en}>
        {i18n.resetFilter.fr}
      </button>
    </div>

  </div>
</section>

<script>
document.addEventListener('DOMContentLoaded', () => {
  const wall = document.getElementById('temoignages-wall');
  const empty = document.getElementById('temoignages-empty');
  const cards = document.querySelectorAll<HTMLElement>('.temoignage-card');
  const tagBtns = document.querySelectorAll<HTMLButtonElement>('.tag-filter');
  const sectorBtns = document.querySelectorAll<HTMLButtonElement>('.sector-tab');
  const resetBtn = document.getElementById('temoignages-reset');

  let activeTag = 'all';
  let activeSector = 'all';

  function filterCards() {
    let visibleCount = 0;
    cards.forEach(card => {
      const tags: string[] = JSON.parse(card.dataset.tags || '[]');
      const sector = card.dataset.sector || '';

      const tagMatch = activeTag === 'all' || tags.includes(activeTag);
      const sectorMatch = activeSector === 'all' || sector === activeSector;

      if (tagMatch && sectorMatch) {
        card.style.display = '';
        visibleCount++;
      } else {
        card.style.display = 'none';
      }
    });

    if (wall) wall.style.display = visibleCount > 0 ? '' : 'none';
    if (empty) empty.style.display = visibleCount === 0 ? 'block' : 'none';
  }

  function setActiveTag(tag: string) {
    activeTag = tag;
    tagBtns.forEach(btn => {
      const isActive = btn.dataset.tag === tag;
      btn.classList.toggle('bg-navy-950', isActive);
      btn.classList.toggle('text-white', isActive);
      btn.classList.toggle('border-navy-950', isActive);
      btn.classList.toggle('bg-white', !isActive);
      btn.classList.toggle('text-slate-600', !isActive);
      btn.classList.toggle('border-slate-200', !isActive);
      if (isActive) btn.classList.add('active');
      else btn.classList.remove('active');
    });
    filterCards();
  }

  function setActiveSector(sector: string) {
    activeSector = sector;
    sectorBtns.forEach(btn => {
      const isActive = btn.dataset.sector === sector;
      if (isActive) {
        btn.classList.add('bg-navy-950', 'text-white', 'active');
        btn.classList.remove('border');
      } else {
        btn.classList.remove('bg-navy-950', 'text-white', 'active');
        btn.classList.add('border');
      }
    });
    filterCards();
  }

  tagBtns.forEach(btn => {
    btn.addEventListener('click', () => setActiveTag(btn.dataset.tag || 'all'));
  });

  sectorBtns.forEach(btn => {
    btn.addEventListener('click', () => setActiveSector(btn.dataset.sector || 'all'));
  });

  resetBtn?.addEventListener('click', () => {
    setActiveTag('all');
    setActiveSector('all');
  });
});
</script>
