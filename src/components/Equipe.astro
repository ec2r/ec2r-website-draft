---
/*
  PLACEHOLDER : photos à remplacer par les vrais portraits.
  Photos nécessaires : Stéphane, Luc, Jean-François, Arnaud.
  
  NOTE: Laurent Prost (Grant Thornton) retiré du site public.
  Raison : positionnement GT incompatible avec affichage public
  (concurrents dans la commission CROEC, rôle officiel = expert-comptable de la méthode).
  Il peut apparaître sur les versions démo internes uniquement.
*/

const founders = [
  {
    name: 'Stéphane Flahaut',
    role: 'Fondateur & Président',
    bio: 'Porteur de la méthode EC²R depuis plus de 4 ans. Construit des collectifs et s\'assure que les comportements facilitent la dynamique. Garant de l\'intégrité de la méthode.',
    initials: 'SF',
  },
  {
    name: 'Luc Letoffe',
    role: 'Co-design Méthode × Technologie',
    bio: 'Passe de l\'idéation à la situation. Remplace une équipe de codeurs par du co-design en direct : formalise le brief avec les experts métiers, avance, livre. L\'IA au service du passage à l\'acte, pas l\'inverse.',
    initials: 'LL',
  },
];

const team = [
  {
    name: 'Jean-François Morin',
    role: 'Co-fondateur',
    bio: 'Co-fondateur de la méthode EC²R, « entraîneur d\'entraîneurs ». Associé depuis les origines.',
    initials: 'JFM',
  },
  {
    name: 'Arnaud Bochurberg',
    role: 'Interlocuteur EC²R',
    bio: 'Accompagne les organisations dans le déploiement opérationnel de la méthode.',
    initials: 'AB',
  },
];
---

<section id="equipe" class="py-24 lg:py-32 bg-slate-50">
  <div class="max-w-7xl mx-auto px-6 lg:px-8">
    
    <div class="max-w-3xl mb-16 reveal">
      <p class="section-label">L'équipe</p>
      <h2 class="section-title">
        Des gens qui passent<br/>
        <span class="energy-gradient-text">à l'acte</span>.
      </h2>
      <p class="section-text">
        Pas de consultants interchangeables. Des profils complémentaires qui croient 
        en la différenciation et qui ont prouvé la puissance de la méthode sur le terrain.
      </p>
    </div>

    <!-- Founders (Stéphane + Luc) — large cards -->
    <div class="grid md:grid-cols-2 gap-8 mb-12">
      {founders.map((member, i) => (
        <div class={`reveal reveal-delay-${i + 1}`}>
          <div class="bg-white rounded-2xl overflow-hidden border border-slate-200 h-full 
                      hover:shadow-xl hover:shadow-navy-900/5 transition-all duration-500 group">
            <!-- Photo placeholder -->
            <div class="aspect-[16/10] bg-gradient-to-br from-navy-900 via-navy-950 to-navy-900 
                        relative flex items-center justify-center overflow-hidden">
              <!-- Geometric accent -->
              <div class="absolute inset-0 opacity-[0.03]">
                <div class="absolute top-1/4 left-1/4 w-40 h-40 rounded-full border border-white"></div>
                <div class="absolute bottom-1/4 right-1/4 w-32 h-32 rounded-full border border-white"></div>
              </div>
              <div class="text-center relative z-10">
                <div class="w-24 h-24 rounded-full bg-white/[0.08] border border-white/10 mx-auto mb-3 
                            flex items-center justify-center backdrop-blur-sm
                            group-hover:border-energy-green/30 transition-colors duration-500">
                  <span class="text-white/50 text-2xl font-display font-bold group-hover:text-energy-green/70 transition-colors">
                    {member.initials}
                  </span>
                </div>
                <p class="text-white/25 text-xs tracking-wider uppercase">Portrait à ajouter</p>
              </div>
            </div>
            <div class="p-8">
              <h3 class="font-display font-bold text-xl text-navy-950 mb-1">{member.name}</h3>
              <p class="text-energy-dark font-semibold text-sm mb-4">{member.role}</p>
              <p class="text-slate-600 leading-relaxed">{member.bio}</p>
            </div>
          </div>
        </div>
      ))}
    </div>

    <!-- Other members -->
    <div class="grid sm:grid-cols-2 gap-6 mb-16">
      {team.map((member, i) => (
        <div class={`reveal reveal-delay-${i + 1}`}>
          <div class="bg-white rounded-xl p-6 border border-slate-200 h-full 
                      hover:border-energy-dark/20 hover:shadow-md transition-all duration-300 group">
            <div class="w-14 h-14 rounded-xl bg-navy-950/[0.04] border border-slate-200 mb-4 
                        flex items-center justify-center
                        group-hover:bg-navy-950 group-hover:border-navy-950 transition-all duration-300">
              <span class="text-navy-900/30 text-sm font-display font-bold 
                          group-hover:text-energy-green transition-colors duration-300">
                {member.initials}
              </span>
            </div>
            <h3 class="font-display font-semibold text-navy-950 mb-1">{member.name}</h3>
            <p class="text-energy-dark text-sm font-medium mb-3">{member.role}</p>
            <p class="text-slate-500 text-sm leading-relaxed">{member.bio}</p>
          </div>
        </div>
      ))}
    </div>

    <!-- Seminar photos teaser -->
    <div class="reveal">
      <div class="bg-white rounded-2xl border border-slate-200 p-8 md:p-12 text-center">
        <p class="text-sm text-slate-400 uppercase tracking-wider font-medium mb-4">Sur le terrain</p>
        <div class="grid grid-cols-2 md:grid-cols-4 gap-3 mb-6">
          {[
            'Séminaire Label Antilles',
            'CROEC Martinique',
            'Formation Laforêt',
            'Atelier collectif',
          ].map((label) => (
            <div class="aspect-[4/3] bg-gradient-to-br from-slate-50 to-slate-100 rounded-lg 
                        flex items-center justify-center border border-slate-200 
                        hover:border-energy-dark/20 transition-colors duration-300">
              <p class="text-slate-400 text-xs text-center px-4 leading-relaxed">{label}</p>
            </div>
          ))}
        </div>
        <p class="text-slate-400 text-sm italic">
          Photos des séminaires et ateliers à intégrer.
        </p>
      </div>
    </div>

  </div>
</section>
