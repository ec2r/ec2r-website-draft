---
interface Props {
  fr: any;
  en: any;
}
const { fr, en } = Astro.props;

const numLabel: Record<string, string> = {
  '①': '1', '②': '2', '③': '3', '④': '4', '⑤': '5', '⑥': '6', '↗': '↗'
};

const nums = ['①','②','③','④','⑤','⑥','↗'];
---

<section id="accueil" class="relative min-h-screen flex items-center overflow-hidden bg-navy-950">
  <div class="absolute inset-0 bg-gradient-to-br from-navy-950 via-navy-900 to-navy-950"></div>
  <div class="absolute inset-0 grid-overlay"></div>
  <div class="absolute top-1/4 right-0 w-[600px] h-[600px] rounded-full border border-white/[0.03] translate-x-1/3"></div>
  <div class="absolute bottom-1/3 left-0 w-[500px] h-[500px] rounded-full border border-energy-dark/[0.06] -translate-x-1/3"></div>
  <div class="absolute top-0 left-0 right-0 energy-gradient-bar h-2"></div>

  <div class="relative z-10 max-w-7xl mx-auto px-6 lg:px-8 w-full py-20 lg:py-12">
    <div class="grid lg:grid-cols-2 gap-12 lg:gap-16 items-start">

      <!-- Gauche : texte -->
      <div class="order-1">
        <p class="text-energy-green text-sm font-semibold tracking-[0.2em] uppercase mb-6 animate-fade-in"
           style="animation-delay: 0.2s"
           data-i18n-fr={fr.hero.label} data-i18n-en={en.hero.label}>{fr.hero.label}</p>

        <h1 class="text-4xl md:text-5xl lg:text-[3.5rem] font-display font-extrabold text-white leading-[1.1] mb-4 opacity-0 animate-fade-up" style="animation-delay: 0.4s">
          <span data-i18n-fr={fr.hero.title1} data-i18n-en={en.hero.title1}>{fr.hero.title1}</span><br/>
          <span class="energy-gradient-text" data-i18n-fr={fr.hero.title2} data-i18n-en={en.hero.title2}>{fr.hero.title2}</span>
        </h1>

        <div class="mb-8 opacity-0 animate-fade-up font-mono" style="animation-delay: 0.6s">
          <div class="space-y-1 text-lg md:text-xl" id="ec2r-lines">
            <div class="ec2r-line flex items-center gap-3 opacity-0" style="transition: opacity 0.3s ease">
              <span class="text-energy-green font-bold text-2xl w-8">E</span>
              <span class="text-white/20">·····</span>
              <span class="text-white/70" data-i18n-fr="Énergie" data-i18n-en="Energy">Énergie</span>
            </div>
            <div class="ec2r-line flex items-center gap-3 opacity-0" style="transition: opacity 0.3s ease">
              <span class="text-energy-green font-bold text-2xl w-8">C</span>
              <span class="text-white/20">·····</span>
              <span class="text-white/70" data-i18n-fr="Collective" data-i18n-en="Collective">Collective</span>
            </div>
            <div class="ec2r-line flex items-center gap-3 opacity-0" style="transition: opacity 0.3s ease">
              <span class="text-energy-green font-bold text-2xl w-8">²C</span>
              <span class="text-white/20">·····</span>
              <span id="c2-cycling" class="text-white font-semibold"></span><span id="c2-caret" class="text-energy-green/60 animate-pulse">_</span>
            </div>
            <div class="ec2r-line flex items-center gap-3 opacity-0" style="transition: opacity 0.3s ease">
              <span class="text-energy-green font-bold text-2xl w-8">R</span>
              <span class="text-white/20">·····</span>
              <span id="r-cycling" class="text-white font-semibold"></span><span id="r-caret" class="text-energy-green/60 animate-pulse">_</span>
            </div>
          </div>
        </div>

        <!-- sub1 : Netflix barré + Waze -->
        <p class="text-lg md:text-xl text-white/60 leading-relaxed max-w-lg mb-4 opacity-0 animate-fade-up" style="animation-delay: 0.8s">
          <span class="line-through decoration-white/20">
            <span id="netflix-prefix" data-i18n-fr={(fr.hero as any).sub1Prefix || 'Pas le Netflix de '} data-i18n-en={(en.hero as any).sub1Prefix || 'Not the Netflix of '}>{(fr.hero as any).sub1Prefix || 'Pas le Netflix de '}</span><strong id="netflix-cycling" class="text-white/40" style="transition: opacity 0.2s ease">{(fr.hero as any).sub1Cycling ? (fr.hero as any).sub1Cycling[0] : 'la formation'}</strong>.
          </span><br/>
          <span>
            <span id="waze-prefix" data-i18n-fr={(fr.hero as any).sub1bPrefix || 'Le Waze du '} data-i18n-en={(en.hero as any).sub1bPrefix || 'The Waze of '}>{(fr.hero as any).sub1bPrefix || 'Le Waze du '}</span><strong id="waze-cycling" class="text-white" style="transition: opacity 0.2s ease">{(fr.hero as any).sub1bCycling ? (fr.hero as any).sub1bCycling[0] : 'comportement professionnel'}</strong>.
          </span>
        </p>
        <p id="hero-sub2" class="text-base text-white/40 leading-relaxed max-w-lg mb-10 opacity-0 animate-fade-up"
           style="animation-delay: 0.95s"
           data-i18n-fr={fr.hero.sub2} data-i18n-en={en.hero.sub2}>{fr.hero.sub2}</p>

        <div class="flex flex-wrap gap-4 opacity-0 animate-fade-up" style="animation-delay: 1.1s">
          <a href="#methode" class="btn-primary w-full sm:w-auto justify-center">
            <span data-i18n-fr={fr.hero.cta1} data-i18n-en={en.hero.cta1}>{fr.hero.cta1}</span>
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3" />
            </svg>
          </a>
          <a href="#contact" class="btn-secondary border-white/20 text-white/70 hover:bg-white/10 hover:text-white hover:border-white/40 w-full sm:w-auto justify-center"
             data-i18n-fr={fr.hero.cta2} data-i18n-en={en.hero.cta2}>{fr.hero.cta2}</a>
        </div>
      </div>

      <!-- Droite : situations accordion -->
      <div class="order-2 opacity-0 animate-fade-in" style="animation-delay: 0.5s">
        <p class="text-xs uppercase tracking-[0.2em] font-semibold text-white/30 mb-1"
           data-i18n-fr={fr.hero.situationsLabel} data-i18n-en={en.hero.situationsLabel}>{fr.hero.situationsLabel}</p>
        <p class="text-xs text-white/20 italic mb-4"
           data-i18n-fr={fr.hero.situationsHint} data-i18n-en={en.hero.situationsHint}>{fr.hero.situationsHint}</p>

        <div class="space-y-1.5" id="hero-situations">
          {fr.situations.map((s: any, i: number) => (
            <div class="sit-item rounded-lg overflow-hidden border border-white/[0.07] transition-colors duration-200 hover:border-white/15" data-sit-idx={i}>

              <button class="sit-trigger w-full text-left px-4 py-3 flex items-start gap-3 group" aria-expanded="false">
                <span class="shrink-0 mt-0.5">
                  {nums[i] === '↗' ? (
                    <svg width="28" height="34" viewBox="0 0 28 34" fill="none" class="text-white/30 group-hover:text-white/60 transition-colors duration-200">
                      <rect x="1" y="5" width="26" height="28" rx="3" stroke="currentColor" stroke-width="1.6" fill="none"/>
                      <rect x="9" y="1" width="10" height="5" rx="1.5" stroke="currentColor" stroke-width="1.4" fill="none"/>
                      <text x="14" y="23" text-anchor="middle" font-size="13" font-weight="700" fill="currentColor" font-family="system-ui">↗</text>
                    </svg>
                  ) : (
                    <svg width="28" height="34" viewBox="0 0 28 34" fill="none" class="text-white/30 group-hover:text-white/60 transition-colors duration-200">
                      <rect x="1" y="5" width="26" height="28" rx="3" stroke="currentColor" stroke-width="1.6" fill="none"/>
                      <rect x="9" y="1" width="10" height="5" rx="1.5" stroke="currentColor" stroke-width="1.4" fill="none"/>
                      <text x="14" y="23" text-anchor="middle" font-size="10" font-weight="700" fill="currentColor" font-family="system-ui">E{i + 1}</text>
                    </svg>
                  )}
                </span>
                <span class="text-white/70 text-sm leading-snug flex-1 group-hover:text-white/90 transition-colors duration-200 sit-accroche"
                      data-fr={s.accroche} data-en={en.situations[i].accroche}>{s.accroche}</span>
                <span class="sit-arrow shrink-0 mt-1 text-white/20 transition-all duration-200 group-hover:text-energy-green">
                  <svg width="14" height="14" viewBox="0 0 14 14" fill="none">
                    <path d="M3.5 5.25L7 8.75L10.5 5.25" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/>
                  </svg>
                </span>
              </button>

              <div class="sit-panel hidden">
                <div class="flex border-t border-white/10 text-xs">
                  <button class="sit-tab active-tab flex-1 py-2 px-3 text-center font-semibold tracking-wide transition-colors duration-150" data-tab="0"
                          data-i18n-fr={fr.hero.tabCeQuiSePasse} data-i18n-en={en.hero.tabCeQuiSePasse}>{fr.hero.tabCeQuiSePasse}</button>
                  <button class="sit-tab flex-1 py-2 px-3 text-center font-semibold tracking-wide transition-colors duration-150" data-tab="1"
                          data-i18n-fr={fr.hero.tabEssaye} data-i18n-en={en.hero.tabEssaye}>{fr.hero.tabEssaye}</button>
                  <button class="sit-tab flex-1 py-2 px-3 text-center font-semibold tracking-wide transition-colors duration-150" data-tab="2"
                          data-i18n-fr={fr.hero.tabPromesse} data-i18n-en={en.hero.tabPromesse}>{fr.hero.tabPromesse}</button>
                </div>

                <div class="sit-content border-t border-white/[0.06]" style="position:relative;">
                  <div class="sit-pane px-4 py-3" data-pane="0" style="position:absolute;top:0;left:0;right:0;opacity:1;pointer-events:auto;transition:opacity 0.15s ease;">
                    <p class="text-slate-300 text-sm leading-relaxed sit-passe"
                       data-fr={s.ceQuiSePasse} data-en={en.situations[i].ceQuiSePasse}>{s.ceQuiSePasse}</p>
                  </div>
                  <div class="sit-pane px-4 py-3" data-pane="1" style="position:absolute;top:0;left:0;right:0;opacity:0;pointer-events:none;transition:opacity 0.15s ease;">
                    <ul class="space-y-1 mb-2 sit-essaye-list"
                        data-fr={JSON.stringify(s.essaye)} data-en={JSON.stringify(en.situations[i].essaye)}>
                      {s.essaye.map((e: string) => (
                        <li class="text-slate-400 text-sm flex items-start gap-2">
                          <span class="text-slate-600 mt-0.5 shrink-0">–</span>
                          <span>{e}</span>
                        </li>
                      ))}
                    </ul>
                    <p class="text-slate-500 text-xs italic mt-2 sit-conclusion"
                       data-fr={s.essayeConclusion} data-en={en.situations[i].essayeConclusion}>{s.essayeConclusion}</p>
                  </div>
                  <div class="sit-pane px-4 py-3" data-pane="2" style="position:absolute;top:0;left:0;right:0;opacity:0;pointer-events:none;transition:opacity 0.15s ease;">
                    <p class="text-white/80 text-sm leading-relaxed sit-reponse"
                       data-fr={s.reponse} data-en={en.situations[i].reponse}>{s.reponse}</p>
                  </div>
                </div>

                <div class="flex items-center justify-between px-4 pb-3 pt-1">
                  <div class="flex gap-1.5">
                    <span class="swipe-dot w-1.5 h-1.5 rounded-full bg-energy-green" data-dot="0"></span>
                    <span class="swipe-dot w-1.5 h-1.5 rounded-full bg-white/20" data-dot="1"></span>
                    <span class="swipe-dot w-1.5 h-1.5 rounded-full bg-white/20" data-dot="2"></span>
                  </div>
                  <button class="sit-validate text-xs text-white/30 hover:text-energy-green border border-white/10 hover:border-energy-green/40 rounded-full px-3 py-1 transition-all duration-200">
                    Je le vis
                  </button>
                </div>
              </div>

            </div>
          ))}
        </div>
      </div>

    </div>
  </div>

  <!-- Data store pour les cycling arrays (évite de dupliquer dans le JS) -->
  <div id="hero-cycling-data" hidden
    data-netflix-fr={JSON.stringify((fr.hero as any).sub1Cycling || [])}
    data-netflix-en={JSON.stringify((en.hero as any).sub1Cycling || [])}
    data-waze-fr={JSON.stringify((fr.hero as any).sub1bCycling || [])}
    data-waze-en={JSON.stringify((en.hero as any).sub1bCycling || [])}
  ></div>

  <!-- Bandeau "Je le vis" CTA -->
  <div id="sit-cta-banner" class="hidden fixed bottom-0 left-0 right-0 z-40 bg-navy-950/95 backdrop-blur border-t border-energy-green/20 py-3 px-6 text-center">
    <span class="text-white/70 text-sm">Vous vous reconnaissez dans <strong id="sit-count" class="text-energy-green">0</strong> situation(s) —</span>
    <a href="#contact" class="text-energy-green font-semibold text-sm ml-2 hover:underline">on s'en parle ?</a>
    <button id="sit-banner-close" class="ml-4 text-white/30 hover:text-white/60 text-xs">✕</button>
  </div>

  <div class="absolute bottom-8 left-1/2 -translate-x-1/2 text-white/30 animate-bounce">
    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3" />
    </svg>
  </div>
</section>

<style>
  .sit-tab { color: rgba(255,255,255,0.3); }
  .sit-tab:hover { color: rgba(255,255,255,0.6); background: rgba(255,255,255,0.04); }
  .sit-tab.active-tab { color: #4ade80; background: rgba(74,222,128,0.06); }
</style>

<script>
  // ── EC²R decomposition : apparition séquentielle + typewriter ──
  const c2El = document.getElementById('c2-cycling') as HTMLElement;
  const rEl  = document.getElementById('r-cycling')  as HTMLElement;
  const c2Caret = document.getElementById('c2-caret') as HTMLElement;
  const rCaret  = document.getElementById('r-caret')  as HTMLElement;

  const c2Fr = ['Croissance', 'Changement', 'Comportement'];
  const c2En = ['Growth', 'Change', 'Behaviour'];
  const rFr  = ['Responsable', 'Réaliste', 'Rapide', 'Rassurant'];
  const rEn  = ['Responsible', 'Realistic', 'Rapid', 'Reassuring'];
  let c2Idx = 0, rIdx = 0;
  let ec2rReady = false;

  // Typewriter : tape lettre par lettre, attend, efface, recommence
  function typewriterCycle(
    el: HTMLElement,
    arrFr: string[], arrEn: string[],
    idxRef: { v: number },
    onDone?: () => void
  ) {
    const lang = document.documentElement.getAttribute('data-lang') || 'fr';
    const word = lang === 'en' ? arrEn[idxRef.v] : arrFr[idxRef.v];
    idxRef.v = (idxRef.v + 1) % arrFr.length;

    let i = 0;
    el.textContent = '';

    // Tape
    const typeInterval = setInterval(() => {
      el.textContent = word.slice(0, i + 1);
      i++;
      if (i >= word.length) {
        clearInterval(typeInterval);
        // Pause affichage
        setTimeout(() => {
          // Efface
          let j = word.length;
          const eraseInterval = setInterval(() => {
            j--;
            el.textContent = word.slice(0, j);
            if (j <= 0) {
              clearInterval(eraseInterval);
              onDone?.();
            }
          }, 40);
        }, 1800);
      }
    }, 55);
  }

  function startC2Cycle() {
    const ref = { v: c2Idx };
    typewriterCycle(c2El, c2Fr, c2En, ref, () => {
      c2Idx = ref.v;
      setTimeout(startC2Cycle, 200);
    });
  }

  function startRCycle() {
    const ref = { v: rIdx };
    typewriterCycle(rEl, rFr, rEn, ref, () => {
      rIdx = ref.v;
      setTimeout(startRCycle, 200);
    });
  }

  // Apparition séquentielle des 4 lignes (après fade-in du bloc)
  const ec2rLines = document.querySelectorAll<HTMLElement>('.ec2r-line');
  const EC2R_LINE_DELAY = 320; // ms entre chaque ligne

  function revealEC2RLines() {
    ec2rLines.forEach((line, i) => {
      setTimeout(() => {
        line.style.opacity = '1';
        // Sur la 3e ligne (²C), démarrer le typewriter
        if (i === 2) setTimeout(startC2Cycle, 200);
        // Sur la 4e ligne (R), démarrer le typewriter avec décalage
        if (i === 3) setTimeout(startRCycle, 600);
      }, i * EC2R_LINE_DELAY);
    });
    ec2rReady = true;
  }

  // Déclencher après le fade-in initial (animation-delay 0.6s + durée ~0.5s)
  setTimeout(revealEC2RLines, 1200);

  // Update EC²R on lang change : re-type le mot courant immédiatement
  new MutationObserver(() => {
    if (!ec2rReady) return;
    const lang = document.documentElement.getAttribute('data-lang') || 'fr';
    // On laisse le cycle gérer la langue au prochain mot — les éléments fixes
    const fixedE  = ec2rLines[0]?.querySelector('[data-i18n-fr]') as HTMLElement;
    const fixedC  = ec2rLines[1]?.querySelector('[data-i18n-fr]') as HTMLElement;
    if (fixedE) fixedE.textContent = lang === 'en' ? 'Energy' : 'Énergie';
    if (fixedC) fixedC.textContent = lang === 'en' ? 'Collective' : 'Collective';
  }).observe(document.documentElement, { attributes: true, attributeFilter: ['data-lang'] });

  // ── Netflix / Waze cycling ──
  const netflixEl  = document.getElementById('netflix-cycling') as HTMLElement;
  const wazeEl     = document.getElementById('waze-cycling') as HTMLElement;
  const cyclingData = document.getElementById('hero-cycling-data') as HTMLElement;

  const netflixFr: string[] = JSON.parse(cyclingData?.dataset.netflixFr || '[]');
  const netflixEn: string[] = JSON.parse(cyclingData?.dataset.netflixEn || '[]');
  const wazeFr: string[]    = JSON.parse(cyclingData?.dataset.wazeFr    || '[]');
  const wazeEn: string[]    = JSON.parse(cyclingData?.dataset.wazeEn    || '[]');

  let nIdx = 0;
  let wIdx = 0;

  function cycleWord(el: HTMLElement | null, arrFr: string[], arrEn: string[], idx: number): number {
    if (!el) return idx;
    const lang = document.documentElement.getAttribute('data-lang') || 'fr';
    el.style.opacity = '0';
    setTimeout(() => {
      el.textContent = lang === 'en' ? arrEn[idx] : arrFr[idx];
      el.style.opacity = '1';
    }, 200);
    return (idx + 1) % arrFr.length;
  }

  setInterval(() => { nIdx = cycleWord(netflixEl, netflixFr, netflixEn, nIdx); }, 2500);
  setInterval(() => { wIdx = cycleWord(wazeEl, wazeFr, wazeEn, wIdx); }, 3200);

  // Update on lang change
  const heroLangObserver = new MutationObserver(() => {
    const lang = document.documentElement.getAttribute('data-lang') || 'fr';
    const ni = nIdx > 0 ? nIdx - 1 : netflixFr.length - 1;
    const wi = wIdx > 0 ? wIdx - 1 : wazeFr.length - 1;
    if (netflixEl) netflixEl.textContent = lang === 'en' ? netflixEn[ni] : netflixFr[ni];
    if (wazeEl)    wazeEl.textContent    = lang === 'en' ? wazeEn[wi]    : wazeFr[wi];
  });
  heroLangObserver.observe(document.documentElement, { attributes: true, attributeFilter: ['data-lang'] });

  // ── Accordion + tabs + swipe ──
  document.addEventListener('DOMContentLoaded', () => {
    const items = document.querySelectorAll('#hero-situations .sit-item');

    items.forEach(item => {
      const trigger = item.querySelector('.sit-trigger')!;
      const panel   = item.querySelector('.sit-panel')!;
      const arrow   = item.querySelector('.sit-arrow')!;
      const tabs    = item.querySelectorAll('.sit-tab');
      const panes   = item.querySelectorAll('.sit-pane');
      const dots    = item.querySelectorAll('.swipe-dot');

      function lockContentHeight() {
        const content = item.querySelector('.sit-content') as HTMLElement;
        content.style.height = '';
        let maxH = 0;
        panes.forEach((p: any) => {
          const prev = { opacity: p.style.opacity, pointer: p.style.pointerEvents, position: p.style.position };
          p.style.opacity = '0'; p.style.pointerEvents = 'none'; p.style.position = 'relative';
          maxH = Math.max(maxH, p.offsetHeight);
          p.style.opacity = prev.opacity; p.style.pointerEvents = prev.pointer; p.style.position = prev.position;
        });
        content.style.height = maxH + 'px';
      }

      trigger.addEventListener('click', () => {
        const isOpen = !panel.classList.contains('hidden');
        items.forEach(it => {
          it.querySelector('.sit-panel')!.classList.add('hidden');
          (it.querySelector('.sit-arrow') as HTMLElement).style.transform = '';
          it.querySelector('.sit-trigger')!.setAttribute('aria-expanded', 'false');
          (it.querySelector('.sit-content') as HTMLElement).style.height = '';
        });
        if (!isOpen) {
          panel.classList.remove('hidden');
          (arrow as HTMLElement).style.transform = 'rotate(180deg)';
          trigger.setAttribute('aria-expanded', 'true');
          lockContentHeight();
          switchPane(0);
        }
      });

      tabs.forEach(tab => {
        tab.addEventListener('click', () => switchPane(parseInt((tab as HTMLElement).dataset.tab || '0')));
        tab.addEventListener('mouseenter', () => switchPane(parseInt((tab as HTMLElement).dataset.tab || '0')));
      });

      let touchStartX = 0;
      let curPane = 0;
      const content = item.querySelector('.sit-content')!;
      content.addEventListener('touchstart', (e: any) => { touchStartX = e.changedTouches[0].clientX; }, { passive: true });
      content.addEventListener('touchend', (e: any) => {
        const dx = e.changedTouches[0].clientX - touchStartX;
        if (Math.abs(dx) < 40) return;
        switchPane(dx < 0 ? Math.min(curPane + 1, 2) : Math.max(curPane - 1, 0));
      }, { passive: true });

      function switchPane(idx: number) {
        curPane = idx;
        tabs.forEach((t, i) => t.classList.toggle('active-tab', i === idx));
        panes.forEach((p: any, i) => {
          p.style.opacity = i === idx ? '1' : '0';
          p.style.pointerEvents = i === idx ? 'auto' : 'none';
        });
        dots.forEach((d, i) => {
          d.classList.toggle('bg-energy-green', i === idx);
          d.classList.toggle('bg-white/20', i !== idx);
        });
      }
    });

    // ── i18n : éléments Hero spéciaux (situations) ──
    function updateSituationsLang(lang: string) {
      document.querySelectorAll('.sit-accroche').forEach((el: any) => {
        el.textContent = el.dataset[lang] || el.dataset.fr;
      });
      document.querySelectorAll('.sit-passe').forEach((el: any) => {
        el.textContent = el.dataset[lang] || el.dataset.fr;
      });
      document.querySelectorAll('.sit-conclusion').forEach((el: any) => {
        el.textContent = el.dataset[lang] || el.dataset.fr;
      });
      document.querySelectorAll('.sit-reponse').forEach((el: any) => {
        el.textContent = el.dataset[lang] || el.dataset.fr;
      });
      document.querySelectorAll('.sit-essaye-list').forEach((el: any) => {
        const items = JSON.parse(el.dataset[lang] || el.dataset.fr);
        el.innerHTML = items.map((e: string) =>
          `<li class="text-slate-400 text-sm flex items-start gap-2"><span class="text-slate-600 mt-0.5 shrink-0">–</span><span>${e}</span></li>`
        ).join('');
      });
    }

    // Écoute les changements de langue
    const observer = new MutationObserver(() => {
      const lang = document.documentElement.getAttribute('data-lang') || 'fr';
      updateSituationsLang(lang);
    });
    observer.observe(document.documentElement, { attributes: true, attributeFilter: ['data-lang'] });

    // Init
    const initLang = document.documentElement.getAttribute('data-lang') || 'fr';
    updateSituationsLang(initLang);

    // ── "Je le vis" interactif ──
    const validated = new Set<string>();
    const banner  = document.getElementById('sit-cta-banner') as HTMLElement;
    const countEl = document.getElementById('sit-count') as HTMLElement;
    const closeBtn= document.getElementById('sit-banner-close') as HTMLElement;

    closeBtn?.addEventListener('click', () => banner.classList.add('hidden'));

    document.querySelectorAll<HTMLElement>('.sit-validate').forEach(btn => {
      btn.addEventListener('click', () => {
        const sitItem = btn.closest<HTMLElement>('.sit-item');
        if (!sitItem) return;
        const idx = sitItem.dataset.sitIdx || '';

        if (validated.has(idx)) {
          validated.delete(idx);
          sitItem.style.borderColor = '';
          btn.textContent = 'Je le vis';
          btn.classList.remove('text-energy-green', 'border-energy-green/40');
          btn.classList.add('text-white/30', 'border-white/10');
        } else {
          validated.add(idx);
          sitItem.style.borderColor = 'rgba(74,222,128,0.35)';
          btn.textContent = '✓ Je le vis';
          btn.classList.add('text-energy-green', 'border-energy-green/40');
          btn.classList.remove('text-white/30', 'border-white/10');
        }

        countEl.textContent = String(validated.size);
        banner.classList.toggle('hidden', validated.size < 2);
        sessionStorage.setItem('ec2r-situations', JSON.stringify([...validated]));
      });
    });
  });


</script>
