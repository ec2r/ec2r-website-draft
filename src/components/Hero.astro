---
interface Props {
  fr: any;
  en: any;
}
const { fr, en } = Astro.props;

const numLabel: Record<string, string> = {
  '①': '1', '②': '2', '③': '3', '④': '4', '⑤': '5', '⑥': '6', '↗': '↗'
};

const nums = ['①','②','③','④','⑤','⑥','↗'];
---

<section id="accueil" class="relative min-h-screen flex items-center overflow-hidden bg-navy-950">
  <div class="absolute inset-0 bg-gradient-to-br from-navy-950 via-navy-900 to-navy-950"></div>
  <div class="absolute inset-0 grid-overlay"></div>
  <div class="absolute top-1/4 right-0 w-[600px] h-[600px] rounded-full border border-white/[0.03] translate-x-1/3"></div>
  <div class="absolute bottom-1/3 left-0 w-[500px] h-[500px] rounded-full border border-energy-dark/[0.06] -translate-x-1/3"></div>
  <div class="absolute top-0 left-0 right-0 energy-gradient-bar h-2"></div>

  <div class="relative z-10 max-w-7xl mx-auto px-6 lg:px-8 w-full py-20 lg:py-12">
    <div class="grid lg:grid-cols-2 gap-12 lg:gap-16 items-start">

      <!-- Gauche : texte -->
      <div class="order-1">
        <p class="text-energy-green text-sm font-semibold tracking-[0.2em] uppercase mb-6 animate-fade-in"
           style="animation-delay: 0.2s"
           data-i18n-fr={fr.hero.label} data-i18n-en={en.hero.label}>{fr.hero.label}</p>

        <h1 class="text-4xl md:text-5xl lg:text-[3.5rem] font-display font-extrabold text-white leading-[1.1] mb-4 opacity-0 animate-fade-up" style="animation-delay: 0.4s">
          <span data-i18n-fr={fr.hero.title1} data-i18n-en={en.hero.title1}>{fr.hero.title1}</span><br/>
          <span class="energy-gradient-text" data-i18n-fr={fr.hero.title2} data-i18n-en={en.hero.title2}>{fr.hero.title2}</span>
        </h1>

        <div class="text-2xl md:text-3xl font-display font-bold text-white/80 mb-8 h-[2.5em] md:h-[2em] opacity-0 animate-fade-up" style="animation-delay: 0.6s">
          <span class="text-white/50" data-i18n-fr={fr.hero.taglinePrefix} data-i18n-en={en.hero.taglinePrefix}>{fr.hero.taglinePrefix}</span>
          <span id="rotating-tagline" class="rotating-words">
            {fr.hero.taglines.map((t: string, i: number) => (
              <span class={`word${i === 0 ? ' active' : ''}`} data-tagline-fr={t} data-tagline-en={en.hero.taglines[i]}>{t}</span>
            ))}
          </span>
        </div>

        <!-- sub1 : structure fixe, seuls les textes changent via data attrs -->
        <p class="text-lg md:text-xl text-white/60 leading-relaxed max-w-lg mb-4 opacity-0 animate-fade-up" style="animation-delay: 0.8s">
          <span id="hero-sub1" data-i18n-fr={fr.hero.sub1} data-i18n-en={en.hero.sub1}>{fr.hero.sub1}</span><br/>
          <span>Le <strong id="hero-sub1b" class="text-white" data-i18n-fr={fr.hero.sub1b} data-i18n-en={en.hero.sub1b}>{fr.hero.sub1b}</strong>.</span>
        </p>
        <p id="hero-sub2" class="text-base text-white/40 leading-relaxed max-w-lg mb-10 opacity-0 animate-fade-up"
           style="animation-delay: 0.95s"
           data-i18n-fr={fr.hero.sub2} data-i18n-en={en.hero.sub2}>{fr.hero.sub2}</p>

        <div class="flex flex-wrap gap-4 opacity-0 animate-fade-up" style="animation-delay: 1.1s">
          <a href="#methode" class="btn-primary w-full sm:w-auto justify-center">
            <span data-i18n-fr={fr.hero.cta1} data-i18n-en={en.hero.cta1}>{fr.hero.cta1}</span>
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3" />
            </svg>
          </a>
          <a href="#contact" class="btn-secondary border-white/20 text-white/70 hover:bg-white/10 hover:text-white hover:border-white/40 w-full sm:w-auto justify-center"
             data-i18n-fr={fr.hero.cta2} data-i18n-en={en.hero.cta2}>{fr.hero.cta2}</a>
        </div>
      </div>

      <!-- Droite : situations accordion -->
      <div class="order-2 opacity-0 animate-fade-in" style="animation-delay: 0.5s">
        <p class="text-xs uppercase tracking-[0.2em] font-semibold text-white/30 mb-4"
           data-i18n-fr={fr.hero.situationsLabel} data-i18n-en={en.hero.situationsLabel}>{fr.hero.situationsLabel}</p>

        <div class="space-y-1.5" id="hero-situations">
          {fr.situations.map((s: any, i: number) => (
            <div class="sit-item rounded-lg overflow-hidden border border-white/[0.07] transition-colors duration-200 hover:border-white/15" data-sit-idx={i}>

              <button class="sit-trigger w-full text-left px-4 py-3 flex items-start gap-3 group" aria-expanded="false">
                <span class="shrink-0 mt-0.5">
                  {nums[i] === '↗' ? (
                    <svg width="28" height="34" viewBox="0 0 28 34" fill="none" class="text-energy-green/60 group-hover:text-energy-green transition-colors duration-200">
                      <rect x="1" y="5" width="26" height="28" rx="3" stroke="currentColor" stroke-width="1.6" fill="none"/>
                      <rect x="9" y="1" width="10" height="5" rx="1.5" stroke="currentColor" stroke-width="1.4" fill="none"/>
                      <text x="14" y="23" text-anchor="middle" font-size="13" font-weight="700" fill="currentColor" font-family="system-ui">↗</text>
                    </svg>
                  ) : (
                    <svg width="28" height="34" viewBox="0 0 28 34" fill="none" class="text-energy-green/60 group-hover:text-energy-green transition-colors duration-200">
                      <rect x="1" y="5" width="26" height="28" rx="3" stroke="currentColor" stroke-width="1.6" fill="none"/>
                      <rect x="9" y="1" width="10" height="5" rx="1.5" stroke="currentColor" stroke-width="1.4" fill="none"/>
                      <text x="14" y="23" text-anchor="middle" font-size="13" font-weight="700" fill="currentColor" font-family="system-ui">{i + 1}</text>
                    </svg>
                  )}
                </span>
                <span class="text-white/70 text-sm leading-snug flex-1 group-hover:text-white/90 transition-colors duration-200 sit-accroche"
                      data-fr={s.accroche} data-en={en.situations[i].accroche}>{s.accroche}</span>
                <span class="sit-arrow shrink-0 mt-1 text-white/20 transition-all duration-200 group-hover:text-energy-green">
                  <svg width="14" height="14" viewBox="0 0 14 14" fill="none">
                    <path d="M3.5 5.25L7 8.75L10.5 5.25" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/>
                  </svg>
                </span>
              </button>

              <div class="sit-panel hidden">
                <div class="flex border-t border-white/10 text-xs">
                  <button class="sit-tab active-tab flex-1 py-2 px-3 text-center font-semibold tracking-wide transition-colors duration-150" data-tab="0"
                          data-i18n-fr={fr.hero.tabCeQuiSePasse} data-i18n-en={en.hero.tabCeQuiSePasse}>{fr.hero.tabCeQuiSePasse}</button>
                  <button class="sit-tab flex-1 py-2 px-3 text-center font-semibold tracking-wide transition-colors duration-150" data-tab="1"
                          data-i18n-fr={fr.hero.tabEssaye} data-i18n-en={en.hero.tabEssaye}>{fr.hero.tabEssaye}</button>
                  <button class="sit-tab flex-1 py-2 px-3 text-center font-semibold tracking-wide transition-colors duration-150" data-tab="2"
                          data-i18n-fr={fr.hero.tabPromesse} data-i18n-en={en.hero.tabPromesse}>{fr.hero.tabPromesse}</button>
                </div>

                <div class="sit-content border-t border-white/[0.06]" style="position:relative;">
                  <div class="sit-pane px-4 py-3" data-pane="0" style="position:absolute;top:0;left:0;right:0;opacity:1;pointer-events:auto;transition:opacity 0.15s ease;">
                    <p class="text-slate-300 text-sm leading-relaxed sit-passe"
                       data-fr={s.ceQuiSePasse} data-en={en.situations[i].ceQuiSePasse}>{s.ceQuiSePasse}</p>
                  </div>
                  <div class="sit-pane px-4 py-3" data-pane="1" style="position:absolute;top:0;left:0;right:0;opacity:0;pointer-events:none;transition:opacity 0.15s ease;">
                    <ul class="space-y-1 mb-2 sit-essaye-list"
                        data-fr={JSON.stringify(s.essaye)} data-en={JSON.stringify(en.situations[i].essaye)}>
                      {s.essaye.map((e: string) => (
                        <li class="text-slate-400 text-sm flex items-start gap-2">
                          <span class="text-slate-600 mt-0.5 shrink-0">–</span>
                          <span>{e}</span>
                        </li>
                      ))}
                    </ul>
                    <p class="text-slate-500 text-xs italic mt-2 sit-conclusion"
                       data-fr={s.essayeConclusion} data-en={en.situations[i].essayeConclusion}>{s.essayeConclusion}</p>
                  </div>
                  <div class="sit-pane px-4 py-3" data-pane="2" style="position:absolute;top:0;left:0;right:0;opacity:0;pointer-events:none;transition:opacity 0.15s ease;">
                    <p class="text-white/80 text-sm leading-relaxed sit-reponse"
                       data-fr={s.reponse} data-en={en.situations[i].reponse}>{s.reponse}</p>
                  </div>
                </div>

                <div class="flex justify-center gap-1.5 pb-2">
                  <span class="swipe-dot w-1.5 h-1.5 rounded-full bg-energy-green" data-dot="0"></span>
                  <span class="swipe-dot w-1.5 h-1.5 rounded-full bg-white/20" data-dot="1"></span>
                  <span class="swipe-dot w-1.5 h-1.5 rounded-full bg-white/20" data-dot="2"></span>
                </div>
              </div>

            </div>
          ))}
        </div>
      </div>

    </div>
  </div>

  <div class="absolute bottom-8 left-1/2 -translate-x-1/2 text-white/30 animate-bounce">
    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3" />
    </svg>
  </div>
</section>

<style>
  .sit-tab { color: rgba(255,255,255,0.3); }
  .sit-tab:hover { color: rgba(255,255,255,0.6); background: rgba(255,255,255,0.04); }
  .sit-tab.active-tab { color: #4ade80; background: rgba(74,222,128,0.06); }
</style>

<script>
  // ── Rotating tagline ──
  const container = document.getElementById('rotating-tagline');
  if (container) {
    const words = container.querySelectorAll('.word');
    let current = 0;
    setInterval(() => {
      words[current].classList.remove('active');
      current = (current + 1) % words.length;
      words[current].classList.add('active');
    }, 3000);
  }

  // ── Accordion + tabs + swipe ──
  document.addEventListener('DOMContentLoaded', () => {
    const items = document.querySelectorAll('#hero-situations .sit-item');

    items.forEach(item => {
      const trigger = item.querySelector('.sit-trigger')!;
      const panel   = item.querySelector('.sit-panel')!;
      const arrow   = item.querySelector('.sit-arrow')!;
      const tabs    = item.querySelectorAll('.sit-tab');
      const panes   = item.querySelectorAll('.sit-pane');
      const dots    = item.querySelectorAll('.swipe-dot');

      function lockContentHeight() {
        const content = item.querySelector('.sit-content') as HTMLElement;
        content.style.height = '';
        let maxH = 0;
        panes.forEach((p: any) => {
          const prev = { opacity: p.style.opacity, pointer: p.style.pointerEvents, position: p.style.position };
          p.style.opacity = '0'; p.style.pointerEvents = 'none'; p.style.position = 'relative';
          maxH = Math.max(maxH, p.offsetHeight);
          p.style.opacity = prev.opacity; p.style.pointerEvents = prev.pointer; p.style.position = prev.position;
        });
        content.style.height = maxH + 'px';
      }

      trigger.addEventListener('click', () => {
        const isOpen = !panel.classList.contains('hidden');
        items.forEach(it => {
          it.querySelector('.sit-panel')!.classList.add('hidden');
          (it.querySelector('.sit-arrow') as HTMLElement).style.transform = '';
          it.querySelector('.sit-trigger')!.setAttribute('aria-expanded', 'false');
          (it.querySelector('.sit-content') as HTMLElement).style.height = '';
        });
        if (!isOpen) {
          panel.classList.remove('hidden');
          (arrow as HTMLElement).style.transform = 'rotate(180deg)';
          trigger.setAttribute('aria-expanded', 'true');
          lockContentHeight();
          switchPane(0);
        }
      });

      tabs.forEach(tab => {
        tab.addEventListener('click', () => switchPane(parseInt((tab as HTMLElement).dataset.tab || '0')));
        tab.addEventListener('mouseenter', () => switchPane(parseInt((tab as HTMLElement).dataset.tab || '0')));
      });

      let touchStartX = 0;
      let curPane = 0;
      const content = item.querySelector('.sit-content')!;
      content.addEventListener('touchstart', (e: any) => { touchStartX = e.changedTouches[0].clientX; }, { passive: true });
      content.addEventListener('touchend', (e: any) => {
        const dx = e.changedTouches[0].clientX - touchStartX;
        if (Math.abs(dx) < 40) return;
        switchPane(dx < 0 ? Math.min(curPane + 1, 2) : Math.max(curPane - 1, 0));
      }, { passive: true });

      function switchPane(idx: number) {
        curPane = idx;
        tabs.forEach((t, i) => t.classList.toggle('active-tab', i === idx));
        panes.forEach((p: any, i) => {
          p.style.opacity = i === idx ? '1' : '0';
          p.style.pointerEvents = i === idx ? 'auto' : 'none';
        });
        dots.forEach((d, i) => {
          d.classList.toggle('bg-energy-green', i === idx);
          d.classList.toggle('bg-white/20', i !== idx);
        });
      }
    });

    // ── i18n : éléments Hero spéciaux (taglines, situations) ──
    function updateHeroLang(lang: string) {
      // Rotating tagline words
      document.querySelectorAll('#rotating-tagline .word').forEach((el: any) => {
        el.textContent = lang === 'en' ? el.dataset.taglineEn : el.dataset.taglineFr;
      });
    }

    function updateSituationsLang(lang: string) {
      document.querySelectorAll('.sit-accroche').forEach((el: any) => {
        el.textContent = el.dataset[lang] || el.dataset.fr;
      });
      document.querySelectorAll('.sit-passe').forEach((el: any) => {
        el.textContent = el.dataset[lang] || el.dataset.fr;
      });
      document.querySelectorAll('.sit-conclusion').forEach((el: any) => {
        el.textContent = el.dataset[lang] || el.dataset.fr;
      });
      document.querySelectorAll('.sit-reponse').forEach((el: any) => {
        el.textContent = el.dataset[lang] || el.dataset.fr;
      });
      document.querySelectorAll('.sit-essaye-list').forEach((el: any) => {
        const items = JSON.parse(el.dataset[lang] || el.dataset.fr);
        el.innerHTML = items.map((e: string) =>
          `<li class="text-slate-400 text-sm flex items-start gap-2"><span class="text-slate-600 mt-0.5 shrink-0">–</span><span>${e}</span></li>`
        ).join('');
      });
      // Rotating tagline words
      document.querySelectorAll('#rotating-tagline .word').forEach((el: any) => {
        el.textContent = el.dataset[`tagline${lang.charAt(0).toUpperCase() + lang.slice(1)}`] || el.dataset.taglineFr;
      });
    }

    // Écoute les changements de langue
    const observer = new MutationObserver(() => {
      const lang = document.documentElement.getAttribute('data-lang') || 'fr';
      updateHeroLang(lang);
      updateSituationsLang(lang);
    });
    observer.observe(document.documentElement, { attributes: true, attributeFilter: ['data-lang'] });

    // Init
    const initLang = document.documentElement.getAttribute('data-lang') || 'fr';
    updateHeroLang(initLang);
    updateSituationsLang(initLang);
  });


</script>
