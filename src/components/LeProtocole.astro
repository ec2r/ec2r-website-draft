---
/**
 * Univers 4 : "Le protocole"
 * 5 étapes IRM, 3 parcours, lien app
 */
import type { Lang } from '../i18n/translations';
interface Props {
  lang: Lang;
  fr?: any;
  en?: any;
}
const { lang, fr, en } = Astro.props;
const t = lang === 'fr' ? fr : en;

const steps = [
  { num: '1', verbFr: 'Mesurer', verbEn: 'Measure', descFr: 'vos énergies collectives de réussite — cibler les leviers', descEn: 'your collective success energies — target the levers', color: '#DC2626' },
  { num: '2', verbFr: 'Prioriser', verbEn: 'Prioritize', descFr: 'ensemble les axes, priorités et comportements sur lesquels agir', descEn: 'together the areas, priorities and behaviours to act on', color: '#EAB308' },
  { num: '3', verbFr: 'Restituer', verbEn: 'Present', descFr: 'embarquer vos équipes ou managers en situation', descEn: 'engage your teams or managers in context', color: '#C9A56E' },
  { num: '4', verbFr: 'Identifier', verbEn: 'Identify', descFr: 'profils, enjeux et leviers de leadership de vos managers', descEn: 'profiles, stakes and leadership levers of your managers', color: '#22C55E' },
  { num: '5', verbFr: 'Ancrer', verbEn: 'Anchor', descFr: 'le passage à l\'acte en s\'entraînant jusqu\'au micro-comportement en situation', descEn: 'the transition to action by training down to micro-behaviour in situation', color: '#166534' },
];

// Palette stricte EC²R (tma_gauge_controller.js)
const gaugeColor = (score: number): string => {
  if (score <= 20) return '#C00000';
  if (score <= 40) return '#FCB118';
  if (score <= 60) return '#FFCC99';
  if (score <= 80) return '#92D050';
  return '#00B050';
};

const parcours = [
  {
    titleFr: 'Mon collectif',
    titleEn: 'My collective',
    icon: '👥',
    preview: null,
    previewAlt: '',
    headlineFr: 'Baromètre énergétique EC²R',
    headlineEn: 'EC²R energy barometer',
    subFr: 'Diagnostic et levier+ immédiat pour mobiliser+ mes équipes',
    subEn: 'Diagnosis and immediate+ lever to mobilize+ my teams',
    itemsFr: ['Baromètre énergétique collectif', 'Restitution+ embarquement', 'Temps fort de restitution et d\'embarquement'],
    itemsEn: ['Collective energy barometer', 'Restitution+ onboarding', 'Strong restitution and onboarding moment'],
  },
  {
    titleFr: 'Mes leaders',
    titleEn: 'My leaders',
    icon: '🎯',
    preview: null,
    previewAlt: '',
    headlineFr: 'Accompagner mes leaders',
    headlineEn: 'Support my leaders',
    subFr: 'Profil de leadership EC²R — faire ma part pour mobiliser ou remobiliser mes équipes, sans épuiser mes batteries',
    subEn: 'EC²R leadership profile — do my part to mobilize or remobilize my teams without draining my batteries',
    itemsFr: ['Profiling de leadership', 'Formation+ accompagnement', 'Mentoring sur situations'],
    itemsEn: ['Leadership profiling', 'Training+ support', 'Situation-based mentoring'],
  },
  {
    titleFr: 'Moi',
    titleEn: 'Me',
    icon: '🚀',
    preview: null,
    previewAlt: '',
    headlineFr: 'Méntōr EC²R sur mes situations terrain',
    headlineEn: 'Méntōr EC²R on my field situations',
    subFr: 'Expérimenter, avancer en autonomie',
    subEn: 'Experiment, advance autonomously',
    itemsFr: ['Je me forme sur la Méthode', 'Je m\'entraîne sur mes situations métiers', 'Méntōr EC²R'],
    itemsEn: ['I learn the Method', 'I train on my work situations', 'Méntōr EC²R'],
    badge: null,
  },
];
---

<div class="min-h-full bg-surface relative">
  <div class="absolute inset-0 bg-gradient-to-br from-surface-alt/50 via-surface to-surface"></div>

  <div class="relative z-10 max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-10 lg:py-14">

    <!-- Titre animé -->
    <div class="text-center mb-10">
      <h2 class="text-3xl md:text-4xl lg:text-5xl font-display font-extrabold text-ink inline-block mb-1">
        {lang === 'fr' ? "Plateforme d'activation du leadership" : 'Leadership activation platform'}
      </h2>
      <p class="text-lg energy-gradient-text font-display font-bold mb-3">
        {lang === 'fr' ? 'individuel et collectif' : 'individual and collective'}
      </p>
      <p class="text-ink-muted text-base max-w-2xl mx-auto font-medium">
        {lang === 'fr' ? (
          <>Un IRM<span class="plus-accent">+</span> organisationnel : diagnostic<span class="plus-accent">+</span> chirurgical, passage<span class="plus-accent">+</span> rapide à l'acte, mesure<span class="plus-accent">+</span> immédiate d'impact.</>
        ) : (
          <>An organizational MRI<span class="plus-accent">+</span>: surgical<span class="plus-accent">+</span> diagnosis, fast<span class="plus-accent">+</span> transition to action, immediate<span class="plus-accent">+</span> impact measurement.</>
        )}
      </p>
      <p class="text-ink-faint text-xs mt-2 max-w-2xl mx-auto italic">
        {lang === 'fr'
          ? 'Ni seulement un cabinet de conseil, ni seulement un organisme de formation, ni seulement un outil RH.'
          : 'Not just a consulting firm, not just a training organization, not just an HR tool.'}
      </p>
    </div>

    <!-- 5 étapes IRM -->
    <div class="mb-14">
      <div class="space-y-3">
        {steps.map(s => (
          <div class="flex items-start gap-4 group">
            <div class="shrink-0 w-10 h-10 rounded-full flex items-center justify-center text-sm font-bold text-ink"
                 style={`background:${s.color}`}>
              {s.num}
            </div>
            <div class="pt-1.5">
              <span class="text-ink font-display font-bold text-lg" style={`color:${s.color}`}>
                {lang === 'fr' ? s.verbFr : s.verbEn}
                <span class="plus-accent">+</span>
              </span>
              <span class="text-ink-subtle text-sm ml-2">
                {lang === 'fr' ? s.descFr : s.descEn}
              </span>
            </div>
          </div>
        ))}
      </div>
    </div>

    <!-- 3 parcours empilés — alternance visuel/texte
         Palette stricte EC²R (tma_gauge_controller.js) :
         0-20 #C00000 rouge / 21-40 #FCB118 jaune / 41-60 #FFCC99 beige
         61-80 #92D050 vert clair / 81-100 #00B050 vert foncé -->
    <div class="space-y-6 mb-12">

      <!-- ─── LIGNE 1 : Mon collectif (visuel masqué — vocal Stéphane 05/05 : ne pas exposer l'IA) ─── -->
      <div class="bg-surface-alt border border-border-subtle rounded-xl overflow-hidden hover:border-border transition-all">
        <div class="grid md:grid-cols-3 gap-0">
          <!-- Visuel reconstruit : Baromètre 6 énergies + score central — petit -->
          <div class="md:col-span-1 bg-gradient-to-br from-surface-alt via-surface to-surface-alt p-4 lg:p-5 relative">
            <p class="text-[10px] uppercase tracking-widest text-ink-faint font-semibold mb-4">
              {lang === 'fr' ? 'Reconstruction illustrative — données fictives' : 'Illustrative reconstruction — fictional data'}
            </p>
            {/* Ordre demandé par Stéphane (12/05) :
                - Colonne GAUCHE bottom→top : Projeter, Centrer, Exiger
                - Colonne DROITE top→bottom : Animer, Réguler, Remobiliser
                Layout : grid-flow-col + grid-rows-3 → le tableau est rempli colonne par colonne.
                Tableau dans l'ordre col1(top→bottom) puis col2(top→bottom) :
                  [Exiger, Centrer, Projeter, Animer, Réguler, Remobiliser]
                → côté gauche, en partant du bas on retrouve Projeter / Centrer / Exiger. ✓ */}
            <div class="grid grid-cols-2 grid-rows-3 grid-flow-col gap-3 lg:gap-4">
              {[
                { name: 'Exiger', file: 'exiger', score: 51 },           // col-G top
                { name: 'Centrer', file: 'centrer', score: 56 },         // col-G middle
                { name: 'Projeter', file: 'projeter', score: 75 },       // col-G bottom
                { name: 'Animer', file: 'animer', score: 60 },           // col-D top
                { name: 'Réguler', file: 'recentrer', score: 71 },       // col-D middle
                { name: 'Remobiliser', file: 'remobiliser', score: 59 }, // col-D bottom
              ].map(e => (
                <div class="flex items-center gap-3 bg-surface-alt border border-border-subtle rounded-lg p-2.5">
                  <img src={`/images/energies/${e.file}-thumb.webp`}
                       srcset={`/images/energies/${e.file}-thumb.webp 1x, /images/energies/${e.file}.webp 2x`}
                       alt={e.name} class="w-12 h-12 object-cover rounded shrink-0" loading="lazy" />
                  <div class="flex-1 min-w-0">
                    {/* Layout 2 lignes : nom seul en haut (pleine largeur du flex-1 → plus de troncature),
                        puis sur la 2e ligne : barre + score aligné à droite (colonne fixe).
                        L'alignement vertical des chiffres dans chaque colonne est garanti par width:1.75rem + tabular-nums. */}
                    <div class="mb-1">
                      <span class="text-ink text-xs font-semibold">{e.name}<span class="plus-accent text-[10px]">+</span></span>
                    </div>
                    <div class="flex items-center gap-2">
                      <div class="h-1 flex-1 bg-surface-raised rounded-full overflow-hidden">
                        <div class="h-full rounded-full" style={`width:${e.score}%;background:${gaugeColor(e.score)}`}></div>
                      </div>
                      <span class="text-sm font-display font-bold tabular-nums text-right shrink-0" style={`color:${gaugeColor(e.score)}; width:1.75rem`}>{e.score}</span>
                    </div>
                  </div>
                </div>
              ))}
            </div>
            <!-- Score central = moyenne arithmétique des 6 (62 → vert clair) -->
            <div class="mt-5 flex items-center justify-center">
              <div class="bg-surface-raised border border-border-subtle rounded-xl px-6 py-3 text-center">
                <div class="font-display font-extrabold text-3xl leading-none" style="color:#92D050">62<span class="text-base text-ink-faint">/100</span></div>
                <div class="text-[10px] uppercase tracking-wider text-ink-subtle font-semibold mt-1">
                  {lang === 'fr' ? 'Énergie collective (moyenne)' : 'Collective energy (average)'}
                </div>
              </div>
            </div>
          </div>
          <!-- Texte 2/3 (visuel petit 1/3 — req Stéphane 12/05 : remettre visuels en petit) -->
          <div class="md:col-span-2 p-6 lg:p-8 flex flex-col justify-center">
            <p class="text-accent/80 text-[10px] uppercase tracking-wider font-semibold mb-2">
              {lang === 'fr' ? parcours[0].titleFr : parcours[0].titleEn}
            </p>
            <h3 class="text-ink font-display font-bold text-xl mb-3 leading-tight">
              {lang === 'fr' ? parcours[0].headlineFr : parcours[0].headlineEn}
            </h3>
            <p class="text-ink-muted text-sm leading-relaxed mb-4 italic">
              {lang === 'fr' ? (
                <>Diagnostic et levier<span class="plus-accent">+</span> immédiat pour mobiliser<span class="plus-accent">+</span> mes équipes</>
              ) : (
                <>Diagnosis and immediate<span class="plus-accent">+</span> lever to mobilize<span class="plus-accent">+</span> my teams</>
              )}
            </p>
            <ul class="space-y-1.5 border-t border-border-subtle pt-3">
              <li class="text-ink-subtle text-xs flex items-start gap-2"><span class="text-accent/60 mt-0.5">›</span><span>{lang === 'fr' ? 'Baromètre énergétique collectif' : 'Collective energy barometer'}</span></li>
              <li class="text-ink-subtle text-xs flex items-start gap-2"><span class="text-accent/60 mt-0.5">›</span><span>{lang === 'fr' ? (<>Restitution<span class="plus-accent">+</span> embarquement</>) : (<>Restitution<span class="plus-accent">+</span> onboarding</>)}</span></li>
              <li class="text-ink-subtle text-xs flex items-start gap-2"><span class="text-accent/60 mt-0.5">›</span><span>{lang === 'fr' ? "Temps fort de restitution et d'embarquement" : 'Strong restitution and onboarding moment'}</span></li>
            </ul>
          </div>
        </div>
      </div>

      <!-- ─── LIGNE 2 : Mes leaders (visuel masqué — vocal Stéphane 05/05 : ne pas exposer l'IA) ─── -->
      <div class="bg-surface-alt border border-border-subtle rounded-xl overflow-hidden hover:border-border transition-all">
        <div class="grid md:grid-cols-3 gap-0">
          <!-- Texte 2/3 (visuel petit 1/3 — req Stéphane 12/05 : remettre visuels en petit) -->
          <div class="md:col-span-2 p-6 lg:p-8 flex flex-col justify-center">
            <p class="text-accent/80 text-[10px] uppercase tracking-wider font-semibold mb-2">
              {lang === 'fr' ? parcours[1].titleFr : parcours[1].titleEn}
            </p>
            <h3 class="text-ink font-display font-bold text-xl mb-3 leading-tight">
              {lang === 'fr' ? parcours[1].headlineFr : parcours[1].headlineEn}
            </h3>
            <p class="text-ink-muted text-sm leading-relaxed mb-4 italic">
              {lang === 'fr' ? parcours[1].subFr : parcours[1].subEn}
            </p>
            <ul class="space-y-1.5 border-t border-border-subtle pt-3">
              <li class="text-ink-subtle text-xs flex items-start gap-2"><span class="text-accent/60 mt-0.5">›</span><span>{lang === 'fr' ? 'Profiling de leadership' : 'Leadership profiling'}</span></li>
              <li class="text-ink-subtle text-xs flex items-start gap-2"><span class="text-accent/60 mt-0.5">›</span><span>{lang === 'fr' ? (<>Formation<span class="plus-accent">+</span> accompagnement</>) : (<>Training<span class="plus-accent">+</span> support</>)}</span></li>
              <li class="text-ink-subtle text-xs flex items-start gap-2"><span class="text-accent/60 mt-0.5">›</span><span>{lang === 'fr' ? 'Mentoring sur situations' : 'Situation-based mentoring'}</span></li>
            </ul>
          </div>
          <!-- Visuel reconstruit : Profil leader — petit -->
          <div class="md:col-span-1 bg-gradient-to-br from-surface-alt via-surface to-surface-alt p-4 lg:p-5 md:order-2 order-1 relative">
            <p class="text-[10px] uppercase tracking-widest text-ink-faint font-semibold mb-4">
              {lang === 'fr' ? 'Reconstruction illustrative — données fictives' : 'Illustrative reconstruction — fictional data'}
            </p>
            <!-- Score central — palier 51-60 = ENGAGEANT (tma_profiles_helper.rb) -->
            <div class="text-center mb-5">
              <div class="text-[10px] uppercase tracking-widest text-accent/70 font-semibold mb-1">
                {lang === 'fr' ? 'Leadership global' : 'Global leadership'}
              </div>
              <div class="font-display font-extrabold text-5xl leading-none" style="color:#FFCC99">55<span style="color:#FFCC99cc">.6</span><span class="text-base text-ink-faint ml-1">/100</span></div>
              <div class="inline-block mt-2 border text-xs font-bold uppercase tracking-wider px-3 py-1 rounded-full" style="background:#FFCC9920;border-color:#FFCC9966;color:#FFCC99">
                ENGAGEANT
              </div>
            </div>
            <!-- Mini-batteries — 6 dimensions, somme 334 → moyenne 55.7 ≈ 55.6 -->
            <div class="grid grid-cols-2 gap-3 lg:gap-4">
              {[
                { labelFr: 'Endurance', labelEn: 'Endurance', score: 36 },         // 21-40 jaune
                { labelFr: 'M\'affirmer', labelEn: 'Assertiveness', score: 56 },   // 41-60 beige
                { labelFr: 'Souplesse', labelEn: 'Flexibility', score: 51 },       // 41-60 beige
                { labelFr: 'Adaptabilité', labelEn: 'Adaptability', score: 65 },   // 61-80 vert clair
                { labelFr: 'Délégation', labelEn: 'Delegation', score: 44 },       // 41-60 beige
                { labelFr: 'Négociation', labelEn: 'Negotiation', score: 82 },     // 81-100 vert foncé
              ].map(d => (
                <div class="bg-surface-alt border border-border-subtle rounded-lg p-2.5">
                  <div class="flex items-baseline justify-between mb-1.5">
                    <span class="text-ink text-xs font-semibold uppercase tracking-wide">{lang === 'fr' ? d.labelFr : d.labelEn}<span class="plus-accent text-[10px]">+</span></span>
                    <span class="text-sm font-display font-bold" style={`color:${gaugeColor(d.score)}`}>{d.score}<span class="text-[9px] text-ink-faint">%</span></span>
                  </div>
                  <div class="h-1 bg-surface-raised rounded-full overflow-hidden">
                    <div class="h-full rounded-full" style={`width:${d.score}%;background:${gaugeColor(d.score)}`}></div>
                  </div>
                </div>
              ))}
            </div>
          </div>
        </div>
      </div>

      <!-- ─── LIGNE 3 : Moi (visuel masqué — vocal Stéphane 05/05 : ne pas exposer l'IA / Méntōr) ─── -->
      <div class="bg-surface-alt border border-border-subtle rounded-xl overflow-hidden hover:border-border transition-all">
        <div class="grid md:grid-cols-3 gap-0">
          <!-- Visuel : simili-chat + avatar Méntōr — petit -->
          <div class="md:col-span-1 bg-gradient-to-br from-surface-alt via-surface to-surface-alt relative overflow-hidden">
            <p class="absolute top-3 left-4 text-[10px] uppercase tracking-widest text-ink-faint font-semibold z-10">
              {lang === 'fr' ? 'Mode simulation — Méntōr EC²R' : 'Simulation mode — Méntōr EC²R'}
            </p>
            <div class="grid grid-cols-1 h-full min-h-[280px]">
              <!-- Simili-chat — bulles 2/3 largeur, chevauchement, traits 3/2/2/1 -->
              <div class="px-4 pt-10 pb-14 flex flex-col justify-start gap-2.5 relative">
                <!-- Bulle 1 mentor (gauche, 3 traits, déborde à droite) -->
                <div class="flex justify-start">
                  <div class="bg-surface-raised border border-border-subtle rounded-xl rounded-bl-sm px-4 py-3 space-y-2" style="width:88%; margin-right:-12%">
                    <div class="h-2 bg-ink-faint/40 rounded-full" style="width:92%"></div>
                    <div class="h-2 bg-ink-faint/40 rounded-full" style="width:78%"></div>
                    <div class="h-2 bg-ink-faint/40 rounded-full" style="width:55%"></div>
                  </div>
                </div>
                <!-- Bulle 2 user (droite, 2 traits, déborde à gauche) -->
                <div class="flex justify-end">
                  <div class="bg-energy-green/15 border border-energy-green/25 rounded-xl rounded-br-sm px-4 py-3 space-y-2" style="width:85%; margin-left:-15%">
                    <div class="h-2 bg-energy-green/45 rounded-full" style="width:88%"></div>
                    <div class="h-2 bg-energy-green/45 rounded-full" style="width:62%"></div>
                  </div>
                </div>
                <!-- Bulle 3 mentor (gauche, 2 traits, déborde à droite) -->
                <div class="flex justify-start">
                  <div class="bg-surface-raised border border-border-subtle rounded-xl rounded-bl-sm px-4 py-3 space-y-2" style="width:80%; margin-right:-10%">
                    <div class="h-2 bg-ink-faint/40 rounded-full" style="width:80%"></div>
                    <div class="h-2 bg-ink-faint/40 rounded-full" style="width:65%"></div>
                  </div>
                </div>
                <!-- Bulle 4 user (droite, 1 trait, déborde à gauche) -->
                <div class="flex justify-end">
                  <div class="bg-energy-green/15 border border-energy-green/25 rounded-xl rounded-br-sm px-4 py-3" style="width:75%; margin-left:-12%">
                    <div class="h-2 bg-energy-green/45 rounded-full" style="width:70%"></div>
                  </div>
                </div>
                {/* 3 badges modes en bas — Texte / Audio / Vidéo (req Stéphane 13/05) */}
                <div class="absolute bottom-3 left-1/2 -translate-x-1/2 flex items-center gap-2">
                  {[
                    { fr: 'Texte', en: 'Text' },
                    { fr: 'Audio', en: 'Audio' },
                    { fr: 'Vidéo', en: 'Video' },
                  ].map(b => (
                    <div class="flex items-center gap-1.5 bg-energy-green/15 backdrop-blur-sm border border-accent/30 rounded-full px-2.5 py-1">
                      <span class="w-1.5 h-1.5 rounded-full bg-accent"></span>
                      <span class="text-[10px] uppercase tracking-wider text-accent font-semibold">
                        {lang === 'fr' ? b.fr : b.en}
                      </span>
                    </div>
                  ))}
                </div>
              </div>
              {/* Bloc avatar Méntōr (photo Stéphane + waveform "À l'écoute") retiré — req Stéphane 13/05 */}
            </div>
          </div>
          <!-- Texte 2/3 (visuel petit 1/3 — req Stéphane 12/05 : remettre visuels en petit) -->
          <div class="md:col-span-2 p-6 lg:p-8 flex flex-col justify-center">
            <p class="text-accent/80 text-[10px] uppercase tracking-wider font-semibold mb-2">
              {lang === 'fr' ? parcours[2].titleFr : parcours[2].titleEn}
            </p>
            <h3 class="text-ink font-display font-bold text-xl mb-3 leading-tight">
              {lang === 'fr' ? parcours[2].headlineFr : parcours[2].headlineEn}
            </h3>
            <p class="text-ink-muted text-sm leading-relaxed mb-4 italic">
              {lang === 'fr' ? parcours[2].subFr : parcours[2].subEn}
            </p>
            <ul class="space-y-1.5 border-t border-border-subtle pt-3">
              <li class="text-ink-subtle text-xs flex items-start gap-2"><span class="text-accent/60 mt-0.5">›</span><span>{lang === 'fr' ? 'Lui envoyer un message dans la journée' : 'Send a message during the day'}</span></li>
              <li class="text-ink-subtle text-xs flex items-start gap-2"><span class="text-accent/60 mt-0.5">›</span><span>{lang === 'fr' ? "Lui parler à l'oral, comme avec un coach" : 'Talk out loud, like with a coach'}</span></li>
              <li class="text-ink-subtle text-xs flex items-start gap-2"><span class="text-accent/60 mt-0.5">›</span><span>{lang === 'fr' ? "S'entraîner en face-à-face avec un avatar vidéo" : 'Train face-to-face with a video avatar'}</span></li>
            </ul>
          </div>
        </div>
      </div>

    </div>

    <!-- Lien app + ce que l'app permet -->
    <div class="text-center bg-surface-alt border border-border-subtle rounded-xl p-6">
      <p class="text-ink-subtle text-sm mb-3">
        {lang === 'fr'
          ? "Ce que l'app permet de réussir : Mesurer, piloter, suivre, accompagner — en individuel et en collectif."
          : 'What the app enables: Measure, steer, track, support — individually and collectively.'}
      </p>
      <div class="flex flex-col items-center gap-2">
        <a href="https://app.methode-ec2r.com" target="_blank" rel="noopener"
           class="inline-flex items-center gap-2 px-6 py-3 bg-accent/10 border border-accent/30
                  text-accent text-base font-semibold rounded-lg hover:bg-accent/20 hover:border-energy-green/50 transition-all">
          {lang === 'fr' ? 'Accéder à la plateforme' : 'Access the platform'}
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
          </svg>
        </a>
        <p class="text-ink-subtle text-xs">
          {lang === 'fr' ? 'mon espace praticien / partenaire' : 'my practitioner / partner space'}
        </p>
      </div>
    </div>

  </div>
</div>
