---
/**
 * Animated battery SVG — visual signature of EC²R.
 * 5 cells representing energy levels from Divergent (red) to Aligné (dark green).
 */
interface Props {
  class?: string;
}

const { class: className = '' } = Astro.props;

const levels = [
  { color: '#166534', label: 'Aligné', y: 16, delay: '1.6s' },
  { color: '#22C55E', label: 'Engagé', y: 60, delay: '1.2s' },
  { color: '#C9A56E', label: 'Neutre', y: 104, delay: '0.8s' },
  { color: '#EAB308', label: 'Préoccupé', y: 148, delay: '0.4s' },
  { color: '#DC2626', label: 'Divergent', y: 192, delay: '0s' },
];
---

<div class={`battery-container ${className}`}>
  <svg viewBox="0 0 120 260" fill="none" xmlns="http://www.w3.org/2000/svg" class="w-full h-full">
    <!-- Battery terminal -->
    <rect x="40" y="2" width="40" height="10" rx="3" fill="white" opacity="0.3" />

    <!-- Battery body outline -->
    <rect x="14" y="14" width="92" height="232" rx="8" stroke="white" stroke-width="2" opacity="0.25" />

    <!-- Energy cells -->
    {levels.map((level) => (
      <g class="battery-cell" style={`--delay: ${level.delay}`}>
        <rect
          x="22"
          y={level.y}
          width="76"
          height="36"
          rx="4"
          fill={level.color}
          opacity="0"
          class="cell-fill"
        />
        <text
          x="60"
          y={level.y + 22}
          text-anchor="middle"
          fill="white"
          font-size="9"
          font-weight="600"
          font-family="'Plus Jakarta Sans', sans-serif"
          opacity="0"
          class="cell-label"
        >
          {level.label}
        </text>
      </g>
    ))}

    <!-- Plus terminal symbol -->
    <text x="60" y="10" text-anchor="middle" fill="white" font-size="8" font-weight="bold" opacity="0.5">+</text>
  </svg>
</div>

<style>
  .battery-container {
    filter: drop-shadow(0 0 30px rgba(22, 101, 52, 0.15));
  }

  .cell-fill {
    animation: cellAppear 0.6s ease-out forwards;
    animation-delay: var(--delay);
  }

  .cell-label {
    animation: cellAppear 0.4s ease-out forwards;
    animation-delay: calc(var(--delay) + 0.3s);
  }

  @keyframes cellAppear {
    0% {
      opacity: 0;
      transform: scaleX(0.3);
    }
    60% {
      opacity: 0.9;
      transform: scaleX(1.02);
    }
    100% {
      opacity: 1;
      transform: scaleX(1);
    }
  }

  /* Subtle glow on the top cell once loaded */
  .battery-cell:first-child .cell-fill {
    animation: cellAppear 0.6s ease-out forwards, subtleGlow 4s ease-in-out 2.5s infinite;
  }

  @keyframes subtleGlow {
    0%, 100% { filter: brightness(1); }
    50% { filter: brightness(1.3); }
  }
</style>
