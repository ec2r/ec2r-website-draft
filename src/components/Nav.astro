---
interface Props {
  fr: { method: string; proof: string; testimonials: string; protocol: string; practitioners: string; contact: string };
  en: { method: string; proof: string; testimonials: string; protocol: string; practitioners: string; contact: string };
}
const { fr, en } = Astro.props;

const links = [
  { href: '#methode',      fr: fr.method,        en: en.method },
  { href: '#preuves',      fr: fr.proof,         en: en.proof },
  { href: '#temoignages',  fr: fr.testimonials,  en: en.testimonials },
  { href: '#protocole',    fr: fr.protocol,      en: en.protocol },
  { href: '#equipe',       fr: fr.practitioners, en: en.practitioners },
  { href: '#contact',      fr: fr.contact,       en: en.contact },
];
---

<!-- Scroll progress bar -->
<div id="scroll-progress-track" style="position:fixed;top:0;left:0;right:0;height:8px;z-index:99;background:rgba(15,23,42,0.9);"></div>
<div id="scroll-progress" style="position:fixed;top:0;left:0;height:8px;z-index:100;background:linear-gradient(90deg,#DC2626,#EAB308,#C9A56E,#22C55E,#166534);width:0%;transition:width 0.1s linear;"></div>

<nav id="nav" class="fixed top-[8px] left-0 right-0 z-50 transition-all duration-300">
  <div class="max-w-7xl mx-auto px-6 lg:px-8 flex items-center justify-between h-16 lg:h-20">
    <!-- Logo -->
    <a href="/" class="flex items-center gap-3 group">
      <img src="/images/logo-ec2r.png" alt="EC²R" class="h-8 lg:h-9 nav-logo-img transition-all duration-300" />
    </a>

    <!-- Desktop links -->
    <ul class="hidden md:flex items-center gap-8">
      {links.map(({ href, fr: labelFr, en: labelEn }) => (
        <li>
          <a href={href} class="nav-link text-base font-semibold tracking-wide transition-colors duration-200
                 text-white/70 hover:text-white
                 relative after:absolute after:bottom-[-4px] after:left-0 after:w-0 after:h-0.5
                 after:bg-energy-green after:transition-all after:duration-300
                 hover:after:w-full [&.active]:after:w-full [&.active]:text-white">
            <span data-i18n-lang="fr">{labelFr}</span>
            <span data-i18n-lang="en">{labelEn}</span>
          </a>
        </li>
      ))}
    </ul>

    <!-- Lang toggle + Mobile hamburger -->
    <div class="flex items-center gap-3">
      <!-- Lang toggle -->
      <button id="lang-toggle" aria-label="Switch language"
        class="flex items-center gap-1.5 text-xs font-semibold tracking-widest text-white/60
               hover:text-white/90 transition-colors duration-200 border border-white/10
               hover:border-white/30 rounded-md px-2.5 py-1.5">
        <span id="lang-fr-flag" class="text-base leading-none">🇫🇷</span>
        <span id="lang-current">FR</span>
        <span class="text-white/20 mx-0.5">·</span>
        <span id="lang-en-flag" class="text-base leading-none" style="opacity:0.4">🇬🇧</span>
        <span id="lang-other" class="text-white/25">EN</span>
      </button>

      <!-- Mobile hamburger -->
      <button id="menu-toggle" class="md:hidden text-white p-2" aria-label="Menu">
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path id="menu-open" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
          <path id="menu-close" class="hidden" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
        </svg>
      </button>
    </div>
  </div>

  <!-- Mobile menu -->
  <div id="mobile-menu" class="hidden md:hidden bg-navy-950/98 backdrop-blur-lg border-t border-white/10">
    <ul class="px-6 py-4 space-y-1">
      {links.map(({ href, fr: labelFr, en: labelEn }) => (
        <li>
          <a href={href} class="mobile-nav-link block py-3 text-white/80 hover:text-white font-medium transition-colors">
            <span data-i18n-lang="fr">{labelFr}</span>
            <span data-i18n-lang="en">{labelEn}</span>
          </a>
        </li>
      ))}
    </ul>
  </div>
</nav>

<script>
  const nav      = document.getElementById('nav')!;
  const toggle   = document.getElementById('menu-toggle')!;
  const menu     = document.getElementById('mobile-menu')!;
  const menuOpen = document.getElementById('menu-open')!;
  const menuClose= document.getElementById('menu-close')!;
  const progress = document.getElementById('scroll-progress')!;
  const langBtn  = document.getElementById('lang-toggle')!;
  const langCur  = document.getElementById('lang-current')!;
  const langOth  = document.getElementById('lang-other')!;

  // ── Lang toggle ────────────────────────────────────────────────────
  // Init : appliquer la classe drapeau au chargement
  const initLang = localStorage.getItem('ec2r-lang') || 'fr';
  langBtn.classList.add(initLang === 'fr' ? 'lang-fr-active' : 'lang-en-active');

  langBtn.addEventListener('click', () => {
    const cur = document.documentElement.getAttribute('data-lang') || 'fr';
    const next = cur === 'fr' ? 'en' : 'fr';
    localStorage.setItem('ec2r-lang', next);
    document.documentElement.setAttribute('data-lang', next); // déclenche l'Observer
    langCur.textContent = next.toUpperCase();
    langOth.textContent = next === 'fr' ? 'EN' : 'FR';
    const frFlag = document.getElementById('lang-fr-flag') as HTMLElement;
    const enFlag = document.getElementById('lang-en-flag') as HTMLElement;
    if (frFlag && enFlag) {
      frFlag.style.opacity = next === 'fr' ? '1' : '0.4';
      enFlag.style.opacity = next === 'en' ? '1' : '0.4';
    }
    langBtn.classList.toggle('lang-fr-active', next === 'fr');
    langBtn.classList.toggle('lang-en-active', next === 'en');
  });

  // ── Scroll ────────────────────────────────────────────────────────
  let scrolled = false;
  window.addEventListener('scroll', () => {
    const isScrolled = window.scrollY > 40;
    if (isScrolled !== scrolled) {
      scrolled = isScrolled;
      nav.classList.toggle('bg-navy-950/95', isScrolled);
      nav.classList.toggle('backdrop-blur-lg', isScrolled);
      nav.classList.toggle('shadow-lg', isScrolled);
    }
    const scrollTop  = window.scrollY;
    const docHeight  = document.documentElement.scrollHeight - window.innerHeight;
    const pct        = docHeight > 0 ? (scrollTop / docHeight) * 100 : 0;
    progress.style.width = pct + '%';
  });

  // ── Mobile toggle ─────────────────────────────────────────────────
  toggle.addEventListener('click', () => {
    menu.classList.toggle('hidden');
    menuOpen.classList.toggle('hidden');
    menuClose.classList.toggle('hidden');
  });

  menu.querySelectorAll('.mobile-nav-link').forEach(link => {
    link.addEventListener('click', () => {
      menu.classList.add('hidden');
      menuOpen.classList.remove('hidden');
      menuClose.classList.add('hidden');
    });
  });

  window.addEventListener('scroll', () => {
    if (!menu.classList.contains('hidden')) {
      menu.classList.add('hidden');
      menuOpen.classList.remove('hidden');
      menuClose.classList.add('hidden');
    }
  });
</script>

<style>
  #lang-toggle.lang-fr-active {
    background: linear-gradient(90deg, rgba(0,35,149,0.08), rgba(255,255,255,0.04), rgba(237,41,57,0.08));
  }
  #lang-toggle.lang-en-active {
    background: linear-gradient(90deg, rgba(0,36,125,0.08), rgba(207,20,43,0.06), rgba(0,36,125,0.08));
  }
</style>
