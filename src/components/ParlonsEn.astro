---
/**
 * Univers 6 : "Parlons-en"
 * Échange humain, prise de RDV, formulaire contact
 */
import EC2R from './EC2R.astro';
interface Props { fr: any; en: any; }
const { fr, en } = Astro.props;
---

<div class="min-h-full bg-surface relative flex items-center">
  <div class="absolute inset-0 bg-gradient-to-tr from-surface via-surface-alt/30 to-surface"></div>

  <div class="relative z-10 max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-12 lg:py-16 w-full">

    <div class="text-center mb-10">
      <h2 class="text-3xl md:text-4xl lg:text-5xl font-display font-extrabold text-ink mb-4">
        <span data-i18n-lang="fr">Parlons-en !</span>
        <span data-i18n-lang="en">Let's talk!</span>
      </h2>

      <p class="text-lg text-ink-muted leading-relaxed max-w-2xl mx-auto mb-6">
        <span data-i18n-lang="fr">Un vrai échange humain et rapide, pas un pitch ou un formulaire commercial, 10 minutes, pas d'agent conversationnel, une vraie présence.</span>
        <span data-i18n-lang="en">A real human and quick exchange, not a pitch or commercial form, 10 minutes, no chatbot, a real presence.</span>
      </p>

      <!-- 3 intentions -->
      <div class="flex flex-wrap justify-center gap-3 mb-6 text-xs">
        <div class="bg-surface-alt border border-border-subtle rounded-lg px-4 py-2">
          <span class="text-accent font-bold" data-i18n-lang="fr">En être</span>
          <span class="text-accent font-bold" data-i18n-lang="en">Be part of it</span>
          <span class="text-ink-subtle" data-i18n-lang="fr"> : vous voulez vivre la méthode</span>
          <span class="text-ink-subtle" data-i18n-lang="en"> : you want to experience the method</span>
        </div>
        <div class="bg-surface-alt border border-border-subtle rounded-lg px-4 py-2">
          <span class="text-accent font-bold" data-i18n-lang="fr">Le vivre</span>
          <span class="text-accent font-bold" data-i18n-lang="en">Live it</span>
          <span class="text-ink-subtle" data-i18n-lang="fr"> : vous avez un projet collectif</span>
          <span class="text-ink-subtle" data-i18n-lang="en"> : you have a collective project</span>
        </div>
        <div class="bg-surface-alt border border-border-subtle rounded-lg px-4 py-2">
          <span class="text-accent font-bold" data-i18n-lang="fr">Prescrire</span>
          <span class="text-accent font-bold" data-i18n-lang="en">Prescribe</span>
          <span class="text-ink-subtle" data-i18n-lang="fr"> : vous pensez à quelqu'un</span>
          <span class="text-ink-subtle" data-i18n-lang="en"> : you're thinking of someone</span>
        </div>
      </div>

      <!-- Petit texte arrogant -->
      <p class="text-xs text-ink-disabled italic max-w-lg mx-auto">
        <span data-i18n-lang="fr">Si ça résonne et que vous voulez construire, parlons-en.</span>
        <span data-i18n-lang="en">If it resonates and you want to build, let's talk.</span>
      </p>
    </div>

    <!-- CTA secondaire (budget) — req Stéphane 12/05 : Cal RDV retiré, contact = formulaire -->
    <div class="flex justify-center mb-8">
      <button id="budget-btn" class="text-ink-faint hover:text-ink-muted border border-border-subtle hover:border-border-strong
              text-xs px-5 py-2.5 rounded-lg transition-all">
        <span data-i18n-lang="fr">Je cherche juste un budget</span>
        <span data-i18n-lang="en">I just need a budget</span>
      </button>
    </div>

    <!-- Formulaire de contact (canal principal — destinataire energies@methode-ec2r.com) -->
    <div id="contact-form-wrapper" class="max-w-lg mx-auto">
      <p class="text-center text-ink-muted text-sm mb-4">
        <span data-i18n-lang="fr">Écrivez-nous — réponse sous 24h ouvrées.</span>
        <span data-i18n-lang="en">Write to us — reply within 1 business day.</span>
      </p>
      <!-- Soumission AJAX → reste sur le site, pas de redirection (UX FormSubmit native trop moche) -->
      <form id="contact-form" action="https://formsubmit.co/ajax/energies@methode-ec2r.com" method="POST" class="space-y-4">
        <input type="hidden" name="_subject" value="[méthode-ec2r.com] Nouveau contact via site" />
        <input type="hidden" name="_template" value="table" />
        <input type="hidden" name="_captcha" value="false" />
        <!-- Honeypot anti-spam (champ caché, doit rester vide) -->
        <input type="text" name="_honey" style="display:none" tabindex="-1" autocomplete="off" />
        <div class="grid sm:grid-cols-2 gap-4">
          <input type="text" name="name" required
                 class="w-full bg-surface-alt border border-border-subtle rounded-lg px-4 py-3 text-ink text-sm
                        placeholder:text-ink-faint focus:border-energy-green/50 focus:ring-1 focus:ring-accent/30 
                        outline-none transition-all"
                 data-placeholder-fr="Votre nom" data-placeholder-en="Your name"
                 placeholder="Votre nom" />
          <input type="email" name="email" required
                 class="w-full bg-surface-alt border border-border-subtle rounded-lg px-4 py-3 text-ink text-sm
                        placeholder:text-ink-faint focus:border-energy-green/50 focus:ring-1 focus:ring-accent/30 
                        outline-none transition-all"
                 data-placeholder-fr="Votre email" data-placeholder-en="Your email"
                 placeholder="Votre email" />
        </div>
        <input type="text" name="organization"
               class="w-full bg-surface-alt border border-border-subtle rounded-lg px-4 py-3 text-ink text-sm
                      placeholder:text-ink-faint focus:border-energy-green/50 focus:ring-1 focus:ring-accent/30 
                      outline-none transition-all"
               data-placeholder-fr="Organisation (optionnel)" data-placeholder-en="Organization (optional)"
               placeholder="Organisation (optionnel)" />
        <textarea name="message" rows="3"
                  class="w-full bg-surface-alt border border-border-subtle rounded-lg px-4 py-3 text-ink text-sm
                         placeholder:text-ink-faint focus:border-energy-green/50 focus:ring-1 focus:ring-accent/30 
                         outline-none transition-all resize-none"
                  data-placeholder-fr="En quelques mots, ce qui résonne chez vous…" data-placeholder-en="In a few words, what resonates with you…"
                  placeholder="En quelques mots, ce qui résonne chez vous…"></textarea>
        <button id="contact-submit-btn" type="submit"
                class="w-full bg-surface-raised hover:bg-surface-raised text-ink font-semibold py-3 rounded-lg
                       border border-border-subtle hover:border-border transition-all text-sm disabled:opacity-60 disabled:cursor-wait">
          <span class="contact-btn-idle" data-i18n-lang="fr">Envoyer</span>
          <span class="contact-btn-idle" data-i18n-lang="en">Send</span>
          <span class="contact-btn-loading hidden" data-i18n-lang="fr">Envoi en cours…</span>
          <span class="contact-btn-loading hidden" data-i18n-lang="en">Sending…</span>
        </button>
      </form>

      <!-- États post-submit (affichés via JS — pas de redirection) -->
      <div id="contact-success" class="hidden text-center py-10 px-6 bg-energy-green/10 border border-energy-green/30 rounded-xl">
        <div class="w-12 h-12 mx-auto mb-3 rounded-full bg-energy-green/20 flex items-center justify-center">
          <svg class="w-6 h-6 text-energy-green" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/>
          </svg>
        </div>
        <p class="text-ink font-display font-bold text-lg mb-1">
          <span data-i18n-lang="fr">Message bien reçu.</span>
          <span data-i18n-lang="en">Message received.</span>
        </p>
        <p class="text-ink-subtle text-sm">
          <span data-i18n-lang="fr">Réponse sous 24h ouvrées sur l'email que vous avez indiqué.</span>
          <span data-i18n-lang="en">We'll reply within 1 business day at the email you provided.</span>
        </p>
      </div>

      <div id="contact-error" class="hidden mt-3 text-center py-3 px-4 bg-energy-red/10 border border-energy-red/30 rounded-lg text-sm">
        <p class="text-energy-red">
          <span data-i18n-lang="fr">L'envoi a échoué. Réessayez ou écrivez directement à energies@methode-ec2r.com.</span>
          <span data-i18n-lang="en">Sending failed. Try again or write directly to energies@methode-ec2r.com.</span>
        </p>
      </div>
    </div>

    <!-- Footer minimal -->
    <div class="mt-12 pt-6 border-t border-border-subtle text-center text-ink-disabled text-xs space-y-1">
      <p>© {new Date().getFullYear()} Méthode <EC2R /> · <EC2R /> Conseil</p>
      <div class="flex justify-center gap-4">
        <a href="/mentions-legales" class="hover:text-ink-faint transition-colors">
          <span data-i18n-lang="fr">Mentions légales</span>
          <span data-i18n-lang="en">Legal</span>
        </a>
        <a href="/politique-de-confidentialite" class="hover:text-ink-faint transition-colors">
          <span data-i18n-lang="fr">Confidentialité</span>
          <span data-i18n-lang="en">Privacy</span>
        </a>
      </div>
    </div>

  </div>
</div>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    // ── Budget snark button ──────────────────────────────────────────
    const btn = document.getElementById('budget-btn');
    if (btn) {
      const originalHTML = btn.innerHTML;
      btn.addEventListener('click', () => {
        const lang = document.documentElement.getAttribute('data-lang') || 'fr';
        const msg = lang === 'en' ? 'Too bad 😏' : 'Dommage 😏';
        btn.innerHTML = `<span class="text-amber-400 font-bold">${msg}</span>`;
        btn.disabled = true;
        btn.classList.add('border-amber-400/30');
        setTimeout(() => {
          btn.innerHTML = originalHTML;
          btn.disabled = false;
          btn.classList.remove('border-amber-400/30');
        }, 5000);
      });
    }

    // ── Formulaire contact AJAX (FormSubmit) ────────────────────────
    const form = document.getElementById('contact-form') as HTMLFormElement | null;
    const submitBtn = document.getElementById('contact-submit-btn') as HTMLButtonElement | null;
    const successBox = document.getElementById('contact-success');
    const errorBox = document.getElementById('contact-error');
    if (!form || !submitBtn) return;

    const idleSpans = submitBtn.querySelectorAll<HTMLElement>('.contact-btn-idle');
    const loadingSpans = submitBtn.querySelectorAll<HTMLElement>('.contact-btn-loading');

    function setLoading(loading: boolean) {
      submitBtn.disabled = loading;
      idleSpans.forEach(s => s.classList.toggle('hidden', loading));
      loadingSpans.forEach(s => s.classList.toggle('hidden', !loading));
    }

    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      errorBox?.classList.add('hidden');
      // Honeypot : si rempli, on simule un succès silencieux (anti-bot)
      const honey = (form.elements.namedItem('_honey') as HTMLInputElement | null)?.value;
      if (honey) {
        form.classList.add('hidden');
        successBox?.classList.remove('hidden');
        return;
      }
      setLoading(true);
      try {
        const res = await fetch(form.action, {
          method: 'POST',
          body: new FormData(form),
          headers: { Accept: 'application/json' },
        });
        const data = await res.json().catch(() => ({}));
        const ok = res.ok && (data.success === 'true' || data.success === true || /sent|inbox|activate/i.test(String(data.message || '')));
        if (ok) {
          form.classList.add('hidden');
          successBox?.classList.remove('hidden');
          successBox?.scrollIntoView({ behavior: 'smooth', block: 'center' });
        } else {
          errorBox?.classList.remove('hidden');
          setLoading(false);
        }
      } catch {
        errorBox?.classList.remove('hidden');
        setLoading(false);
      }
    });
  });
</script>
