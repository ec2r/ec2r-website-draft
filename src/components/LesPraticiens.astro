---
/**
 * Univers 5 : "Les praticiens" — VERSION V3 COMPLÈTE
 * Merge de : LesPraticiens.astro (v2) + Equipe.astro (v1)
 * 
 * Structure :
 * 1. Titre + baseline différenciation
 * 2. Founders (2 grandes cartes avec bios complètes)
 * 3. Équipe praticiens (4 cartes moyennes)
 * 4. Teaser "Sur le terrain" (photos séminaires à venir)
 */
interface Props { fr: any; en: any; }
const { fr, en } = Astro.props;

// Founders (données fixes — pas traduites)
const founders = [
  { name: 'Stéphane', namePlus: 'FLAHAUT', initials: 'SF', linkedin: 'https://www.linkedin.com/in/stephane-flahaut' },
  { name: 'Luc', namePlus: 'LÉTOFFÉ', initials: 'LL', linkedin: '' },
];

// Praticiens (données fixes)
const praticiens = [
  {
    name: 'Jean-François Morin',
    initials: 'JFM',
    photo: '',
    titleFr: 'Associé méthode EC2R',
    titleEn: 'EC2R Method Partner',
    subtitleFr: 'Cofondateur EC2R Conseil',
    subtitleEn: 'Co-founder EC2R Conseil',
    linkedin: '',
  },
  {
    name: 'Arnaud Bochurberg',
    initials: 'AB',
    photo: '/photos/equipe/arnaud-bochurberg.webp',
    titleFr: 'Associé EC2R Conseil — Praticien et prescripteur',
    titleEn: 'EC2R Conseil Partner — Practitioner & prescriber',
    subtitleFr: 'Expert du profilage comportemental · Palmes académiques',
    subtitleEn: 'Behavioural profiling expert · Academic distinction',
    linkedin: '',
    bioFr: "Président du Groupe Alard. Professeur associé en Psycho-sociologie de la Communication à l'Université Gustave Eiffel depuis 28 ans. Conférencier, formateur et coach de dirigeants. Auteur de « La Communication Solutionnelle » et « Rendre Possible l'Impossible ». Officier des Palmes Académiques. 1750+ leaders accompagnés.",
    bioEn: "President of Groupe Alard. Associate Professor in Psycho-sociology of Communication at Gustave Eiffel University for 28 years. Speaker, trainer and executive coach. Author of « La Communication Solutionnelle » and « Rendre Possible l'Impossible ». Officer of the Palmes Académiques. 1750+ leaders supported.",
  },
  {
    name: 'Jean Zuccarelli',
    initials: 'JZ',
    photo: '',
    titleFr: 'Associé EC2R Conseil',
    titleEn: 'EC2R Conseil Partner',
    subtitleFr: '',
    subtitleEn: '',
    linkedin: '',
  },
  {
    name: 'Marie-Emilia Garcia',
    initials: 'MEG',
    photo: '',
    titleFr: 'Facilitatrice EC2R Conseil',
    titleEn: 'EC2R Conseil Facilitator',
    subtitleFr: 'Logistique · Équipe · Déploiement · Pédagogie',
    subtitleEn: 'Logistics · Teams · Deployment · Pedagogy',
    linkedin: '',
  },
];

// Teaser séminaires
const seminairePlaceholders = [
  { labelFr: 'Séminaire Laforêt 2024', labelEn: 'Laforêt seminar 2024' },
  { labelFr: 'Diagnostic collectif IRM+', labelEn: 'Collective IRM+ diagnosis' },
  { labelFr: 'Passage à l\'acte terrain', labelEn: 'Field action deployment' },
  { labelFr: 'Co-design en session', labelEn: 'Co-design in session' },
];
---

<div class="min-h-full bg-navy-950 relative">
  <div class="absolute inset-0 bg-gradient-to-bl from-navy-900/30 via-navy-950 to-navy-950"></div>

  <div class="relative z-10 max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-10 lg:py-14 space-y-12">

    <!-- ════════════════════════════════════════════════════════════════════════ -->
    <!-- 1. TITRE : PRATICIENS + PRESCRIPTEURS -->
    <!-- ════════════════════════════════════════════════════════════════════════ -->
    <div>
      <h2 class="text-2xl md:text-3xl lg:text-4xl font-display font-extrabold text-white mb-3">
        <span data-i18n-lang="fr">Praticiens certifiés qui vous aident à passer à l'acte</span>
        <span data-i18n-lang="en">Certified practitioners who help you take action</span>
      </h2>
      <p class="text-white/40 text-sm mb-3 italic">
        <span data-i18n-lang="fr">Pas des consultants interchangeables, pas des associés ou des seniors et ensuite des juniors.</span>
        <span data-i18n-lang="en">Not interchangeable consultants, not partners or seniors then juniors.</span>
      </p>
      <p class="text-white/50 text-sm leading-relaxed max-w-3xl">
        <span data-i18n-lang="fr">Des professionnels et des humains qui ont expérimenté, qui croient à la différenciation de la méthode, qui savent dans chaque étape comment vous la faire vivre et traduire dans votre quotidien. La méthode à votre service, pas l'inverse.</span>
        <span data-i18n-lang="en">Professionals and humans who have experienced it, who believe in the method's differentiation, who know at every stage how to bring it to life and translate it into your daily reality. The method at your service, not the other way around.</span>
      </p>
    </div>

    <!-- ════════════════════════════════════════════════════════════════════════ -->
    <!-- 2. FOUNDERS (2 grandes cartes avec bios) -->
    <!-- ════════════════════════════════════════════════════════════════════════ -->
    <div class="grid md:grid-cols-2 gap-6">
      {founders.map((member, i) => (
        <div class="bg-white/[0.02] border border-white/[0.06] rounded-2xl overflow-hidden hover:border-white/15 transition-all group h-full">
          <!-- Photo placeholder avec plus accent -->
          <div class="aspect-[16/10] bg-gradient-to-br from-navy-900 via-navy-950 to-navy-900 
                      relative flex items-center justify-center overflow-hidden">
            <div class="absolute inset-0 opacity-[0.03]">
              <div class="absolute top-1/4 left-1/4 w-40 h-40 rounded-full border border-white"></div>
              <div class="absolute bottom-1/4 right-1/4 w-32 h-32 rounded-full border border-white"></div>
            </div>
            <div class="text-center relative z-10">
              <div class="w-24 h-24 rounded-full bg-white/[0.08] border border-white/10 mx-auto mb-3 
                          flex items-center justify-center backdrop-blur-sm
                          group-hover:border-energy-green/30 transition-colors duration-500">
                <span class="text-white/50 text-2xl font-display font-bold group-hover:text-energy-green/70 transition-colors">
                  {member.initials}
                </span>
              </div>
              <p class="text-white/25 text-xs tracking-wider uppercase">
                <span data-i18n-lang="fr">Portrait à venir</span>
                <span data-i18n-lang="en">Portrait coming soon</span>
              </p>
            </div>
          </div>

          <!-- Contenu carte -->
          <div class="p-6">
            <h3 class="font-display font-bold text-xl text-white mb-2 flex items-center gap-2">
              {member.name}<span class="plus-accent">+</span> {member.namePlus}
              {member.linkedin && (
                <a href={member.linkedin} target="_blank" rel="noopener" 
                   class="text-white/20 hover:text-energy-green text-xs transition-colors ml-auto">
                  <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
                    <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
                  </svg>
                </a>
              )}
            </h3>
            <p class="text-energy-green font-semibold text-sm mb-4">
              <span data-i18n-lang="fr">{fr.equipe?.founders?.[i]?.role || 'Co-fondateur méthode EC2R'}</span>
              <span data-i18n-lang="en">{en.equipe?.founders?.[i]?.role || 'Co-founder EC2R method'}</span>
            </p>
            <p class="text-white/60 text-sm leading-relaxed">
              <span data-i18n-lang="fr">{fr.equipe?.founders?.[i]?.bio || ''}</span>
              <span data-i18n-lang="en">{en.equipe?.founders?.[i]?.bio || ''}</span>
            </p>
          </div>
        </div>
      ))}
    </div>

    <!-- ════════════════════════════════════════════════════════════════════════ -->
    <!-- 3. PRATICIENS (grille 4 cartes) -->
    <!-- ════════════════════════════════════════════════════════════════════════ -->
    <div>
      <h3 class="text-lg font-display font-bold text-white/70 mb-4 uppercase tracking-wider text-xs">
        <span data-i18n-lang="fr">Praticiens & Facilitateurs</span>
        <span data-i18n-lang="en">Practitioners & Facilitators</span>
      </h3>
      <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-4">
        {praticiens.map((member, i) => (
          <div class="bg-white/[0.03] border border-white/[0.08] rounded-xl p-5 hover:border-white/15 transition-all group h-full flex flex-col">
            <!-- Photo ou initiales -->
            <div class="flex items-start gap-3 mb-4">
              {member.photo ? (
                <img src={member.photo} alt={member.name} 
                     class="w-14 h-14 rounded-xl object-cover border-2 border-white/10 group-hover:border-energy-green/30 transition-colors" 
                     loading="lazy" />
              ) : (
                <div class="w-14 h-14 rounded-xl bg-white/10 flex items-center justify-center text-white/40 font-bold text-lg border-2 border-white/10 group-hover:border-energy-green/30 transition-colors">
                  {member.initials}
                </div>
              )}
              <div class="flex-1 min-w-0">
                <h4 class="text-white font-display font-bold text-sm group-hover:text-energy-green transition-colors leading-tight">
                  {member.name}
                </h4>
                {member.linkedin && (
                  <a href={member.linkedin} target="_blank" rel="noopener" 
                     class="text-white/20 hover:text-white/50 text-[10px] transition-colors">
                    LinkedIn →
                  </a>
                )}
              </div>
            </div>

            <div class="flex-1 space-y-2">
              <p class="text-white/60 text-xs leading-snug">
                <span data-i18n-lang="fr">{member.titleFr}</span>
                <span data-i18n-lang="en">{member.titleEn}</span>
              </p>
              {member.subtitleFr && (
                <p class="text-white/30 text-[11px] leading-snug">
                  <span data-i18n-lang="fr">{member.subtitleFr}</span>
                  <span data-i18n-lang="en">{member.subtitleEn}</span>
                </p>
              )}
              {member.bioFr && (
                <p class="text-white/40 text-[11px] leading-relaxed pt-2 border-t border-white/5">
                  <span data-i18n-lang="fr">{member.bioFr}</span>
                  <span data-i18n-lang="en">{member.bioEn}</span>
                </p>
              )}
            </div>
          </div>
        ))}
      </div>
    </div>

    <!-- ════════════════════════════════════════════════════════════════════════ -->
    <!-- 4. PRESCRIPTEURS : Ils l'ont vécu ou ils veulent nous recommander -->
    <!-- ════════════════════════════════════════════════════════════════════════ -->
    <div>
      <h3 class="text-lg font-display font-bold text-white/70 mb-4 uppercase tracking-wider text-xs">
        <span data-i18n-lang="fr">Prescripteurs</span>
        <span data-i18n-lang="en">Prescribers</span>
      </h3>
      <div class="bg-white/[0.02] border border-white/[0.06] rounded-xl p-8 text-center">
        <p class="text-white/50 text-sm leading-relaxed max-w-2xl mx-auto mb-4">
          <span data-i18n-lang="fr">Ils l'ont vécu ou ils veulent nous recommander</span>
          <span data-i18n-lang="en">They experienced it or they want to recommend us</span>
        </p>
        <p class="text-white/30 text-xs italic">
          <span data-i18n-lang="fr">Section en construction</span>
          <span data-i18n-lang="en">Under construction</span>
        </p>
      </div>
    </div>

    <!-- ════════════════════════════════════════════════════════════════════════ -->
    <!-- 5. LIEN LINKEDIN EC2R -->
    <!-- ════════════════════════════════════════════════════════════════════════ -->
    <div class="text-center">
      <a href="https://www.linkedin.com/company/ec2r-conseil" target="_blank" rel="noopener"
         class="inline-flex items-center gap-2 bg-white/5 hover:bg-white/10 border border-white/10 hover:border-white/20 
                text-white text-sm font-semibold px-6 py-3 rounded-lg transition-all group">
        <svg class="w-5 h-5 text-white/70 group-hover:text-energy-green transition-colors" fill="currentColor" viewBox="0 0 24 24">
          <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
        </svg>
        <span data-i18n-lang="fr">Suivre EC²R sur LinkedIn</span>
        <span data-i18n-lang="en">Follow EC²R on LinkedIn</span>
      </a>
    </div>

  </div>
</div>
