---
interface Props { fr: any; en: any; }
const { fr, en } = Astro.props;

const parcoursIcons = [
  `<svg class="w-6 h-6 text-energy-green" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M18 18.72a9.094 9.094 0 003.741-.479 3 3 0 00-4.682-2.72m.94 3.198l.001.031c0 .225-.012.447-.037.666A11.944 11.944 0 0112 21c-2.17 0-4.207-.576-5.963-1.584A6.062 6.062 0 016 18.719m12 0a5.971 5.971 0 00-.941-3.197m0 0A5.995 5.995 0 0012 12.75a5.995 5.995 0 00-5.058 2.772m0 0a3 3 0 00-4.681 2.72 8.986 8.986 0 003.74.477m.94-3.197a5.971 5.971 0 00-.94 3.197M15 6.75a3 3 0 11-6 0 3 3 0 016 0zm6 3a2.25 2.25 0 11-4.5 0 2.25 2.25 0 014.5 0zm-13.5 0a2.25 2.25 0 11-4.5 0 2.25 2.25 0 014.5 0z" /></svg>`,
  `<svg class="w-6 h-6 text-energy-green" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15.75 6a3.75 3.75 0 11-7.5 0 3.75 3.75 0 017.5 0zM4.501 20.118a7.5 7.5 0 0114.998 0A17.933 17.933 0 0112 21.75c-2.676 0-5.216-.584-7.499-1.632z" /></svg>`,
  `<svg class="w-6 h-6 text-navy-900" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9.813 15.904L9 18.75l-.813-2.846a4.5 4.5 0 00-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 003.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 003.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 00-3.09 3.09zM18.259 8.715L18 9.75l-.259-1.035a3.375 3.375 0 00-2.455-2.456L14.25 6l1.036-.259a3.375 3.375 0 002.455-2.456L18 2.25l.259 1.035a3.375 3.375 0 002.455 2.456L21.75 6l-1.036.259a3.375 3.375 0 00-2.455 2.456z" /></svg>`,
];

const abymeColors = ['bg-energy-red/10 text-energy-red', 'bg-energy-yellow/10 text-energy-yellow', 'bg-energy-green/10 text-energy-green', 'bg-energy-dark/10 text-energy-dark'];
---

<section id="protocole" class="py-24 lg:py-32 bg-white">
  <div class="max-w-7xl mx-auto px-6 lg:px-8">

    <div class="max-w-3xl mb-16 reveal">
      <p class="section-label" data-i18n-fr={fr.label} data-i18n-en={en.label}>{fr.label}</p>
      <h2 class="section-title">
        <span data-i18n-fr={fr.title1} data-i18n-en={en.title1}>{fr.title1}</span><br/>
        <span data-i18n-fr={fr.title2} data-i18n-en={en.title2}>{fr.title2}</span> <span class="energy-gradient-text">→</span>
      </h2>
      <p class="section-text" data-i18n-fr={fr.intro} data-i18n-en={en.intro}>{fr.intro}</p>
    </div>

    <!-- IRM : 5 étapes -->
    <div class="mb-16 reveal">
      <div class="bg-navy-950 rounded-2xl p-8 md:p-12 text-white">
        <h3 class="font-display font-bold text-2xl mb-2"
            data-i18n-fr={fr.irmTitle} data-i18n-en={en.irmTitle}>{fr.irmTitle}</h3>
        <p class="text-white/50 text-sm mb-8"
           data-i18n-fr={fr.irmSub} data-i18n-en={en.irmSub}>{fr.irmSub}</p>
        <div class="flex flex-col md:flex-row items-start gap-4">
          {fr.irmSteps.map((step: any, i: number) => (
            <>
              <div class="flex-1 text-center">
                <div class="w-10 h-10 rounded-full bg-energy-dark/30 text-energy-green flex items-center justify-center mx-auto mb-3 text-sm font-bold">
                  {i + 1}
                </div>
                <p class="font-display font-semibold text-white text-sm mb-1"
                   data-i18n-fr={step.title} data-i18n-en={en.irmSteps[i].title}>{step.title}</p>
                <p class="text-white/40 text-xs"
                   data-i18n-fr={step.text} data-i18n-en={en.irmSteps[i].text}>{step.text}</p>
              </div>
              {i < fr.irmSteps.length - 1 && (
                <div class="hidden md:flex items-center text-energy-green/40 mt-8">
                  <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
                  </svg>
                </div>
              )}
            </>
          ))}
        </div>
      </div>
    </div>

    <!-- 3 parcours -->
    <div class="grid md:grid-cols-3 gap-6 mb-20">
      {fr.parcours.map((p: any, i: number) => (
        <div class={`reveal reveal-delay-${i+1}`}>
          <div class={`${i < 2 ? 'bg-navy-950 text-white' : 'bg-slate-50 text-navy-950 border border-slate-200'} rounded-2xl p-8 h-full relative overflow-hidden group hover:shadow-2xl hover:shadow-navy-900/30 transition-all duration-500`}>
            {i === 2 && (
              <span class="absolute top-4 right-4 text-xs text-slate-400 bg-slate-100 px-2 py-0.5 rounded-full">accès libre</span>
            )}
            <div class={`absolute top-0 left-0 right-0 h-1 ${i === 0 ? 'bg-gradient-to-r from-energy-red via-energy-yellow to-energy-green' : i === 1 ? 'bg-gradient-to-r from-energy-green via-energy-yellow to-energy-red' : 'bg-energy-green'}`}></div>
            <div class={`w-12 h-12 ${i < 2 ? 'bg-energy-dark/20' : 'bg-navy-950/[0.06]'} rounded-xl flex items-center justify-center mb-6`}
                 set:html={parcoursIcons[i]}></div>
            <h3 class="font-display font-bold text-xl mb-3"
                data-i18n-fr={p.title} data-i18n-en={en.parcours[i].title}>{p.title}</h3>
            <p class={`${i < 2 ? 'text-white/50' : 'text-slate-600'} text-sm leading-relaxed mb-6`}
               data-i18n-fr={p.text} data-i18n-en={en.parcours[i].text}>{p.text}</p>
            <div class={`flex flex-wrap items-center gap-2 ${i < 2 ? 'text-energy-green/70' : 'text-energy-dark'} text-xs font-medium`}>
              {p.steps.map((step: string, j: number) => (
                <>
                  <span class={`px-2 py-1 rounded ${i < 2 ? 'bg-white/5' : 'bg-navy-950/[0.06]'}`}
                        data-i18n-fr={step} data-i18n-en={en.parcours[i].steps[j]}>{step}</span>
                  {j < p.steps.length - 1 && (
                    <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
                  )}
                </>
              ))}
            </div>
          </div>
        </div>
      ))}
    </div>

    <!-- Mise en abyme -->
    <div class="reveal">
      <div class="bg-slate-50 rounded-2xl border border-slate-200 overflow-hidden">
        <div class="grid lg:grid-cols-2">
          <div class="p-8 md:p-12 lg:border-r border-slate-200">
            <p class="text-xs text-energy-dark uppercase tracking-wider font-semibold mb-4"
               data-i18n-fr={fr.abyme.label} data-i18n-en={en.abyme.label}>{fr.abyme.label}</p>
            <h3 class="font-display font-bold text-2xl text-navy-950 mb-4"
                data-i18n-fr={fr.abyme.title} data-i18n-en={en.abyme.title}>{fr.abyme.title}</h3>
            <p class="text-slate-600 leading-relaxed mb-6"
               data-i18n-fr={fr.abyme.text1} data-i18n-en={en.abyme.text1}>{fr.abyme.text1}</p>
            <p class="text-slate-500 text-sm leading-relaxed"
               data-i18n-fr={fr.abyme.text2} data-i18n-en={en.abyme.text2}>{fr.abyme.text2}</p>
          </div>
          <div class="p-8 md:p-12 bg-white">
            <div class="space-y-6">
              {fr.abyme.steps.map((step: any, i: number) => (
                <div class="flex items-start gap-4">
                  <div class={`w-8 h-8 rounded-lg ${abymeColors[i].split(' ')[0]} flex items-center justify-center flex-shrink-0 mt-0.5`}>
                    <span class={`${abymeColors[i].split(' ')[1]} text-xs font-bold`}>0{i+1}</span>
                  </div>
                  <div>
                    <h4 class="font-display font-semibold text-navy-950 mb-1"
                        data-i18n-fr={step.title} data-i18n-en={en.abyme.steps[i].title}>{step.title}</h4>
                    <p class="text-slate-500 text-sm"
                       data-i18n-fr={step.text} data-i18n-en={en.abyme.steps[i].text}>{step.text}</p>
                  </div>
                </div>
              ))}
            </div>
          </div>
        </div>
      </div>
    </div>

  </div>
</section>
