---
/**
 * Univers 3 : "Ils l'ont vécu" — VERSION V3 COMPLÈTE
 * Merge de : Temoignages.astro + Preuves.astro + Chiffres.astro (début)
 * 
 * Structure :
 * 1. Section Chiffres (stats animées)
 * 2. Mur de témoignages complet (736, filtres secteur/impact/tags)
 * 3. Vidéos YouTube
 * 4. Musée / Timeline
 * 5. LinkedIn cards
 */
import type { Lang } from '../i18n/translations';
interface Props {
  lang: Lang;
  fr?: any;
  en?: any;
}
const { lang, fr, en } = Astro.props;
const t = lang === 'fr' ? fr : en;

import { testimonials, sectorLabels, impactLabels, tagTranslations, allTags, allSectors, type Sector, type ImpactLevel } from '../data/testimonials';
import { fieldMoments, fieldMomentColors, fieldMomentLabels } from '../data/onTerrain';

// IDs YouTube fixes
const videoIds = ["jhq47z0GanA", "e3KEgfNuNzQ"];

// Chiffres
const statsValues = [5, 200, 18, 250];

// Tag frequency for word cloud sizing
const tagFreq: Record<string, number> = {};
testimonials.forEach(t => t.tags.forEach(tag => { tagFreq[tag] = (tagFreq[tag] || 0) + 1; }));
const topTags = Object.entries(tagFreq).sort((a, b) => b[1] - a[1]).slice(0, 25);

// Tri anti-chronologique + anti-adjacence (pas deux fois le même name à la suite).
// Évite "Florence Beaucousin 7 fois d'affilée" tout en gardant les récents en haut.
const sortedByYear = [...testimonials].sort((a, b) => b.year - a.year);
const orderedTestimonials: typeof testimonials = [];
const remaining = [...sortedByYear];
while (remaining.length > 0) {
  const lastName = orderedTestimonials.length > 0 ? orderedTestimonials[orderedTestimonials.length - 1].name : null;
  let pickIdx = remaining.findIndex(t => t.name !== lastName);
  if (pickIdx === -1) pickIdx = 0; // tous restants = même name → on prend
  orderedTestimonials.push(remaining.splice(pickIdx, 1)[0]);
}

// Sector colors
const sectorColors: Record<Sector, string> = {
  'expertise-comptable': 'bg-blue-50 text-blue-700 border-blue-200',
  'immobilier':          'bg-green-50 text-green-700 border-green-200',
  'assurance-protection':'bg-amber-50 text-amber-700 border-amber-200',
  'industrie':           'bg-surface-raised text-ink-muted border-border-strong',
  'hospitality':         'bg-purple-50 text-purple-700 border-purple-200',
  'conseil-rh':          'bg-rose-50 text-rose-700 border-rose-200',
  'direction-generale':  'bg-surface-inverse/5 text-ink border-ink/20',
};

const impactBadge: Record<ImpactLevel, string> = {
  'institutionnel': 'bg-yellow-400/20 text-yellow-800',
  'direction':      'bg-accent-strong/10 text-accent-strong',
  'operationnel':   'bg-surface-raised text-ink-muted',
  'prescripteur':   'bg-blue-100 text-blue-700',
};

// Timeline colors (Preuves)
const timelineColors = [
  'bg-red-500', 'bg-yellow-400', 'bg-amber-300', 'bg-green-300', 'bg-green-600', 'bg-gradient-to-r from-accent-strong to-accent',
];
const timelineTextColors = [
  'text-red-500', 'text-yellow-500', 'text-amber-500', 'text-green-500', 'text-green-700', 'text-green-500',
];

// Word cloud data (Preuves)
const wordsData: Record<string, { large: string[]; medium: string[]; small: string[] }> = {
  fr: {
    large: ['mobilisation', "passage à l'acte", 'collectif vivant', 'méthode vivante', 'résultats concrets'],
    medium: ['chirurgical', 'engagement réel', 'IRM organisationnel', 'co-design', 'énergie collective', 'transformation durable', 'leadership', 'comportement', 'diagnostic', 'terrain'],
    small: ['protocole', 'réaliste', 'ancrage', 'mesurable', 'humain', 'continu', 'praticien', 'boucle', 'situation', 'progrès', 'vivant', 'guidage'],
  },
  en: {
    large: ['mobilisation', 'moving to action', 'living collective', 'living method', 'concrete results'],
    medium: ['surgical', 'real engagement', 'organisational MRI', 'co-design', 'collective energy', 'lasting transformation', 'leadership', 'behaviour', 'diagnosis', 'field'],
    small: ['protocol', 'realistic', 'grounding', 'measurable', 'human', 'continuous', 'practitioner', 'loop', 'situation', 'progress', 'living', 'guidance'],
  },
};
---

<div class="min-h-full bg-surface relative">
  <div class="absolute inset-0 bg-gradient-to-tr from-surface via-surface-alt/30 to-surface"></div>

  <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-10 lg:py-14 space-y-16">

    <!-- Indicateur scroll : descendre vers le mur de témoignages -->
    <div class="text-center -mb-8">
      <a href="#temoignages-wall" class="inline-flex items-center gap-2 text-accent text-xs font-semibold uppercase tracking-wider hover:text-accent/80 transition-colors animate-bounce" aria-label={lang === 'fr' ? 'Voir les témoignages' : 'See testimonials'}>
        {lang === 'fr' ? 'Descendre vers les témoignages' : 'Scroll to testimonials'}
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3" /></svg>
      </a>
    </div>

    <!-- ════════════════════════════════════════════════════════════════════════ -->
    <!-- 1. NUAGE DE MOTS-CLÉS + BANNIÈRE "CE SITE EST VIVANT" — EN HAUT -->
    <!--    (remplace l'ancienne section "En chiffres" — req 6gZ0QrEG/0sqfNTUS) -->
    <!-- ════════════════════════════════════════════════════════════════════════ -->
    <section class="grid lg:grid-cols-3 gap-6">
      <!-- Word cloud dynamique (2/3) -->
      <div class="lg:col-span-2 bg-surface-alt border border-border-subtle rounded-xl p-6">
        <h3 class="font-display font-semibold text-ink text-lg mb-4">
          {lang === 'fr' ? (
            <Fragment>Ce que retiennent ceux qui ont vécu la <strong class="text-accent">Méthode</strong></Fragment>
          ) : (
            <Fragment>What those who lived the <strong class="text-accent">Method</strong> retain</Fragment>
          )}
        </h3>
        <div id="word-cloud-top" class="relative h-[160px] md:h-[200px] overflow-hidden"></div>
        <p class="text-ink-faint text-xs mt-3 italic">
          {lang === 'fr' ? 'Mots-clés en temps réel — extraits des témoignages spontanés' : 'Real-time keywords — extracted from spontaneous testimonials'}
        </p>
      </div>
      <!-- Bannière "Ce site est vivant" — clic pour développer -->
      <details class="bg-energy-green/[0.04] border border-accent/15 rounded-xl p-5 md:p-6 group flex flex-col justify-center">
        <summary class="cursor-pointer list-none">
          <div class="flex items-center justify-between mb-3">
            <h3 class="text-xl md:text-2xl font-display font-extrabold text-accent leading-tight">
              {lang === 'fr' ? 'Ce site est vivant' : 'This site is alive'}
            </h3>
            <svg class="w-5 h-5 text-accent/70 group-open:rotate-180 transition-transform shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
            </svg>
          </div>
          <p class="text-ink-muted text-base leading-snug">
            {lang === 'fr' ? (
              <Fragment>Pourquoi ? <span class="text-accent/80 font-semibold">Cliquez pour lire.</span></Fragment>
            ) : (
              <Fragment>Why? <span class="text-accent/80 font-semibold">Click to read.</span></Fragment>
            )}
          </p>
        </summary>
        <p class="text-ink-subtle text-sm leading-relaxed mt-4 pt-4 border-t border-accent/10">
          {lang === 'fr' ? (
            <Fragment>Il documente sa propre construction et notre dynamique de mobilisation. Pas un résultat figé — l'illustration du processus vivant. Nous avons utilisé la puissance<span class="plus-accent">+</span> dirigée de l'IA pour partir du réel et passer d'un savoir-faire artisanal à un mode augmenté. On essaye, on expérimente, on traduit, on améliore.</Fragment>
          ) : (
            <Fragment>It documents its own construction and our mobilization dynamics. Not a frozen result — the illustration of the living process. We used the directed<span class="plus-accent">+</span> power of AI to start from reality and move from artisanal know-how to augmented mode.</Fragment>
          )}
        </p>
      </details>
    </section>

    <!-- ════════════════════════════════════════════════════════════════════════ -->
    <!-- 2. MUR DE TÉMOIGNAGES COMPLET -->
    <!-- ════════════════════════════════════════════════════════════════════════ -->
    <section>
      <div class="mb-8">
        <h2 class="text-2xl md:text-3xl lg:text-4xl font-display font-extrabold text-ink mb-3">
          {lang === 'fr' ? (
            <Fragment>Ils l'ont vécu, la <strong class="text-accent">Méthode</strong></Fragment>
          ) : (
            <Fragment>They lived the <strong class="text-accent">Method</strong></Fragment>
          )}
        </h2>
        <p class="text-base text-ink-subtle leading-relaxed max-w-3xl mb-6">
          {lang === 'fr' ? (
            <Fragment>Pas de promesses marketing, des résultats concrets avec les mots de nos clients depuis l'origine. Pas de témoignages sollicités, pas de citations anonymisées — ce sont les mots publiés <strong>spontanément</strong> par des dirigeants, des managers de terrain, des leaders. Des données <span class="plus-accent">+</span> mesurables, des comportements <span class="plus-accent">+</span> observables, un impact déjà <span class="plus-accent">+</span> réel.</Fragment>
          ) : (
            <Fragment>No marketing promises, concrete results in our clients' own words from the start. No solicited testimonials, no anonymized quotes — words published <strong>spontaneously</strong> by executives, field managers, leaders. Measurable<span class="plus-accent">+</span> data, observable<span class="plus-accent">+</span> behaviours, already<span class="plus-accent">+</span> real impact.</Fragment>
          )}
        </p>

        <!-- Stats bar -->
        <div class="flex flex-wrap gap-6 mb-6">
          <div class="flex items-center gap-2">
            <span class="text-3xl font-display font-bold text-ink">{testimonials.length}</span>
            <span class="text-sm text-ink-subtle">
              {lang === 'fr' ? (
                <Fragment>témoignages<br/>vérifiables</Fragment>
              ) : (
                <Fragment>verifiable<br/>testimonials</Fragment>
              )}
            </span>
          </div>
          <div class="flex items-center gap-2">
            <span class="text-3xl font-display font-bold text-ink">{allSectors.length}</span>
            <span class="text-sm text-ink-subtle">
              {lang === 'fr' ? (
                <Fragment>secteurs<br/>d'activité</Fragment>
              ) : (
                <Fragment>sectors<br/>of activity</Fragment>
              )}
            </span>
          </div>
          <div class="flex items-center gap-2">
            <span class="text-3xl font-display font-bold text-accent">100%</span>
            <span class="text-sm text-ink-subtle">
              {lang === 'fr' ? (
                <Fragment>non sollicités<br/>publics sur LinkedIn</Fragment>
              ) : (
                <Fragment>unsolicited<br/>public on LinkedIn</Fragment>
              )}
            </span>
          </div>
        </div>
      </div>

      <!-- Tag cloud (clickable filters) -->
      <div class="mb-6" id="temoignages-tags">
        <div class="flex flex-wrap gap-2">
          <button class="tag-filter active px-3 py-2 rounded-full text-xs font-medium border transition-all duration-300 bg-accent/10 border-accent/30 text-accent" data-tag="all">
            {lang === 'fr' ? 'Tous' : 'All'}
          </button>
          {topTags.map(([tag, freq]) => (
            <button
              class="tag-filter px-3 py-2 rounded-full text-xs border transition-all duration-300 bg-surface-alt text-ink-subtle border-border-subtle hover:border-border-strong hover:text-ink-muted"
              data-tag={tag}
            >
              {lang === 'en' ? (tagTranslations[tag] || tag) : tag} <span class="text-[10px] text-ink-disabled ml-1">{freq}</span>
            </button>
          ))}
        </div>
      </div>

      <!-- Sector tabs (flex-wrap comme les tags ci-dessus, pas de scroll horizontal) -->
      <div class="mb-6" id="temoignages-sectors">
        <div class="flex flex-wrap gap-2">
          <button class="sector-tab active px-3 py-2 rounded-full text-xs font-medium border transition-all duration-300 bg-accent/10 border-accent/30 text-accent" data-sector="all">
            {lang === 'fr' ? 'Tous les secteurs' : 'All sectors'}
          </button>
          {allSectors.map(sector => {
            const count = testimonials.filter(t => t.sector === sector).length;
            return (
              <button
                class="sector-tab px-3 py-2 rounded-full text-xs border transition-all duration-300 bg-surface-alt text-ink-subtle border-border-subtle hover:border-border-strong hover:text-ink-muted"
                data-sector={sector}
              >
                {sectorLabels[sector][lang]}
                <span class="text-[10px] text-ink-disabled ml-1">{count}</span>
              </button>
            );
          })}
        </div>
      </div>

      <!-- THE WALL (masonry layout) -->
      <div id="temoignages-wall" class="columns-1 md:columns-2 lg:columns-3 gap-4 space-y-4">
        {orderedTestimonials.map((tm) => (
          <div
            class="temoignage-card break-inside-avoid bg-surface-alt rounded-xl p-5 border border-border-subtle
                   hover:border-border hover:shadow-lg hover:shadow-brand-anchor/5
                   transition-all duration-300"
            data-tags={JSON.stringify(tm.tags)}
            data-sector={tm.sector}
            data-impact={tm.impact}
          >
            <!-- Header: photo + name -->
            <div class="flex items-start gap-3 mb-3">
              {tm.linkedinUrl ? (
                <a href={tm.linkedinUrl} target="_blank" rel="noopener noreferrer"
                   class="flex-shrink-0 w-10 h-10 rounded-full bg-surface-raised border border-border-subtle flex items-center justify-center overflow-hidden hover:border-accent/40 transition-colors group"
                   title={lang === 'fr' ? `Voir le profil LinkedIn de ${tm.name}` : `View ${tm.name}'s LinkedIn profile`}>
                  {tm.photoUrl ? (
                    <img src={tm.photoUrl} alt={tm.name} class="w-full h-full object-cover rounded-full" loading="lazy" />
                  ) : (
                    <span class="text-ink-faint text-xs font-bold group-hover:text-accent transition-colors">
                      {tm.name.split(' ').map(w => w[0]).filter(c => c && c === c.toUpperCase()).slice(0, 2).join('')}
                    </span>
                  )}
                </a>
              ) : (
                <span class="flex-shrink-0 w-10 h-10 rounded-full bg-surface-raised border border-border-subtle flex items-center justify-center overflow-hidden">
                  {tm.photoUrl ? (
                    <img src={tm.photoUrl} alt={tm.name} class="w-full h-full object-cover rounded-full" loading="lazy" />
                  ) : (
                    <span class="text-ink-faint text-xs font-bold">
                      {tm.name.split(' ').map(w => w[0]).filter(c => c && c === c.toUpperCase()).slice(0, 2).join('')}
                    </span>
                  )}
                </span>
              )}
              <div class="min-w-0">
                {tm.linkedinUrl ? (
                  <a href={tm.linkedinUrl} target="_blank" rel="noopener noreferrer"
                     class="font-display font-semibold text-ink text-sm hover:text-accent transition-colors block truncate">
                    {tm.name}
                  </a>
                ) : (
                  <span class="font-display font-semibold text-ink text-sm block truncate">{tm.name}</span>
                )}
                <p class="text-ink-subtle text-xs leading-snug">{tm.title}</p>
                {tm.company && <p class="text-ink-faint text-xs">{tm.company}</p>}
              </div>
            </div>

            <!-- Badges -->
            <div class="flex flex-wrap gap-1.5 mb-3">
              <span class="inline-block text-[10px] font-semibold uppercase tracking-wider px-2 py-0.5 rounded-full bg-surface-raised text-ink-subtle border border-border-subtle">
                {sectorLabels[tm.sector][lang]}
              </span>
              <span class="inline-block text-[10px] font-medium px-2 py-0.5 rounded-full bg-surface-alt text-ink-faint">
                {impactLabels[tm.impact][lang]}
              </span>
            </div>

            <!-- Quote -->
            <blockquote class="text-ink-muted text-sm leading-relaxed italic mb-3">
              "{lang === 'fr' ? tm.quote : tm.quoteEn}"
            </blockquote>

            <!-- Footer: year + LinkedIn link -->
            <div class="flex items-center justify-between pt-3 border-t border-border-subtle">
              <span class="text-xs text-ink-faint">{tm.year}</span>
              <a href={tm.postUrl} target="_blank" rel="noopener noreferrer"
                 class="text-xs text-accent/70 hover:text-accent flex items-center gap-1 transition-colors"
                 title={lang === 'fr' ? 'Voir le post original sur LinkedIn' : 'See the original post on LinkedIn'}>
                <svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 24 24">
                  <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
                </svg>
                {lang === 'fr' ? 'Voir sur LinkedIn' : 'See on LinkedIn'}
              </a>
            </div>
          </div>
        ))}
      </div>

      <!-- Empty state -->
      <div id="temoignages-empty" class="hidden text-center py-16">
        <p class="text-ink-subtle text-lg">
          {lang === 'fr' ? 'Aucun témoignage pour ce filtre.' : 'No testimonials for this filter.'}
        </p>
        <button class="mt-4 text-accent text-sm font-medium hover:underline" id="temoignages-reset">
          {lang === 'fr' ? 'Voir tous les témoignages' : 'See all testimonials'}
        </button>
      </div>
    </section>

    <!-- ════════════════════════════════════════════════════════════════════════ -->
    <!-- 2bis. SUR LE TERRAIN — preuves d'activité (séminaires, keynotes) -->
    <!--       Pas de citations : documente la présence terrain, partenaires, dates. -->
    <!-- ════════════════════════════════════════════════════════════════════════ -->
    <section>
      <div class="flex items-center gap-3 mb-4">
        <div class="w-2 h-8 bg-gradient-to-b from-energy-green to-accent rounded-full"></div>
        <h3 class="font-display font-bold text-2xl text-ink">
          {lang === 'fr' ? 'Sur le terrain' : 'In the field'}
        </h3>
      </div>
      <p class="text-ink-subtle text-sm mb-6 ml-5 max-w-3xl">
        {lang === 'fr'
          ? "Séminaires, keynotes, ateliers de mobilisation. Des preuves d'activité publiques — partenaires nommés, dates, contextes. Les retours des participants se trouvent dans le mur ci-dessus."
          : 'Off-sites, keynotes, mobilization workshops. Public proof of activity — named partners, dates, contexts. Participant feedback is in the wall above.'}
      </p>

      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-4">
        {fieldMoments.map((m) => (
          <a
            href={m.postUrl}
            target="_blank"
            rel="noopener noreferrer"
            class="group block bg-surface-alt border border-border-subtle rounded-xl p-5
                   hover:border-accent/40 hover:shadow-lg hover:shadow-brand-anchor/5
                   transition-all duration-300"
          >
            <div class="flex items-center justify-between mb-3">
              <span class={`inline-block text-[10px] font-semibold uppercase tracking-wider px-2 py-0.5 rounded-full border ${fieldMomentColors[m.univers]}`}>
                {fieldMomentLabels[m.univers][lang]}
              </span>
              <time class="text-xs text-ink-faint font-medium" datetime={m.date}>
                {new Date(m.date).toLocaleDateString(lang === 'fr' ? 'fr-FR' : 'en-GB', { month: 'short', year: 'numeric' })}
              </time>
            </div>

            <h4 class="font-display font-semibold text-ink text-base leading-snug mb-2 group-hover:text-accent transition-colors">
              {lang === 'fr' ? m.titleFr : m.titleEn}
            </h4>

            <p class="text-ink-subtle text-sm mb-3">
              {lang === 'fr' ? m.subtitleFr : m.subtitleEn}
            </p>

            <p class="text-ink-faint text-xs leading-relaxed border-t border-border-subtle pt-3">
              <span class="font-medium text-ink-subtle">
                {lang === 'fr' ? 'Avec :' : 'With:'}
              </span>
              {' '}{m.partners}
            </p>

            <div class="flex items-center justify-between mt-3 text-xs text-ink-faint">
              <span class="flex items-center gap-3">
                <span class="flex items-center gap-1" title="Likes">
                  <svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 24 24"><path d="M12 21.35l-1.45-1.32C5.4 15.36 2 12.28 2 8.5 2 5.42 4.42 3 7.5 3c1.74 0 3.41.81 4.5 2.09C13.09 3.81 14.76 3 16.5 3 19.58 3 22 5.42 22 8.5c0 3.78-3.4 6.86-8.55 11.54L12 21.35z"/></svg>
                  {m.likes}
                </span>
                {m.comments > 0 && (
                  <span class="flex items-center gap-1" title="Commentaires">
                    <svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 24 24"><path d="M21.99 4c0-1.1-.89-2-1.99-2H4c-1.1 0-2 .9-2 2v12c0 1.1.9 2 2 2h14l4 4-.01-18z"/></svg>
                    {m.comments}
                  </span>
                )}
              </span>
              <span class="text-accent/70 group-hover:text-accent flex items-center gap-1 transition-colors">
                {lang === 'fr' ? 'Voir le post' : 'See post'}
                <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"/></svg>
              </span>
            </div>
          </a>
        ))}
      </div>
    </section>

    <!-- ════════════════════════════════════════════════════════════════════════ -->
    <!-- 3. VIDÉOS YOUTUBE -->
    <!-- ════════════════════════════════════════════════════════════════════════ -->
    <section>
      <div class="flex items-center gap-3 mb-4">
        <div class="w-2 h-8 bg-gradient-to-b from-energy-red to-energy-dark rounded-full"></div>
        <h3 class="font-display font-bold text-2xl text-ink">
          {t?.preuves?.trajTitle || (lang === 'fr' ? 'Trajectoires' : 'Trajectories')}
        </h3>
      </div>
      <p class="text-ink-subtle text-sm mb-2 ml-5">
        {t?.preuves?.trajSub || (lang === 'fr' ? 'Vidéos de témoignages réels' : 'Real testimonial videos')}
      </p>
      <p class="text-ink-faint text-xs mb-6 ml-5 italic">
        {lang === 'fr' ? (
          <Fragment>Vidéos de la trajectoire <strong class="text-accent not-italic">Méthode EC²R</strong> — pour l'avenir.</Fragment>
        ) : (
          <Fragment>Videos of the <strong class="text-accent not-italic">EC²R Method</strong> trajectory — for the future.</Fragment>
        )}
      </p>
      <div class="grid md:grid-cols-2 gap-6">
        {(t?.preuves?.videos || fr?.preuves?.videos || []).slice(0, 2).map((video: any, i: number) => (
          <div class="group">
            <div class="relative aspect-video bg-surface-alt rounded-xl overflow-hidden shadow-lg group-hover:shadow-xl transition-shadow duration-300">
              <iframe src={`https://www.youtube-nocookie.com/embed/${videoIds[i]}`}
                title={video.title} class="absolute inset-0 w-full h-full" frameborder="0"
                allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
                allowfullscreen loading="lazy"></iframe>
            </div>
            <div class="mt-4">
              <h4 class="font-display font-semibold text-ink">
                {video.title}
              </h4>
              <p class="text-sm text-accent font-medium">
                {video.subtitle}
              </p>
              <p class="text-sm text-ink-subtle mt-1">
                {video.description}
              </p>
            </div>
          </div>
        ))}
      </div>
    </section>

    <!-- (Section "Mur de contributions" + "Mise en abyme" supprimée — déduplication
         avec la section haut #word-cloud-top + bannière "Ce site est vivant"
         qui contient déjà ces 2 éléments — req Stéphane v1) -->

    <!-- ════════════════════════════════════════════════════════════════════════ -->
    <!-- 6. MUSÉE / TIMELINE -->
    <!-- ════════════════════════════════════════════════════════════════════════ -->
    {t?.preuves?.museeTimeline && (
      <section class="bg-surface-alt border border-border-subtle rounded-2xl p-8 md:p-10">
        <p class="text-xs text-ink-faint uppercase tracking-wider font-medium mb-3">
          {t.preuves?.museeLabel || (lang === 'fr' ? 'Musée' : 'Museum')}
        </p>
        <h4 class="font-display font-bold text-xl text-ink mb-3">
          {t.preuves?.museeTitle || (lang === 'fr' ? 'Trajectoire énergétique' : 'Energy trajectory')}
        </h4>
        <p class="text-ink-subtle leading-relaxed mb-8">
          {t.preuves?.museeSub || '2018 → 2025'}
        </p>

        <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-6 gap-4">
          {t.preuves.museeTimeline.map((item: any, i: number) => (
            <div class={`${i === 5 ? 'ring-1 ring-accent/30 bg-green-500/[0.03]' : ''} rounded-lg p-4`}>
              <div class={`h-1 ${timelineColors[i]} rounded-full mb-3`}></div>
              <p class={`font-display font-bold text-lg ${timelineTextColors[i]}`}>{item.year}</p>
              <p class="font-display font-semibold text-ink text-sm mb-1">
                {item.label}
              </p>
              <p class="text-ink-subtle text-xs leading-relaxed">
                {item.sub}
              </p>
            </div>
          ))}
        </div>
      </section>
    )}

  </div>
</div>

<script>
// ═══ FILTRES TÉMOIGNAGES ═══
document.addEventListener('DOMContentLoaded', () => {
  const wall = document.getElementById('temoignages-wall');
  const empty = document.getElementById('temoignages-empty');
  const cards = document.querySelectorAll<HTMLElement>('.temoignage-card');
  const tagBtns = document.querySelectorAll<HTMLButtonElement>('.tag-filter');
  const sectorBtns = document.querySelectorAll<HTMLButtonElement>('.sector-tab');
  const resetBtn = document.getElementById('temoignages-reset');

  let activeTag = 'all';
  let activeSector = 'all';

  function filterCards() {
    let visibleCount = 0;
    cards.forEach(card => {
      const tags: string[] = JSON.parse(card.dataset.tags || '[]');
      const sector = card.dataset.sector || '';

      const tagMatch = activeTag === 'all' || tags.includes(activeTag);
      const sectorMatch = activeSector === 'all' || sector === activeSector;

      if (tagMatch && sectorMatch) {
        card.style.display = '';
        visibleCount++;
      } else {
        card.style.display = 'none';
      }
    });

    if (wall) wall.style.display = visibleCount > 0 ? '' : 'none';
    if (empty) empty.style.display = visibleCount === 0 ? 'block' : 'none';
  }

  function setActiveTag(tag: string) {
    activeTag = tag;
    tagBtns.forEach(btn => {
      const isActive = btn.dataset.tag === tag;
      if (isActive) {
        btn.classList.add('bg-accent/10', 'border-accent/30', 'text-accent', 'active');
        btn.classList.remove('bg-surface-alt', 'text-ink-subtle', 'border-border-subtle');
      } else {
        btn.classList.remove('bg-accent/10', 'border-accent/30', 'text-accent', 'active');
        btn.classList.add('bg-surface-alt', 'text-ink-subtle', 'border-border-subtle');
      }
    });
    filterCards();
  }

  function setActiveSector(sector: string) {
    activeSector = sector;
    sectorBtns.forEach(btn => {
      const isActive = btn.dataset.sector === sector;
      if (isActive) {
        btn.classList.add('bg-accent/10', 'border-accent/30', 'text-accent', 'active');
        btn.classList.remove('bg-surface-alt', 'text-ink-subtle', 'border-border-subtle');
      } else {
        btn.classList.remove('bg-accent/10', 'border-accent/30', 'text-accent', 'active');
        btn.classList.add('bg-surface-alt', 'text-ink-subtle', 'border-border-subtle');
      }
    });
    filterCards();
  }

  tagBtns.forEach(btn => {
    btn.addEventListener('click', () => setActiveTag(btn.dataset.tag || 'all'));
  });

  sectorBtns.forEach(btn => {
    btn.addEventListener('click', () => setActiveSector(btn.dataset.sector || 'all'));
  });

  resetBtn?.addEventListener('click', () => {
    setActiveTag('all');
    setActiveSector('all');
  });
});

// ═══ COMPTEURS CHIFFRES ═══
const counters = document.querySelectorAll('.counter-value[data-target]');
const counterObserver = new IntersectionObserver((entries) => {
  entries.forEach(entry => {
    if (entry.isIntersecting) {
      const el = entry.target as HTMLElement;
      const target = parseInt(el.dataset.target || '0');
      const duration = 2000;
      const start = performance.now();
      const animate = (now: number) => {
        const elapsed = now - start;
        const progress = Math.min(elapsed / duration, 1);
        const eased = 1 - Math.pow(1 - progress, 3);
        el.textContent = Math.round(target * eased).toString();
        if (progress < 1) requestAnimationFrame(animate);
      };
      requestAnimationFrame(animate);
      counterObserver.unobserve(el);
    }
  });
}, { threshold: 0.5 });
counters.forEach(counter => counterObserver.observe(counter));

// ═══ WORD CLOUD DYNAMIQUE (en haut de section, id=word-cloud-top) ═══
(() => {
  const cloud = document.getElementById('word-cloud-top');
  if (!cloud) return;

  const wordsData: Record<string, { large: string[]; medium: string[]; small: string[] }> = {
    fr: {
      large: ['mobilisation', "passage à l'acte", 'collectif vivant', 'méthode vivante', 'résultats concrets'],
      medium: ['chirurgical', 'engagement réel', 'IRM organisationnel', 'co-design', 'énergie collective', 'transformation durable', 'leadership', 'comportement', 'diagnostic', 'terrain'],
      small: ['protocole', 'réaliste', 'ancrage', 'mesurable', 'humain', 'continu', 'praticien', 'boucle', 'situation', 'progrès', 'vivant', 'guidage'],
    },
    en: {
      large: ['mobilisation', 'moving to action', 'living collective', 'living method', 'concrete results'],
      medium: ['surgical', 'real engagement', 'organisational MRI', 'co-design', 'collective energy', 'lasting transformation', 'leadership', 'behaviour', 'diagnosis', 'field'],
      small: ['protocol', 'realistic', 'grounding', 'measurable', 'human', 'continuous', 'practitioner', 'loop', 'situation', 'progress', 'living', 'guidance'],
    },
  };

  const sizeClasses: Record<string, string> = {
    large: 'text-xl md:text-2xl font-bold text-ink',
    medium: 'text-sm md:text-base font-medium text-ink-muted',
    small: 'text-xs text-ink-faint',
  };

  const sizeOpacity: Record<string, number> = { large: 1, medium: 0.7, small: 0.4 };

  function render() {
    const lang = document.documentElement.getAttribute('data-lang') || 'fr';
    const words = wordsData[lang] || wordsData.fr;
    cloud!.innerHTML = '';

    const allWords = [
      ...words.large.map((w: string) => ({ text: w, size: 'large' })),
      ...words.medium.map((w: string) => ({ text: w, size: 'medium' })),
      ...words.small.map((w: string) => ({ text: w, size: 'small' })),
    ];

    // Shuffle
    for (let i = allWords.length - 1; i > 0; i--) {
      const j = Math.floor(Math.random() * (i + 1));
      [allWords[i], allWords[j]] = [allWords[j], allWords[i]];
    }

    // Cleanup ancienne anim si re-render (changement de langue)
    cancelAnimationFrame((cloud as any)._raf || 0);

    type Particle = { el: HTMLSpanElement; x: number; y: number; vx: number; vy: number; maxX: number; maxY: number };
    const particles: Particle[] = [];

    const containerW = cloud!.clientWidth || 1;
    const containerH = cloud!.clientHeight || 1;

    allWords.forEach((word, i) => {
      const span = document.createElement('span');
      span.textContent = word.text;
      span.className = `absolute ${sizeClasses[word.size]} opacity-0 whitespace-nowrap`;
      span.style.transition = 'opacity 1.2s ease';
      span.style.willChange = 'transform';
      cloud!.appendChild(span);

      // Bornes dynamiques par mot : prend en compte la largeur du mot pour éviter le crop
      const wPct = (span.offsetWidth / containerW) * 100;
      const hPct = (span.offsetHeight / containerH) * 100;
      const maxX = Math.max(2, 100 - wPct - 2);
      const maxY = Math.max(2, 100 - hPct - 2);

      const x = 2 + Math.random() * Math.max(0, maxX - 2);
      const y = 2 + Math.random() * Math.max(0, maxY - 2);
      span.style.left = `${x}%`;
      span.style.top = `${y}%`;

      // Fade-in décalé
      setTimeout(() => { span.style.opacity = String(sizeOpacity[word.size]); }, 80 + i * 60);

      // Vitesse très lente, direction aléatoire (% par seconde)
      const speed = 0.05 + Math.random() * 0.08;
      const angle = Math.random() * Math.PI * 2;
      particles.push({
        el: span, x, y,
        vx: Math.cos(angle) * speed,
        vy: Math.sin(angle) * speed,
        maxX, maxY,
      });
    });

    // Animation continue rAF avec rebond aux bords (bornes par mot)
    let lastT = performance.now();
    const tick = (now: number) => {
      const dt = Math.min((now - lastT) / 1000, 0.05);
      lastT = now;
      for (const p of particles) {
        p.x += p.vx * dt * 60;
        p.y += p.vy * dt * 60;
        if (p.x < 2 || p.x > p.maxX) { p.vx *= -1; p.x = Math.max(2, Math.min(p.maxX, p.x)); }
        if (p.y < 2 || p.y > p.maxY) { p.vy *= -1; p.y = Math.max(2, Math.min(p.maxY, p.y)); }
        p.el.style.left = `${p.x}%`;
        p.el.style.top = `${p.y}%`;
      }
      (cloud as any)._raf = requestAnimationFrame(tick);
    };
    (cloud as any)._raf = requestAnimationFrame(tick);
  }

  render();
})();
</script>
