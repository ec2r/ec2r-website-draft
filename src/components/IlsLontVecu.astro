---
/**
 * Univers 3 : "Ils l'ont vécu" — VERSION V3 COMPLÈTE
 * Merge de : Temoignages.astro + Preuves.astro + Chiffres.astro (début)
 * 
 * Structure :
 * 1. Section Chiffres (stats animées)
 * 2. Mur de témoignages complet (736, filtres secteur/impact/tags)
 * 3. Vidéos YouTube
 * 4. Musée / Timeline
 * 5. LinkedIn cards
 */
interface Props { fr: any; en: any; }
const { fr, en } = Astro.props;

import { testimonials, sectorLabels, impactLabels, allTags, allSectors, type Sector, type ImpactLevel } from '../data/testimonials';

// IDs YouTube fixes
const videoIds = ["jhq47z0GanA", "e3KEgfNuNzQ"];

// Chiffres
const statsValues = [5, 200, 18, 250];

// Tag frequency for word cloud sizing
const tagFreq: Record<string, number> = {};
testimonials.forEach(t => t.tags.forEach(tag => { tagFreq[tag] = (tagFreq[tag] || 0) + 1; }));
const topTags = Object.entries(tagFreq).sort((a, b) => b[1] - a[1]).slice(0, 25);

// Sector colors
const sectorColors: Record<Sector, string> = {
  'expertise-comptable': 'bg-blue-50 text-blue-700 border-blue-200',
  'immobilier':          'bg-green-50 text-green-700 border-green-200',
  'assurance-protection':'bg-amber-50 text-amber-700 border-amber-200',
  'industrie':           'bg-slate-100 text-slate-700 border-slate-300',
  'hospitality':         'bg-purple-50 text-purple-700 border-purple-200',
  'conseil-rh':          'bg-rose-50 text-rose-700 border-rose-200',
  'direction-generale':  'bg-navy-950/5 text-navy-950 border-navy-950/20',
};

const impactBadge: Record<ImpactLevel, string> = {
  'institutionnel': 'bg-yellow-400/20 text-yellow-800',
  'direction':      'bg-energy-dark/10 text-energy-dark',
  'operationnel':   'bg-slate-100 text-slate-600',
  'prescripteur':   'bg-blue-100 text-blue-700',
};

// Timeline colors (Preuves)
const timelineColors = [
  'bg-red-500', 'bg-yellow-400', 'bg-amber-300', 'bg-green-300', 'bg-green-600', 'bg-gradient-to-r from-green-600 to-green-400',
];
const timelineTextColors = [
  'text-red-500', 'text-yellow-500', 'text-amber-500', 'text-green-500', 'text-green-700', 'text-green-500',
];

// Word cloud data (Preuves)
const wordsData: Record<string, { large: string[]; medium: string[]; small: string[] }> = {
  fr: {
    large: ['mobilisation', "passage à l'acte", 'collectif vivant', 'méthode vivante', 'résultats concrets'],
    medium: ['chirurgical', 'engagement réel', 'IRM organisationnel', 'co-design', 'énergie collective', 'transformation durable', 'leadership', 'comportement', 'diagnostic', 'terrain'],
    small: ['protocole', 'réaliste', 'ancrage', 'mesurable', 'humain', 'continu', 'praticien', 'boucle', 'situation', 'progrès', 'vivant', 'guidage'],
  },
  en: {
    large: ['mobilisation', 'moving to action', 'living collective', 'living method', 'concrete results'],
    medium: ['surgical', 'real engagement', 'organisational MRI', 'co-design', 'collective energy', 'lasting transformation', 'leadership', 'behaviour', 'diagnosis', 'field'],
    small: ['protocol', 'realistic', 'grounding', 'measurable', 'human', 'continuous', 'practitioner', 'loop', 'situation', 'progress', 'living', 'guidance'],
  },
};
---

<div class="min-h-full bg-navy-950 relative">
  <div class="absolute inset-0 bg-gradient-to-tr from-navy-950 via-navy-900/30 to-navy-950"></div>

  <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-10 lg:py-14 space-y-16">

    <!-- ════════════════════════════════════════════════════════════════════════ -->
    <!-- 1. NUAGE DE MOTS-CLÉS + BANNIÈRE "CE SITE EST VIVANT" — EN HAUT -->
    <!--    (remplace l'ancienne section "En chiffres" — req 6gZ0QrEG/0sqfNTUS) -->
    <!-- ════════════════════════════════════════════════════════════════════════ -->
    <section class="grid lg:grid-cols-3 gap-6">
      <!-- Word cloud dynamique (2/3) -->
      <div class="lg:col-span-2 bg-white/[0.02] border border-white/[0.06] rounded-xl p-6">
        <h3 class="font-display font-semibold text-white text-lg mb-4">
          <span data-i18n-lang="fr">Ce que retiennent ceux qui ont vécu la <strong class="text-energy-green">Méthode</strong></span>
          <span data-i18n-lang="en">What those who lived the <strong class="text-energy-green">Method</strong> retain</span>
        </h3>
        <div id="word-cloud-top" class="relative h-[160px] md:h-[200px] overflow-hidden"></div>
        <p class="text-white/25 text-xs mt-3 italic">
          <span data-i18n-lang="fr">Mots-clés en temps réel — extraits des témoignages spontanés</span>
          <span data-i18n-lang="en">Real-time keywords — extracted from spontaneous testimonials</span>
        </p>
      </div>
      <!-- Bannière "Ce site est vivant" — clic pour développer -->
      <details class="bg-energy-green/[0.04] border border-energy-green/15 rounded-xl p-5 group">
        <summary class="cursor-pointer list-none">
          <div class="flex items-center justify-between">
            <h3 class="text-sm font-display font-bold text-energy-green/90">
              <span data-i18n-lang="fr">Ce site est vivant</span>
              <span data-i18n-lang="en">This site is alive</span>
            </h3>
            <svg class="w-4 h-4 text-energy-green/60 group-open:rotate-180 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
            </svg>
          </div>
          <p class="text-white/40 text-xs mt-2 italic">
            <span data-i18n-lang="fr">Pourquoi ? Cliquez pour lire.</span>
            <span data-i18n-lang="en">Why? Click to read.</span>
          </p>
        </summary>
        <p class="text-white/40 text-xs leading-relaxed mt-3">
          <span data-i18n-lang="fr">Il documente sa propre construction et notre dynamique de mobilisation. Pas un résultat figé — l'illustration du processus vivant. Nous avons utilisé la puissance<span class="plus-accent">+</span> dirigée de l'IA pour partir du réel et passer d'un savoir-faire artisanal à un mode augmenté. On essaye, on expérimente, on traduit, on améliore.</span>
          <span data-i18n-lang="en">It documents its own construction and our mobilization dynamics. Not a frozen result — the illustration of the living process. We used the directed<span class="plus-accent">+</span> power of AI to start from reality and move from artisanal know-how to augmented mode.</span>
        </p>
      </details>
    </section>

    <!-- ════════════════════════════════════════════════════════════════════════ -->
    <!-- 2. MUR DE TÉMOIGNAGES COMPLET -->
    <!-- ════════════════════════════════════════════════════════════════════════ -->
    <section>
      <div class="mb-8">
        <h2 class="text-2xl md:text-3xl lg:text-4xl font-display font-extrabold text-white mb-3">
          <span data-i18n-lang="fr">Ils l'ont vécu, la <strong class="text-energy-green">Méthode</strong></span>
          <span data-i18n-lang="en">They lived the <strong class="text-energy-green">Method</strong></span>
        </h2>
        <p class="text-base text-white/50 leading-relaxed max-w-3xl mb-6">
          <span data-i18n-lang="fr">Pas de promesses marketing, des résultats concrets avec les mots de nos clients depuis l'origine. Pas de témoignages sollicités, pas de citations anonymisées — ce sont les mots publiés <strong>spontanément</strong> par des dirigeants, des managers de terrain, des leaders. Des données <span class="plus-accent">+</span> mesurables, des comportements <span class="plus-accent">+</span> observables, un impact déjà <span class="plus-accent">+</span> réel.</span>
          <span data-i18n-lang="en">No marketing promises, concrete results in our clients' own words from the start. No solicited testimonials, no anonymized quotes — words published <strong>spontaneously</strong> by executives, field managers, leaders. Measurable<span class="plus-accent">+</span> data, observable<span class="plus-accent">+</span> behaviours, already<span class="plus-accent">+</span> real impact.</span>
        </p>

        <!-- Stats bar -->
        <div class="flex flex-wrap gap-6 mb-6">
          <div class="flex items-center gap-2">
            <span class="text-3xl font-display font-bold text-white">{testimonials.length}</span>
            <span class="text-sm text-white/40">
              <span data-i18n-lang="fr">témoignages<br/>vérifiables</span>
              <span data-i18n-lang="en">verifiable<br/>testimonials</span>
            </span>
          </div>
          <div class="flex items-center gap-2">
            <span class="text-3xl font-display font-bold text-white">{allSectors.length}</span>
            <span class="text-sm text-white/40">
              <span data-i18n-lang="fr">secteurs<br/>d'activité</span>
              <span data-i18n-lang="en">sectors<br/>of activity</span>
            </span>
          </div>
          <div class="flex items-center gap-2">
            <span class="text-3xl font-display font-bold text-energy-green">100%</span>
            <span class="text-sm text-white/40">
              <span data-i18n-lang="fr">non sollicités<br/>publics sur LinkedIn</span>
              <span data-i18n-lang="en">unsolicited<br/>public on LinkedIn</span>
            </span>
          </div>
        </div>
      </div>

      <!-- Tag cloud (clickable filters) -->
      <div class="mb-6" id="temoignages-tags">
        <div class="flex flex-wrap gap-2">
          <button class="tag-filter active px-3 py-2 rounded-full text-xs font-medium border transition-all duration-300 bg-energy-green/10 border-energy-green/30 text-energy-green" data-tag="all">
            <span data-i18n-lang="fr">Tous</span>
            <span data-i18n-lang="en">All</span>
          </button>
          {topTags.map(([tag, freq]) => (
            <button
              class="tag-filter px-3 py-2 rounded-full text-xs border transition-all duration-300 bg-white/5 text-white/40 border-white/10 hover:border-white/30 hover:text-white/70"
              data-tag={tag}
            >
              {tag} <span class="text-[10px] text-white/20 ml-1">{freq}</span>
            </button>
          ))}
        </div>
      </div>

      <!-- Sector tabs -->
      <div class="mb-6 overflow-x-auto">
        <div class="flex gap-2 min-w-max">
          <button class="sector-tab active px-4 py-2 rounded-lg text-xs font-medium transition-all duration-300 bg-energy-green/10 border border-energy-green/30 text-energy-green" data-sector="all">
            <span data-i18n-lang="fr">Tous les secteurs</span>
            <span data-i18n-lang="en">All sectors</span>
          </button>
          {allSectors.map(sector => {
            const count = testimonials.filter(t => t.sector === sector).length;
            return (
              <button
                class="sector-tab px-4 py-2 rounded-lg text-xs font-medium transition-all duration-300 bg-white/5 border border-white/10 text-white/40 hover:border-white/30 hover:text-white/70"
                data-sector={sector}
              >
                <span data-i18n-lang="fr">{sectorLabels[sector].fr}</span>
                <span data-i18n-lang="en">{sectorLabels[sector].en}</span>
                <span class="opacity-60"> ({count})</span>
              </button>
            );
          })}
        </div>
      </div>

      <!-- THE WALL (masonry layout) -->
      <div id="temoignages-wall" class="columns-1 md:columns-2 lg:columns-3 gap-4 space-y-4">
        {testimonials.map((t) => (
          <div
            class="temoignage-card break-inside-avoid bg-white/[0.03] rounded-xl p-5 border border-white/[0.06]
                   hover:border-white/15 hover:shadow-lg hover:shadow-navy-900/5
                   transition-all duration-300"
            data-tags={JSON.stringify(t.tags)}
            data-sector={t.sector}
            data-impact={t.impact}
          >
            <!-- Header: photo + name -->
            <div class="flex items-start gap-3 mb-3">
              <a href={t.linkedinUrl || '#'} target="_blank" rel="noopener noreferrer"
                 class="flex-shrink-0 w-10 h-10 rounded-full bg-white/10 border border-white/10 flex items-center justify-center overflow-hidden hover:border-energy-green/40 transition-colors group"
                 title={`Voir le profil LinkedIn de ${t.name}`}>
                {t.photoUrl ? (
                  <img src={t.photoUrl} alt={t.name} class="w-full h-full object-cover rounded-full" loading="lazy" />
                ) : (
                  <span class="text-white/30 text-xs font-bold group-hover:text-energy-green transition-colors">
                    {t.name.split(' ').map(w => w[0]).filter(c => c && c === c.toUpperCase()).slice(0, 2).join('')}
                  </span>
                )}
              </a>
              <div class="min-w-0">
                <a href={t.linkedinUrl || '#'} target="_blank" rel="noopener noreferrer"
                   class="font-display font-semibold text-white text-sm hover:text-energy-green transition-colors block truncate">
                  {t.name}
                </a>
                <p class="text-white/40 text-xs leading-snug">{t.title}</p>
                {t.company && <p class="text-white/25 text-xs">{t.company}</p>}
              </div>
            </div>

            <!-- Badges -->
            <div class="flex flex-wrap gap-1.5 mb-3">
              <span class="inline-block text-[10px] font-semibold uppercase tracking-wider px-2 py-0.5 rounded-full bg-white/10 text-white/40 border border-white/10">
                <span data-i18n-lang="fr">{sectorLabels[t.sector].fr}</span>
                <span data-i18n-lang="en">{sectorLabels[t.sector].en}</span>
              </span>
              <span class="inline-block text-[10px] font-medium px-2 py-0.5 rounded-full bg-white/5 text-white/30">
                <span data-i18n-lang="fr">{impactLabels[t.impact].fr}</span>
                <span data-i18n-lang="en">{impactLabels[t.impact].en}</span>
              </span>
            </div>

            <!-- Quote -->
            <blockquote class="text-white/60 text-sm leading-relaxed italic mb-3">
              "{t.quote}"
            </blockquote>

            <!-- Footer: year + LinkedIn link -->
            <div class="flex items-center justify-between pt-3 border-t border-white/5">
              <span class="text-xs text-white/25">{t.year}</span>
              <a href={t.postUrl} target="_blank" rel="noopener noreferrer"
                 class="text-xs text-energy-green/70 hover:text-energy-green flex items-center gap-1 transition-colors"
                 title="Voir le post original sur LinkedIn">
                <svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 24 24">
                  <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
                </svg>
                <span data-i18n-lang="fr">Voir sur LinkedIn</span>
                <span data-i18n-lang="en">See on LinkedIn</span>
              </a>
            </div>
          </div>
        ))}
      </div>

      <!-- Empty state -->
      <div id="temoignages-empty" class="hidden text-center py-16">
        <p class="text-white/40 text-lg">
          <span data-i18n-lang="fr">Aucun témoignage pour ce filtre.</span>
          <span data-i18n-lang="en">No testimonials for this filter.</span>
        </p>
        <button class="mt-4 text-energy-green text-sm font-medium hover:underline" id="temoignages-reset">
          <span data-i18n-lang="fr">Voir tous les témoignages</span>
          <span data-i18n-lang="en">See all testimonials</span>
        </button>
      </div>
    </section>

    <!-- ════════════════════════════════════════════════════════════════════════ -->
    <!-- 3. VIDÉOS YOUTUBE -->
    <!-- ════════════════════════════════════════════════════════════════════════ -->
    <section>
      <div class="flex items-center gap-3 mb-4">
        <div class="w-2 h-8 bg-gradient-to-b from-energy-red to-energy-dark rounded-full"></div>
        <h3 class="font-display font-bold text-2xl text-white">
          <span data-i18n-lang="fr">{fr.preuves?.trajTitle || 'Trajectoires'}</span>
          <span data-i18n-lang="en">{en.preuves?.trajTitle || 'Trajectories'}</span>
        </h3>
      </div>
      <p class="text-white/40 text-sm mb-2 ml-5">
        <span data-i18n-lang="fr">{fr.preuves?.trajSub || 'Vidéos de témoignages réels'}</span>
        <span data-i18n-lang="en">{en.preuves?.trajSub || 'Real testimonial videos'}</span>
      </p>
      <p class="text-white/25 text-xs mb-6 ml-5 italic">
        <span data-i18n-lang="fr">Vidéos de la trajectoire <strong class="text-energy-green not-italic">Méthode EC²R</strong> — pour l'avenir.</span>
        <span data-i18n-lang="en">Videos of the <strong class="text-energy-green not-italic">EC²R Method</strong> trajectory — for the future.</span>
      </p>
      <div class="grid md:grid-cols-2 gap-6">
        {(fr.preuves?.videos || []).slice(0, 2).map((video: any, i: number) => (
          <div class="group">
            <div class="relative aspect-video bg-navy-900 rounded-xl overflow-hidden shadow-lg group-hover:shadow-xl transition-shadow duration-300">
              <iframe src={`https://www.youtube-nocookie.com/embed/${videoIds[i]}`}
                title={video.title} class="absolute inset-0 w-full h-full" frameborder="0"
                allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
                allowfullscreen loading="lazy"></iframe>
            </div>
            <div class="mt-4">
              <h4 class="font-display font-semibold text-white">
                <span data-i18n-lang="fr">{video.title}</span>
                <span data-i18n-lang="en">{en.preuves?.videos?.[i]?.title || video.title}</span>
              </h4>
              <p class="text-sm text-energy-green font-medium">
                <span data-i18n-lang="fr">{video.subtitle}</span>
                <span data-i18n-lang="en">{en.preuves?.videos?.[i]?.subtitle || video.subtitle}</span>
              </p>
              <p class="text-sm text-white/40 mt-1">
                <span data-i18n-lang="fr">{video.description}</span>
                <span data-i18n-lang="en">{en.preuves?.videos?.[i]?.description || video.description}</span>
              </p>
            </div>
          </div>
        ))}
      </div>
    </section>

    <!-- (Section "Mur de contributions" + "Mise en abyme" supprimée — déduplication
         avec la section haut #word-cloud-top + bannière "Ce site est vivant"
         qui contient déjà ces 2 éléments — req Stéphane v1) -->

    <!-- ════════════════════════════════════════════════════════════════════════ -->
    <!-- 6. MUSÉE / TIMELINE -->
    <!-- ════════════════════════════════════════════════════════════════════════ -->
    {fr.preuves?.museeTimeline && (
      <section class="bg-white/[0.02] border border-white/[0.06] rounded-2xl p-8 md:p-10">
        <p class="text-xs text-white/30 uppercase tracking-wider font-medium mb-3">
          <span data-i18n-lang="fr">{fr.preuves?.museeLabel || 'Musée'}</span>
          <span data-i18n-lang="en">{en.preuves?.museeLabel || 'Museum'}</span>
        </p>
        <h4 class="font-display font-bold text-xl text-white mb-3">
          <span data-i18n-lang="fr">{fr.preuves?.museeTitle || 'Trajectoire énergétique'}</span>
          <span data-i18n-lang="en">{en.preuves?.museeTitle || 'Energy trajectory'}</span>
        </h4>
        <p class="text-white/50 leading-relaxed mb-8">
          <span data-i18n-lang="fr">{fr.preuves?.museeSub || '2018 → 2025'}</span>
          <span data-i18n-lang="en">{en.preuves?.museeSub || '2018 → 2025'}</span>
        </p>

        <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-6 gap-4">
          {fr.preuves.museeTimeline.map((item: any, i: number) => (
            <div class={`${i === 5 ? 'ring-1 ring-green-500/30 bg-green-500/[0.03]' : ''} rounded-lg p-4`}>
              <div class={`h-1 ${timelineColors[i]} rounded-full mb-3`}></div>
              <p class={`font-display font-bold text-lg ${timelineTextColors[i]}`}>{item.year}</p>
              <p class="font-display font-semibold text-white text-sm mb-1">
                <span data-i18n-lang="fr">{item.label}</span>
                <span data-i18n-lang="en">{en.preuves?.museeTimeline?.[i]?.label || item.label}</span>
              </p>
              <p class="text-white/40 text-xs leading-relaxed">
                <span data-i18n-lang="fr">{item.sub}</span>
                <span data-i18n-lang="en">{en.preuves?.museeTimeline?.[i]?.sub || item.sub}</span>
              </p>
            </div>
          ))}
        </div>
      </section>
    )}

  </div>
</div>

<script>
// ═══ FILTRES TÉMOIGNAGES ═══
document.addEventListener('DOMContentLoaded', () => {
  const wall = document.getElementById('temoignages-wall');
  const empty = document.getElementById('temoignages-empty');
  const cards = document.querySelectorAll<HTMLElement>('.temoignage-card');
  const tagBtns = document.querySelectorAll<HTMLButtonElement>('.tag-filter');
  const sectorBtns = document.querySelectorAll<HTMLButtonElement>('.sector-tab');
  const resetBtn = document.getElementById('temoignages-reset');

  let activeTag = 'all';
  let activeSector = 'all';

  function filterCards() {
    let visibleCount = 0;
    cards.forEach(card => {
      const tags: string[] = JSON.parse(card.dataset.tags || '[]');
      const sector = card.dataset.sector || '';

      const tagMatch = activeTag === 'all' || tags.includes(activeTag);
      const sectorMatch = activeSector === 'all' || sector === activeSector;

      if (tagMatch && sectorMatch) {
        card.style.display = '';
        visibleCount++;
      } else {
        card.style.display = 'none';
      }
    });

    if (wall) wall.style.display = visibleCount > 0 ? '' : 'none';
    if (empty) empty.style.display = visibleCount === 0 ? 'block' : 'none';
  }

  function setActiveTag(tag: string) {
    activeTag = tag;
    tagBtns.forEach(btn => {
      const isActive = btn.dataset.tag === tag;
      if (isActive) {
        btn.classList.add('bg-energy-green/10', 'border-energy-green/30', 'text-energy-green', 'active');
        btn.classList.remove('bg-white/5', 'text-white/40', 'border-white/10');
      } else {
        btn.classList.remove('bg-energy-green/10', 'border-energy-green/30', 'text-energy-green', 'active');
        btn.classList.add('bg-white/5', 'text-white/40', 'border-white/10');
      }
    });
    filterCards();
  }

  function setActiveSector(sector: string) {
    activeSector = sector;
    sectorBtns.forEach(btn => {
      const isActive = btn.dataset.sector === sector;
      if (isActive) {
        btn.classList.add('bg-energy-green/10', 'border-energy-green/30', 'text-energy-green', 'active');
        btn.classList.remove('bg-white/5', 'text-white/40', 'border-white/10');
      } else {
        btn.classList.remove('bg-energy-green/10', 'border-energy-green/30', 'text-energy-green', 'active');
        btn.classList.add('bg-white/5', 'text-white/40', 'border-white/10');
      }
    });
    filterCards();
  }

  tagBtns.forEach(btn => {
    btn.addEventListener('click', () => setActiveTag(btn.dataset.tag || 'all'));
  });

  sectorBtns.forEach(btn => {
    btn.addEventListener('click', () => setActiveSector(btn.dataset.sector || 'all'));
  });

  resetBtn?.addEventListener('click', () => {
    setActiveTag('all');
    setActiveSector('all');
  });
});

// ═══ COMPTEURS CHIFFRES ═══
const counters = document.querySelectorAll('.counter-value[data-target]');
const counterObserver = new IntersectionObserver((entries) => {
  entries.forEach(entry => {
    if (entry.isIntersecting) {
      const el = entry.target as HTMLElement;
      const target = parseInt(el.dataset.target || '0');
      const duration = 2000;
      const start = performance.now();
      const animate = (now: number) => {
        const elapsed = now - start;
        const progress = Math.min(elapsed / duration, 1);
        const eased = 1 - Math.pow(1 - progress, 3);
        el.textContent = Math.round(target * eased).toString();
        if (progress < 1) requestAnimationFrame(animate);
      };
      requestAnimationFrame(animate);
      counterObserver.unobserve(el);
    }
  });
}, { threshold: 0.5 });
counters.forEach(counter => counterObserver.observe(counter));

// ═══ WORD CLOUD DYNAMIQUE (en haut de section, id=word-cloud-top) ═══
(() => {
  const cloud = document.getElementById('word-cloud-top');
  if (!cloud) return;

  const wordsData: Record<string, { large: string[]; medium: string[]; small: string[] }> = {
    fr: {
      large: ['mobilisation', "passage à l'acte", 'collectif vivant', 'méthode vivante', 'résultats concrets'],
      medium: ['chirurgical', 'engagement réel', 'IRM organisationnel', 'co-design', 'énergie collective', 'transformation durable', 'leadership', 'comportement', 'diagnostic', 'terrain'],
      small: ['protocole', 'réaliste', 'ancrage', 'mesurable', 'humain', 'continu', 'praticien', 'boucle', 'situation', 'progrès', 'vivant', 'guidage'],
    },
    en: {
      large: ['mobilisation', 'moving to action', 'living collective', 'living method', 'concrete results'],
      medium: ['surgical', 'real engagement', 'organisational MRI', 'co-design', 'collective energy', 'lasting transformation', 'leadership', 'behaviour', 'diagnosis', 'field'],
      small: ['protocol', 'realistic', 'grounding', 'measurable', 'human', 'continuous', 'practitioner', 'loop', 'situation', 'progress', 'living', 'guidance'],
    },
  };

  const sizeClasses: Record<string, string> = {
    large: 'text-xl md:text-2xl font-bold text-white',
    medium: 'text-sm md:text-base font-medium text-white/60',
    small: 'text-xs text-white/30',
  };

  const sizeOpacity: Record<string, number> = { large: 1, medium: 0.7, small: 0.4 };

  function render() {
    const lang = document.documentElement.getAttribute('data-lang') || 'fr';
    const words = wordsData[lang] || wordsData.fr;
    cloud!.innerHTML = '';

    const allWords = [
      ...words.large.map((w: string) => ({ text: w, size: 'large' })),
      ...words.medium.map((w: string) => ({ text: w, size: 'medium' })),
      ...words.small.map((w: string) => ({ text: w, size: 'small' })),
    ];

    // Shuffle
    for (let i = allWords.length - 1; i > 0; i--) {
      const j = Math.floor(Math.random() * (i + 1));
      [allWords[i], allWords[j]] = [allWords[j], allWords[i]];
    }

    allWords.forEach((word, i) => {
      const span = document.createElement('span');
      span.textContent = word.text;
      span.className = `absolute ${sizeClasses[word.size]} transition-all duration-1000 opacity-0`;
      span.style.left = `${5 + Math.random() * 80}%`;
      span.style.top = `${5 + Math.random() * 80}%`;
      cloud!.appendChild(span);

      setTimeout(() => {
        span.style.opacity = String(sizeOpacity[word.size]);
      }, 100 + i * 80);
    });
  }

  render();

  new MutationObserver(render).observe(
    document.documentElement, { attributes: true, attributeFilter: ['data-lang'] }
  );

  setInterval(() => {
    const spans = cloud!.querySelectorAll('span');
    spans.forEach((s: any) => {
      const dx = (Math.random() - 0.5) * 3;
      const dy = (Math.random() - 0.5) * 2;
      const left = parseFloat(s.style.left) + dx;
      const top = parseFloat(s.style.top) + dy;
      s.style.left = `${Math.max(2, Math.min(90, left))}%`;
      s.style.top = `${Math.max(2, Math.min(88, top))}%`;
    });
  }, 4000);
})();
</script>
