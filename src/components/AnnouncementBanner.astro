---
/**
 * Bandeau d'annonce — teaser lancement semaine prochaine
 * Discret, en haut de page, dismissable
 */
import type { Lang } from '../i18n/translations';
interface Props { lang: Lang }
const { lang } = Astro.props;
---

<div id="announcement-banner"
     class="fixed top-0 left-0 right-0 z-[100]
            bg-energy-green/95 text-ink
            px-3 py-2 text-center text-sm font-medium
            transition-all duration-300">
  <div class="flex items-center justify-center gap-2 pr-8">
    <span class="inline-flex items-center gap-2 flex-wrap justify-center">
      <!-- Pulse indicator (hidden on mobile to save space) -->
      <span class="relative hidden sm:flex h-2 w-2 shrink-0">
        <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-surface opacity-50"></span>
        <span class="relative inline-flex rounded-full h-2 w-2 bg-surface"></span>
      </span>
      <span class="text-xs sm:text-sm">
        {lang === 'fr' ? (
          <Fragment>Accès anticipé — lancement officiel <strong>la semaine prochaine</strong></Fragment>
        ) : (
          <Fragment>Early access — official launch <strong>next week</strong></Fragment>
        )}
      </span>
      <a href="#parlons-en"
         class="underline underline-offset-2 font-semibold hover:no-underline transition-all text-xs sm:text-sm whitespace-nowrap"
         onclick="document.getElementById('parlons-en')?.scrollIntoView({behavior:'smooth'})">
        {lang === 'fr' ? 'Parlons-en →' : "Let's talk →"}
      </a>
    </span>
  </div>
  <button id="close-announcement"
          class="absolute right-2 top-1/2 -translate-y-1/2 p-1 opacity-50 hover:opacity-100 transition-opacity"
          aria-label={lang === 'fr' ? 'Fermer' : 'Close'}>
    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
    </svg>
  </button>
</div>

<!-- Spacer pour compenser la hauteur du bandeau -->
<div id="announcement-spacer" class="h-10 sm:h-9"></div>

<script is:inline>
  // Pose la classe AVANT le paint pour éviter un saut visuel
  (function(){
    if (sessionStorage.getItem('ec2r-banner-closed') === '1') {
      document.documentElement.classList.add('banner-closed');
    }
  })();
</script>
<script>
  const banner = document.getElementById('announcement-banner');
  const spacer = document.getElementById('announcement-spacer');
  const closeBtn = document.getElementById('close-announcement');

  if (document.documentElement.classList.contains('banner-closed')) {
    banner?.classList.add('hidden');
    spacer?.classList.add('hidden');
  }

  closeBtn?.addEventListener('click', () => {
    banner?.classList.add('hidden');
    spacer?.classList.add('hidden');
    document.documentElement.classList.add('banner-closed');
    sessionStorage.setItem('ec2r-banner-closed', '1');
  });
</script>
