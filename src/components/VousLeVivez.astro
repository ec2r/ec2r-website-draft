---
/**
 * Univers 1 : "Vous le vivez"
 * Page d'arrivée — Logo batterie, taglines animées, 6+1 onglets énergie
 * Porte le contenu de l'ancien Hero.astro + Situations.astro
 */
interface Props { fr: any; en: any; }
const { fr, en } = Astro.props;

const energyColors = ['#DC2626','#EAB308','#C9A56E','#22C55E','#166534','#3B82F6','#8B5CF6'];
const energyLabels = ['E1','E2','E3','E4','E5','E6','↗'];
---

<div class="min-h-full bg-surface relative flex flex-col">
  <div class="absolute inset-0 bg-gradient-to-br from-surface via-surface-alt to-surface"></div>
  <div class="absolute inset-0 grid-overlay"></div>

  <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pt-20 pb-16 flex-1 flex flex-col justify-center">

    <!-- Compteurs live -->
    <div class="flex flex-wrap justify-center text-center gap-4 mb-4 text-xs text-ink-faint">
      <div class="flex items-center gap-2">
        <span class="w-2 h-2 rounded-full bg-accent animate-pulse"></span>
        <span data-i18n-lang="fr">EC2R Conseil depuis le 1er juillet 2021 —</span>
        <span data-i18n-lang="en">EC2R Conseil since July 1, 2021 —</span>
        <span id="counter-ec2r" class="font-mono text-ink-subtle"></span>
      </div>
      <div class="flex items-center gap-2">
        <span class="w-2 h-2 rounded-full bg-accent animate-pulse"></span>
        <span data-i18n-lang="fr">Protocole augmenté depuis le 11 mars 2026 —</span>
        <span data-i18n-lang="en">Augmented protocol since March 11, 2026 —</span>
        <span id="counter-proto" class="font-mono text-ink-subtle"></span>
      </div>
    </div>

    <div class="grid lg:grid-cols-2 gap-8 lg:gap-12 items-start flex-1">

      <!-- Gauche : branding + taglines -->
      <div>
        <!-- Phrase d'accroche unique dominante -->
        <p class="text-2xl md:text-3xl lg:text-4xl font-display text-ink leading-tight max-w-lg mb-6">
          <span data-i18n-lang="fr">Vos collectifs ont besoin d'énergie et de savoir comment passer<span class="plus-accent">+</span> vite à l'action et pas à l'acte.</span>
          <span data-i18n-lang="en">Your collectives need energy and to know how to take action faster<span class="plus-accent">+</span>, not just plan it.</span>
        </p>

        <!-- Tagline EC2R animée -->
        <div class="mb-6">
          <h1 class="text-2xl md:text-3xl lg:text-4xl font-display font-extrabold text-ink leading-[1.1] mb-2">
            <span data-i18n-lang="fr">La méthode<span class="plus-accent">+</span> vivante</span>
            <span data-i18n-lang="en">The living method<span class="plus-accent">+</span></span>
            <br/>
            <span class="energy-gradient-text">EC²R</span>
          </h1>

          <div class="space-y-0.5 text-base md:text-lg font-mono mt-4" id="ec2r-decomposition">
            <div class="flex items-center gap-2 opacity-0 ec2r-line" style="transition:opacity 0.3s">
              <span class="text-accent font-bold text-xl w-7">E</span>
              <span class="text-ink-disabled">···</span>
              <span class="text-ink-muted"><span class="plus-accent">+</span>Énergies</span>
            </div>
            <div class="flex items-center gap-2 opacity-0 ec2r-line" style="transition:opacity 0.3s">
              <span class="text-accent font-bold text-xl w-7">C</span>
              <span class="text-ink-disabled">···</span>
              <span class="text-ink-muted"><span class="plus-accent">+</span>Collectives</span>
            </div>
            <div class="flex items-center gap-2 opacity-0 ec2r-line" style="transition:opacity 0.3s">
              <span class="text-accent font-bold text-xl w-7">C</span>
              <span class="text-ink-disabled">···</span>
              <span class="plus-accent">+</span><span id="c2-cycling" class="text-ink font-semibold"></span><span class="text-energy-green/50 animate-pulse">_</span>
            </div>
            <div class="flex items-center gap-2 opacity-0 ec2r-line" style="transition:opacity 0.3s">
              <span class="text-accent font-bold text-xl w-7">R</span>
              <span class="text-ink-disabled">···</span>
              <span class="plus-accent">+</span><span id="r-cycling" class="text-ink font-semibold"></span><span class="text-energy-green/50 animate-pulse">_</span>
            </div>
          </div>
        </div>

        <!-- Waze tagline (tout en blanc, "Le Waze" en gradient énergie) -->
        <p class="text-lg md:text-xl text-ink leading-relaxed max-w-lg mb-3 font-semibold">
          <span class="line-through decoration-white/40">
            <span data-i18n-lang="fr">Pas le Netflix </span>
            <span data-i18n-lang="en">Not the Netflix of </span>
            <strong id="netflix-word" class="text-ink">de la formation</strong>.
          </span><br/>
          <span class="energy-gradient-text font-bold" data-i18n-lang="fr">Le Waze </span>
          <span class="energy-gradient-text font-bold" data-i18n-lang="en">The Waze of </span>
          <strong id="waze-word" class="text-ink">de la mobilisation collective</strong>.
        </p>

        <!-- IRM baseline -->
        <p class="text-sm text-ink-faint leading-relaxed max-w-lg mb-6">
          <span data-i18n-lang="fr">Votre IRM<span class="plus-accent">+</span> organisationnel qui mesure vos énergies collectives, identifie <span class="plus-accent">+</span> chirurgicalement vos leviers de mobilisation et accompagne votre passage à l'acte jusqu'au micro-comportement dans vos situations quotidiennes.</span>
          <span data-i18n-lang="en">Your organizational MRI<span class="plus-accent">+</span> that measures your collective energies, identifies <span class="plus-accent">+</span> surgically your mobilization levers and supports your transition to action down to micro-behaviours in your daily situations.</span>
        </p>
      </div>

      <!-- Droite : 6+1 onglets énergie -->
      <div>
        <p class="text-sm text-ink mb-3 font-medium">
          <span data-i18n-lang="fr">Créez des collectifs qui agissent réellement — pas juste qui aimera faire ou se sentent bien au travail.</span>
          <span data-i18n-lang="en">Build collectives that truly act — not just want to or feel good at work.</span>
        </p>

        <div class="space-y-1.5" id="situations-accordion">
          {fr.situations.map((s: any, i: number) => (
            <div class="sit-item rounded-lg overflow-hidden bg-surface-raised border border-border-subtle transition-all duration-200 hover:bg-surface-raised hover:border-accent/40 hover:shadow-lg hover:shadow-energy-green/5" data-idx={i}>
              <button class="sit-trigger w-full text-left px-3 py-3 flex items-center gap-2.5 group cursor-pointer" aria-expanded="false">
                <span class="shrink-0 w-7 h-8 flex items-center justify-center rounded border text-[10px] font-bold transition-colors"
                      style={`border-color: ${energyColors[i]}60; color: ${energyColors[i]}; background: ${energyColors[i]}12`}>
                  {energyLabels[i]}
                </span>
                <span class="text-ink text-sm leading-snug flex-1 sit-accroche font-medium"
                      data-fr={s.accroche} data-en={en.situations[i].accroche}>{s.accroche}</span>
                <span class="sit-cta shrink-0 hidden md:flex items-center gap-1 text-[10px] uppercase tracking-wider text-accent/60 group-hover:text-accent font-semibold transition-colors">
                  <span data-i18n-lang="fr">Voir</span>
                  <span data-i18n-lang="en">View</span>
                </span>
                <span class="sit-arrow shrink-0 text-accent/70 group-hover:text-accent group-hover:translate-y-0.5 transition-all">
                  <svg width="16" height="16" viewBox="0 0 14 14" fill="none">
                    <path d="M3.5 5.25L7 8.75L10.5 5.25" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
                  </svg>
                </span>
              </button>

              <div class="sit-panel hidden">
                <div class="flex border-t border-border-subtle text-xs">
                  <button class="sit-tab active-tab flex-1 py-1.5 px-2 text-center font-semibold tracking-wide transition-colors" data-tab="0">
                    <span data-i18n-lang="fr">Ce qui se passe</span><span data-i18n-lang="en">What's happening</span>
                  </button>
                  <button class="sit-tab flex-1 py-1.5 px-2 text-center font-semibold tracking-wide transition-colors" data-tab="1">
                    <span data-i18n-lang="fr">Vous avez essayé — ou vous ne voulez pas vous limiter à</span><span data-i18n-lang="en">You've tried — or you don't want to limit yourself to</span>
                  </button>
                  <button class="sit-tab flex-1 py-1.5 px-2 text-center font-semibold tracking-wide transition-colors" data-tab="2">
                    <span data-i18n-lang="fr">Notre réponse</span><span data-i18n-lang="en">Our answer</span>
                  </button>
                </div>
                <div class="sit-content border-t border-border-subtle relative" style="min-height:80px">
                  <div class="sit-pane px-3 py-2.5 absolute inset-0 transition-opacity" data-pane="0" style="opacity:1;pointer-events:auto">
                    <p class="text-ink-faint text-sm leading-relaxed sit-passe" data-fr={s.ceQuiSePasse} data-en={en.situations[i].ceQuiSePasse}>{s.ceQuiSePasse}</p>
                  </div>
                  <div class="sit-pane px-3 py-2.5 absolute inset-0 transition-opacity" data-pane="1" style="opacity:0;pointer-events:none">
                    <ul class="space-y-0.5 mb-1 sit-essaye-list" data-fr={JSON.stringify(s.essaye)} data-en={JSON.stringify(en.situations[i].essaye)}>
                      {s.essaye.map((e: string) => (
                        <li class="text-ink-subtle text-sm flex items-start gap-1.5">
                          <span class="text-ink-muted mt-0.5 shrink-0">–</span><span>{e}</span>
                        </li>
                      ))}
                    </ul>
                    <p class="text-ink-subtle text-xs italic sit-conclusion" data-fr={s.essayeConclusion} data-en={en.situations[i].essayeConclusion}>{s.essayeConclusion}</p>
                  </div>
                  <div class="sit-pane px-3 py-2.5 absolute inset-0 transition-opacity" data-pane="2" style="opacity:0;pointer-events:none">
                    <p class="text-ink-muted text-sm leading-relaxed sit-reponse" data-fr={s.reponse} data-en={en.situations[i].reponse}>{s.reponse}</p>
                  </div>
                </div>
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>

    <!-- CTA scroll vers la méthode -->
    <div class="text-center mt-10">
      <a href="#diff-points" class="inline-flex items-center gap-1.5 text-accent text-xs font-semibold uppercase tracking-wider hover:text-accent/80 transition-colors animate-bounce" aria-label="Voir la méthode">
        <span data-i18n-lang="fr">Voir la méthode</span>
        <span data-i18n-lang="en">See the method</span>
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3" /></svg>
      </a>
    </div>
  </div>
</div>

<!-- Cycling data store -->
<div id="vlv-cycling-data" hidden
  data-netflix-fr={JSON.stringify((fr.hero as any).sub1Cycling || ['de la formation','du conseil','du co-développement','du management','de la RH'])}
  data-netflix-en={JSON.stringify((en.hero as any).sub1Cycling || ['training','consulting','co-development','management','HR'])}
  data-waze-fr={JSON.stringify((fr.hero as any).sub1bCycling || ['de la mobilisation collective','des comportements de leadership','des micro-comportements décisifs','du changement'])}
  data-waze-en={JSON.stringify((en.hero as any).sub1bCycling || ['collective mobilisation','leadership behaviours','decisive micro-behaviours','change'])}
  data-c2-fr={JSON.stringify((fr.hero as any).ec2rLines?.c2cycling || ['Croissance','Changement','Comportement'])}
  data-c2-en={JSON.stringify((en.hero as any).ec2rLines?.c2cycling || ['Growth','Change','Behaviour'])}
  data-r-fr={JSON.stringify((fr.hero as any).ec2rLines?.rCycling || ['Responsable','Réaliste','Rapide','Rassurant'])}
  data-r-en={JSON.stringify((en.hero as any).ec2rLines?.rCycling || ['Responsible','Realistic','Rapid','Reassuring'])}
></div>

<style>
  .sit-tab { color: rgb(var(--ink-faint)); }
  .sit-tab:hover { color: rgb(var(--ink-muted)); background: rgb(var(--surface-raised) / 0.6); }
  .sit-tab.active-tab { color: rgb(var(--accent)); background: rgb(var(--accent) / 0.08); }
</style>

<script>
  // ── Compteurs live ──
  function updateCounters() {
    const fiveYearsStart = new Date('2021-07-01T00:00:00').getTime();
    const ec2rStart = new Date('2021-07-01T00:00:00').getTime();
    const protoStart = new Date('2026-03-11T00:00:00').getTime();
    const now = Date.now();

    function fmt(ms: number) {
      const d = Math.floor(ms / 86400000);
      const h = Math.floor((ms % 86400000) / 3600000);
      const m = Math.floor((ms % 3600000) / 60000);
      const s = Math.floor((ms % 60000) / 1000);
      return `${d}j ${String(h).padStart(2,'0')}:${String(m).padStart(2,'0')}:${String(s).padStart(2,'0')}`;
    }

    const el0 = document.getElementById('counter-5ans');
    const el1 = document.getElementById('counter-ec2r');
    const el2 = document.getElementById('counter-proto');
    if (el0) el0.textContent = fmt(now - fiveYearsStart);
    if (el1) el1.textContent = fmt(now - ec2rStart);
    if (el2) el2.textContent = fmt(now - protoStart);
  }
  setInterval(updateCounters, 1000);
  updateCounters();

  // ── EC2R decomposition typewriter (i18n FR/EN) ──
  const c2El = document.getElementById('c2-cycling')! as HTMLElement;
  const rEl = document.getElementById('r-cycling')! as HTMLElement;
  const cyclingDataEl = document.getElementById('vlv-cycling-data')!;
  const c2WordsFr: string[] = JSON.parse(cyclingDataEl.dataset.c2Fr || '["Croissance","Changement","Comportement"]');
  const c2WordsEn: string[] = JSON.parse(cyclingDataEl.dataset.c2En || '["Growth","Change","Behaviour"]');
  const rWordsFr:  string[] = JSON.parse(cyclingDataEl.dataset.rFr  || '["Responsable","Réaliste","Rapide","Rassurant"]');
  const rWordsEn:  string[] = JSON.parse(cyclingDataEl.dataset.rEn  || '["Responsible","Realistic","Rapid","Reassuring"]');
  let c2i = 0, ri = 0;

  function typewriter(el: HTMLElement, wordsFr: string[], wordsEn: string[], idxRef: {v:number}, cb: ()=>void) {
    const lang = document.documentElement.getAttribute('data-lang') || 'fr';
    const words = lang === 'en' ? wordsEn : wordsFr;
    const word = words[idxRef.v];
    idxRef.v = (idxRef.v + 1) % words.length;
    let i = 0;
    el.textContent = '';
    const t = setInterval(() => {
      el.textContent = word.slice(0, ++i);
      if (i >= word.length) {
        clearInterval(t);
        setTimeout(() => {
          let j = word.length;
          const e = setInterval(() => {
            el.textContent = word.slice(0, --j);
            if (j <= 0) { clearInterval(e); cb(); }
          }, 40);
        }, 1800);
      }
    }, 55);
  }
  function cycleC2() {
    const ref = { v: c2i };
    typewriter(c2El, c2WordsFr, c2WordsEn, ref, () => {
      c2i = ref.v;
      setTimeout(cycleC2, 200);
    });
  }
  function cycleR() {
    const ref = { v: ri };
    typewriter(rEl, rWordsFr, rWordsEn, ref, () => {
      ri = ref.v;
      setTimeout(cycleR, 200);
    });
  }

  // Reveal lines
  const lines = document.querySelectorAll<HTMLElement>('#ec2r-decomposition .ec2r-line');
  lines.forEach((l,i)=>setTimeout(()=>{l.style.opacity='1';if(i===2)setTimeout(cycleC2,200);if(i===3)setTimeout(cycleR,600);},i*300));

  // ── Netflix / Waze cycling ──
  const data = document.getElementById('vlv-cycling-data')!;
  const nFr: string[] = JSON.parse(data.dataset.netflixFr||'[]');
  const wFr: string[] = JSON.parse(data.dataset.wazeFr||'[]');
  const nEl = document.getElementById('netflix-word');
  const wEl = document.getElementById('waze-word');
  let ni=0, wi=0;
  setInterval(()=>{if(!nEl)return;nEl.style.opacity='0';setTimeout(()=>{nEl.textContent=nFr[ni];nEl.style.opacity='1';ni=(ni+1)%nFr.length;},200);},2500);
  setInterval(()=>{if(!wEl)return;wEl.style.opacity='0';setTimeout(()=>{wEl.textContent=wFr[wi];wEl.style.opacity='1';wi=(wi+1)%wFr.length;},200);},3200);

  // ── Accordion ──
  document.addEventListener('DOMContentLoaded', () => {
    const items = document.querySelectorAll('#situations-accordion .sit-item');
    items.forEach(item => {
      const trigger = item.querySelector('.sit-trigger')!;
      const panel = item.querySelector('.sit-panel')!;
      const arrow = item.querySelector('.sit-arrow') as HTMLElement;
      const tabs = item.querySelectorAll('.sit-tab');
      const panes = item.querySelectorAll('.sit-pane');
      const content = item.querySelector('.sit-content') as HTMLElement;

      function lockHeight(){content.style.height='';let max=0;panes.forEach((p:any)=>{const s={o:p.style.opacity,pe:p.style.pointerEvents,pos:p.style.position};p.style.opacity='0';p.style.pointerEvents='none';p.style.position='relative';max=Math.max(max,p.offsetHeight);p.style.opacity=s.o;p.style.pointerEvents=s.pe;p.style.position=s.pos;});content.style.height=max+'px';}

      trigger.addEventListener('click',()=>{
        const open=!panel.classList.contains('hidden');
        items.forEach(it=>{it.querySelector('.sit-panel')!.classList.add('hidden');(it.querySelector('.sit-arrow')as HTMLElement).style.transform='';});
        if(!open){panel.classList.remove('hidden');arrow.style.transform='rotate(180deg)';lockHeight();switchPane(0);}
      });

      let cur=0;
      function switchPane(idx:number){cur=idx;tabs.forEach((t,i)=>t.classList.toggle('active-tab',i===idx));panes.forEach((p:any,i)=>{p.style.opacity=i===idx?'1':'0';p.style.pointerEvents=i===idx?'auto':'none';});}
      tabs.forEach(t=>t.addEventListener('click',()=>switchPane(parseInt((t as HTMLElement).dataset.tab||'0'))));

      // Swipe
      let sx=0;
      content.addEventListener('touchstart',(e:any)=>{sx=e.changedTouches[0].clientX},{passive:true});
      content.addEventListener('touchend',(e:any)=>{const dx=e.changedTouches[0].clientX-sx;if(Math.abs(dx)<40)return;switchPane(dx<0?Math.min(cur+1,2):Math.max(cur-1,0));},{passive:true});
    });

    // i18n situations
    function updateSitLang(lang:string){
      document.querySelectorAll('.sit-accroche').forEach((el:any)=>{el.textContent=el.dataset[lang]||el.dataset.fr;});
      document.querySelectorAll('.sit-passe').forEach((el:any)=>{el.textContent=el.dataset[lang]||el.dataset.fr;});
      document.querySelectorAll('.sit-conclusion').forEach((el:any)=>{el.textContent=el.dataset[lang]||el.dataset.fr;});
      document.querySelectorAll('.sit-reponse').forEach((el:any)=>{el.textContent=el.dataset[lang]||el.dataset.fr;});
      document.querySelectorAll('.sit-essaye-list').forEach((el:any)=>{const items=JSON.parse(el.dataset[lang]||el.dataset.fr);el.innerHTML=items.map((e:string)=>`<li class="text-ink-subtle text-sm flex items-start gap-1.5"><span class="text-ink-muted mt-0.5 shrink-0">–</span><span>${e}</span></li>`).join('');});
    }
    new MutationObserver(()=>updateSitLang(document.documentElement.getAttribute('data-lang')||'fr')).observe(document.documentElement,{attributes:true,attributeFilter:['data-lang']});
    updateSitLang(document.documentElement.getAttribute('data-lang')||'fr');
  });
</script>
